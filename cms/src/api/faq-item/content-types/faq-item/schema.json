{
  "kind": "collectionType",
  "collectionName": "faq_items",
  "info": {
    "singularName": "faq-item",
    "pluralName": "faq-items",
    "displayName": "FAQ Item"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "question": {
      "type": "string",
      "required": true
    },
    "answer": {
      "type": "richtext",
      "required": true
    },
    "sortOrder": {
      "type": "integer",
      "default": 0
    },
    "searchTags": {
      "type": "text"
    },
    "faq_category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::faq-category.faq-category",
      "inversedBy": "faq_items"
    }
  }
}
