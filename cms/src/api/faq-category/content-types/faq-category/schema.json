{
  "kind": "collectionType",
  "collectionName": "faq_categories",
  "info": {
    "singularName": "faq-category",
    "pluralName": "faq-categories",
    "displayName": "FAQ Category"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "sortOrder": {
      "type": "integer",
      "default": 0
    },
    "faq_items": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::faq-item.faq-item",
      "mappedBy": "faq_category"
    }
  }
}
