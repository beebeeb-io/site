---
import Base from '../layouts/base.astro';
---

<Base
  title="Bug Bounty — Beebeeb"
  description="Beebeeb's responsible disclosure program. Report security vulnerabilities in beebeeb.io and earn rewards from €100 to €5,000."
  path="/bug-bounty"
>
  <div class="px-8 py-20 max-w-[780px] mx-auto">

    <div class="mb-10">
      <div class="section-label mb-4">Security</div>
      <h1 class="text-[40px] font-bold tracking-[-0.025em] leading-tight mb-4">
        Bug Bounty Program
      </h1>
      <p class="text-[15px] leading-relaxed" style="color: var(--color-ink-2);">
        We believe security researchers make products safer for everyone.
        If you find a vulnerability in Beebeeb, we want to hear from you — and we'll pay for the disclosure.
      </p>
    </div>

    <!-- Reward table -->
    <div class="mb-12">
      <h2 class="text-[20px] font-semibold tracking-tight mb-5">Rewards</h2>
      <div class="rounded-xl border overflow-hidden" style="border-color: var(--color-line);">
        <div class="grid text-[11px] font-semibold uppercase tracking-wider px-5 py-2.5"
          style="grid-template-columns: 1fr 1fr 2fr; background: var(--color-paper-2); border-bottom: 1px solid var(--color-line); color: var(--color-ink-4);">
          <span>Severity</span>
          <span>Reward</span>
          <span>Examples</span>
        </div>

        {[
          {
            level: 'Critical',
            reward: '€5,000',
            bg: 'oklch(0.98 0.01 15)',
            badge: 'oklch(0.55 0.18 25)',
            badgeBg: 'oklch(0.95 0.04 25)',
            examples: 'RCE, authentication bypass, mass data exposure, cryptographic break',
          },
          {
            level: 'High',
            reward: '€2,000',
            bg: 'var(--color-paper)',
            badge: 'oklch(0.55 0.15 50)',
            badgeBg: 'oklch(0.95 0.04 50)',
            examples: 'Privilege escalation, unauthorized file access, account takeover',
          },
          {
            level: 'Medium',
            reward: '€500',
            bg: 'var(--color-paper-2)',
            badge: 'var(--color-amber-deep)',
            badgeBg: 'var(--color-amber-bg)',
            examples: 'CSRF, stored XSS, insecure direct object reference',
          },
          {
            level: 'Low',
            reward: '€100',
            bg: 'var(--color-paper)',
            badge: 'var(--color-ink-3)',
            badgeBg: 'var(--color-paper-3)',
            examples: 'Reflected XSS (requires interaction), verbose error messages, open redirect',
          },
        ].map((row, i) => (
          <div class="grid gap-4 px-5 py-4 items-start"
            style={`grid-template-columns: 1fr 1fr 2fr; background: ${row.bg}; ${i > 0 ? 'border-top: 1px solid var(--color-line);' : ''}`}>
            <span class="inline-flex items-center self-start">
              <span class="text-[11.5px] font-semibold px-2.5 py-0.5 rounded-full"
                style={`color: ${row.badge}; background: ${row.badgeBg};`}>
                {row.level}
              </span>
            </span>
            <span class="text-[15px] font-semibold font-mono" style="color: var(--color-ink);">{row.reward}</span>
            <span class="text-[13px] leading-relaxed" style="color: var(--color-ink-3);">{row.examples}</span>
          </div>
        ))}
      </div>
      <p class="text-[12px] mt-3" style="color: var(--color-ink-4);">
        Rewards are determined by severity, impact, and report quality.
        Duplicate reports receive no reward. Final determination is at our discretion.
      </p>
    </div>

    <!-- In scope -->
    <div class="mb-10">
      <h2 class="text-[20px] font-semibold tracking-tight mb-4">In scope</h2>
      <ul class="scope-list">
        <li><code>api.beebeeb.io</code> — REST API server</li>
        <li><code>app.beebeeb.io</code> — Web application</li>
        <li><code>beebeeb.io</code> — Marketing site</li>
        <li>GitHub repositories under <a href="https://github.com/beebeeb-io" target="_blank" rel="noopener">github.com/beebeeb-io</a> (client-side code)</li>
      </ul>
    </div>

    <!-- Out of scope -->
    <div class="mb-10">
      <h2 class="text-[20px] font-semibold tracking-tight mb-4">Out of scope</h2>
      <ul class="scope-list oos">
        <li>Denial-of-service attacks (network or application layer)</li>
        <li>Social engineering or phishing against Beebeeb staff</li>
        <li>Stripe, Hetzner, Cloudflare, or other third-party services</li>
        <li>Vulnerabilities in dependencies we don't control</li>
        <li>Missing security headers without demonstrated exploitability</li>
        <li>Rate limiting issues without a viable attack scenario</li>
        <li>Reports generated by automated scanners without manual verification</li>
      </ul>
    </div>

    <!-- Our commitments -->
    <div class="mb-10">
      <h2 class="text-[20px] font-semibold tracking-tight mb-4">Our commitments</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        {[
          { icon: '⏱', title: '72-hour acknowledgment', desc: 'We confirm receipt of every valid report within 72 hours.' },
          { icon: '🔒', title: '30-day fix for High+', desc: 'High and Critical vulnerabilities are fixed within 30 days of verification.' },
          { icon: '🤝', title: 'No legal action', desc: 'We will not pursue legal action against researchers who follow this policy.' },
          { icon: '📣', title: 'Credit with permission', desc: 'We\'ll credit you in our Hall of Fame if you want.' },
        ].map(c => (
          <div class="p-4 rounded-xl border" style="background: var(--color-paper-2); border-color: var(--color-line);">
            <div class="text-[20px] mb-2">{c.icon}</div>
            <div class="text-[13.5px] font-semibold mb-1" style="color: var(--color-ink);">{c.title}</div>
            <div class="text-[12.5px] leading-relaxed" style="color: var(--color-ink-3);">{c.desc}</div>
          </div>
        ))}
      </div>
    </div>

    <!-- How to report -->
    <div class="mb-12 p-6 rounded-xl border"
      style="background: var(--color-amber-bg); border-color: oklch(0.86 0.07 90);">
      <h2 class="text-[18px] font-semibold tracking-tight mb-3">How to report</h2>
      <p class="text-[13.5px] leading-relaxed mb-4" style="color: var(--color-ink-2);">
        Send your report to
        <a href="mailto:security@beebeeb.io" class="font-semibold"
          style="color: var(--color-amber-deep);">security@beebeeb.io</a>.
        A PGP key is available on request for sensitive disclosures.
      </p>
      <p class="text-[13px] leading-relaxed mb-3" style="color: var(--color-ink-2);">
        A good report includes:
      </p>
      <ul class="report-checklist">
        <li>A clear description of the vulnerability and its impact</li>
        <li>Step-by-step reproduction instructions</li>
        <li>Any proof-of-concept code, screenshots, or HTTP traces</li>
        <li>Your suggested severity level and reasoning</li>
      </ul>
    </div>

    <!-- Hall of Fame -->
    <div class="mb-10">
      <h2 class="text-[20px] font-semibold tracking-tight mb-2">Hall of Fame</h2>
      <p class="text-[13.5px] mb-6" style="color: var(--color-ink-3);">
        Security researchers who have responsibly disclosed vulnerabilities.
      </p>
      <div class="p-8 rounded-xl border text-center"
        style="background: var(--color-paper-2); border-color: var(--color-line); border-style: dashed;">
        <div class="text-[28px] mb-2">🏆</div>
        <div class="text-[14px] font-medium mb-1" style="color: var(--color-ink);">Be the first!</div>
        <div class="text-[12.5px]" style="color: var(--color-ink-4);">
          No vulnerabilities have been responsibly disclosed yet.
        </div>
      </div>
    </div>

  </div>
</Base>

<style>
  .scope-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding-left: 0;
    list-style: none;
  }
  .scope-list li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 14px;
    line-height: 1.5;
    color: var(--color-ink-2);
  }
  .scope-list li::before {
    content: '✓';
    font-size: 11px;
    font-weight: 700;
    color: oklch(0.55 0.15 155);
    background: oklch(0.93 0.05 155);
    border-radius: 50%;
    width: 18px;
    height: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 1px;
  }
  .scope-list.oos li::before {
    content: '✕';
    color: oklch(0.5 0.18 25);
    background: oklch(0.95 0.04 25);
  }
  .scope-list code {
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 12px;
    background: var(--color-paper-2);
    border: 1px solid var(--color-line);
    padding: 1px 5px;
    border-radius: 4px;
  }
  .scope-list a {
    color: var(--color-amber-deep);
    text-decoration: none;
  }
  .scope-list a:hover {
    text-decoration: underline;
  }
  .report-checklist {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding-left: 0;
    list-style: none;
  }
  .report-checklist li {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    font-size: 13px;
    line-height: 1.5;
    color: var(--color-ink-2);
  }
  .report-checklist li::before {
    content: '→';
    color: var(--color-amber-deep);
    font-weight: 600;
    flex-shrink: 0;
  }
</style>
