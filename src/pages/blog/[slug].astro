---
import Base from '../../layouts/base.astro'
import { fetchBlogPostBySlug, fetchBlogPosts } from '../../lib/strapi'
import { articleSchema } from '../../lib/schemas'

const { slug } = Astro.params
if (!slug) {
  Astro.response.status = 404
  return Astro.rewrite('/404')
}

const post = await fetchBlogPostBySlug(slug)
if (!post) {
  Astro.response.status = 404
  return Astro.rewrite('/404')
}

// Fetch all posts for prev/next navigation
const allPosts = await fetchBlogPosts()
const idx = allPosts.findIndex((p) => p.slug === post.slug)
const prevPost = idx < allPosts.length - 1 ? allPosts[idx + 1] : null
const nextPost = idx > 0 ? allPosts[idx - 1] : null

function formatDate(iso: string): string {
  return new Date(iso).toLocaleDateString('en-GB', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  })
}

const canonicalUrl = `https://beebeeb.io/blog/${post.slug}`
const shareText = encodeURIComponent(post.title + ' — ' + post.excerpt)
const twitterUrl = `https://x.com/intent/post?text=${shareText}&url=${encodeURIComponent(canonicalUrl)}`
const mastodonUrl = `https://mastodon.social/share?text=${shareText}+${encodeURIComponent(canonicalUrl)}`

const jsonLd = articleSchema({
  headline: post.title,
  description: post.seoDescription || post.excerpt,
  datePublished: post.publishedAt,
  authorName: post.author?.name,
  image: post.coverImage,
  url: canonicalUrl,
})
---

<Base
  title={`${post.seoTitle || post.title} — Beebeeb Blog`}
  description={post.seoDescription || post.excerpt}
  path={`/blog/${post.slug}`}
  jsonLd={jsonLd}
>
  <!-- Hero / header -->
  <section class="post-header" style="background: linear-gradient(180deg, var(--paper-2) 0%, var(--paper) 100%);">
    <div class="post-header-inner">
      <a href="/blog" class="post-back-link">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="post-back-icon">
          <path d="M19 12H5M12 5l-7 7 7 7"/>
        </svg>
        All posts
      </a>

      <div class="post-meta">
        <span class="post-meta-date">{formatDate(post.publishedAt)}</span>
        <span class="post-meta-sep">&middot;</span>
        <span class="post-meta-date">{post.readingTime} min read</span>
      </div>

      <h1 class="post-title">
        {post.title}
      </h1>

      <p class="post-excerpt">
        {post.excerpt}
      </p>

      <div class="post-author">
        <div class="post-author-avatar">
          {(post.author?.name || 'B').charAt(0)}
        </div>
        <div>
          <div class="post-author-name">{post.author?.name || 'Beebeeb Team'}</div>
          <div class="post-author-org">Initlabs B.V. &middot; Wijchen, Netherlands</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Post body -->
  <article class="post-body-section">
    <div class="post-body prose-blog" set:html={post.content} />
  </article>

  <!-- Share + prev/next -->
  <section class="post-footer">
    <div class="post-footer-inner">
      <!-- Share row -->
      <div class="post-share-row">
        <span class="post-share-label">Share this post</span>
        <div class="post-share-buttons">
          <button
            id="copyLinkBtn"
            data-url={canonicalUrl}
            class="post-share-btn"
          >
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
            <span id="copyLinkLabel">Copy link</span>
          </button>
          <a
            href={twitterUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="post-share-btn"
          >
            <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.737-8.835L1.254 2.25H8.08l4.261 5.635 5.902-5.635zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            Post on X
          </a>
          <a
            href={mastodonUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="post-share-btn"
          >
            <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M21.327 8.566c0-4.339-2.843-5.61-2.843-5.61-1.433-.658-3.894-.935-6.451-.956h-.063c-2.557.021-5.016.298-6.45.956 0 0-2.843 1.272-2.843 5.61 0 .993-.019 2.181.012 3.441.103 4.243.778 8.425 4.701 9.463 1.809.479 3.362.579 4.612.510 2.268-.126 3.542-.809 3.542-.809l-.075-1.646s-1.621.511-3.441.449c-1.804-.062-3.707-.194-3.999-2.409a4.523 4.523 0 0 1-.04-.621s1.77.433 4.014.536c1.372.063 2.658-.08 3.965-.236 2.506-.299 4.688-1.843 4.962-3.254.434-2.223.398-5.424.398-5.424zm-3.353 5.59h-2.081V9.057c0-1.075-.452-1.62-1.357-1.62-1.001 0-1.502.647-1.502 1.927v2.791h-2.069V9.364c0-1.28-.501-1.927-1.502-1.927-.905 0-1.357.545-1.357 1.62v5.099H6.026V8.903c0-1.074.273-1.927.823-2.558.568-.631 1.313-.955 2.236-.955 1.089 0 1.902.418 2.405 1.256l.519.87.519-.87c.503-.838 1.316-1.256 2.405-1.256.923 0 1.668.324 2.236.955.55.631.823 1.484.823 2.558v5.253z"/></svg>
            Mastodon
          </a>
        </div>
      </div>

      <!-- Prev / Next -->
      <div class="post-nav-grid">
        {prevPost && (
          <a href={`/blog/${prevPost.slug}`} class="post-nav-card">
            <div class="post-nav-label post-nav-label--prev">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
              Previous
            </div>
            <div class="post-nav-title">
              {prevPost.title}
            </div>
          </a>
        )}
        {nextPost && (
          <a href={`/blog/${nextPost.slug}`} class:list={['post-nav-card post-nav-card--next', !prevPost && 'post-nav-card--offset']}>
            <div class="post-nav-label post-nav-label--next">
              Next
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </div>
            <div class="post-nav-title post-nav-title--right">
              {nextPost.title}
            </div>
          </a>
        )}
      </div>
    </div>
  </section>
</Base>

<!-- Copy link script -->
<script>
  const btn = document.getElementById('copyLinkBtn')
  const label = document.getElementById('copyLinkLabel')
  if (btn && label) {
    btn.addEventListener('click', async () => {
      const url = btn.getAttribute('data-url') ?? window.location.href
      try {
        await navigator.clipboard.writeText(url)
        label.textContent = 'Copied!'
        setTimeout(() => { label.textContent = 'Copy link' }, 2000)
      } catch {
        // clipboard unavailable
      }
    })
  }
</script>

<style>
  /* ── Post header ────────────────────────────────────────── */
  .post-header {
    padding: 72px 32px 48px;
    border-bottom: 1px solid var(--line);
  }

  .post-header-inner {
    max-width: 720px;
    margin: 0 auto;
  }

  .post-back-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    color: var(--ink-3);
    text-decoration: none;
    margin-bottom: 24px;
    transition: color 150ms var(--ease);
  }

  .post-back-link:hover {
    color: var(--ink-2);
  }

  .post-back-icon {
    transition: transform 150ms var(--ease);
  }

  .post-back-link:hover .post-back-icon {
    transform: translateX(-2px);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 20px;
  }

  .post-meta-date {
    font-size: 11px;
    font-family: var(--font-mono);
    color: var(--ink-4);
  }

  .post-meta-sep {
    color: var(--ink-4);
  }

  .post-title {
    font-size: 48px;
    line-height: 1.06;
    font-weight: 700;
    letter-spacing: -0.025em;
    color: var(--ink);
    margin-bottom: 20px;
  }

  .post-excerpt {
    font-size: 16px;
    color: var(--ink-2);
    line-height: 1.65;
    margin-bottom: 24px;
  }

  .post-author {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .post-author-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--amber-soft);
    color: var(--amber-deep);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 700;
    flex-shrink: 0;
  }

  .post-author-name {
    font-size: 13px;
    font-weight: 500;
    color: var(--ink);
  }

  .post-author-org {
    font-size: 11px;
    color: var(--ink-4);
  }

  /* ── Post body ──────────────────────────────────────────── */
  .post-body-section {
    padding: 48px 32px;
  }

  .post-body {
    max-width: 720px;
    margin: 0 auto;
  }

  /* ── Post footer ────────────────────────────────────────── */
  .post-footer {
    padding: 40px 32px;
    border-top: 1px solid var(--line);
    background: var(--paper-2);
  }

  .post-footer-inner {
    max-width: 720px;
    margin: 0 auto;
  }

  .post-share-row {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 40px;
    padding-bottom: 40px;
    border-bottom: 1px solid var(--line);
    flex-wrap: wrap;
  }

  .post-share-label {
    font-size: 13px;
    font-weight: 500;
    color: var(--ink-2);
    flex-shrink: 0;
  }

  .post-share-buttons {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  .post-share-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    border: 1px solid var(--line);
    border-radius: 6px;
    font-size: 12px;
    color: var(--ink-2);
    background: var(--paper);
    text-decoration: none;
    cursor: pointer;
    font-family: var(--font-sans);
    transition: border-color 150ms var(--ease), color 150ms var(--ease);
  }

  .post-share-btn:hover {
    border-color: oklch(0.58 0.16 60 / 0.4);
    color: var(--ink);
  }

  /* ── Prev / Next navigation ─────────────────────────────── */
  .post-nav-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  .post-nav-card {
    display: block;
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 20px;
    text-decoration: none;
    background: var(--paper);
    transition: all 150ms var(--ease);
  }

  .post-nav-card:hover {
    border-color: oklch(0.58 0.16 60 / 0.4);
    box-shadow: var(--shadow-1);
  }

  .post-nav-card--next {
    text-align: right;
  }

  .post-nav-card--offset {
    grid-column-start: 2;
  }

  .post-nav-label {
    font-size: 10px;
    font-family: var(--font-mono);
    color: var(--ink-4);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 8px;
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .post-nav-label--next {
    justify-content: flex-end;
  }

  .post-nav-title {
    font-size: 14px;
    font-weight: 600;
    color: var(--ink);
    line-height: 1.3;
    transition: color 150ms var(--ease);
  }

  .post-nav-card:hover .post-nav-title {
    color: var(--amber-deep);
  }

  .post-nav-title--right {
    text-align: right;
  }

  /* ── Prose typography for blog post body ─────────────────── */
  .prose-blog {
    color: var(--ink-2);
    font-size: 16px;
    line-height: 1.75;
  }

  .prose-blog :global(h2) {
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    line-height: 1.25;
  }

  .prose-blog :global(h3) {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--ink);
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }

  .prose-blog :global(p) {
    margin-bottom: 1.25rem;
  }

  .prose-blog :global(strong) {
    color: var(--ink);
    font-weight: 600;
  }

  .prose-blog :global(em) {
    color: var(--ink);
    font-style: italic;
  }

  .prose-blog :global(code) {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: var(--paper-2);
    border: 1px solid var(--line);
    border-radius: 4px;
    padding: 0.1em 0.4em;
    color: var(--ink);
  }

  .prose-blog :global(ul) {
    list-style: none;
    padding-left: 0;
    margin-bottom: 1.25rem;
  }

  .prose-blog :global(ul li) {
    padding-left: 1.25rem;
    position: relative;
    margin-bottom: 0.4rem;
  }

  .prose-blog :global(ul li::before) {
    content: '\2014';
    position: absolute;
    left: 0;
    color: var(--amber-deep);
    font-weight: 600;
  }

  .prose-blog :global(ol) {
    list-style: decimal;
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }

  .prose-blog :global(ol li) {
    margin-bottom: 0.4rem;
  }

  .prose-blog :global(blockquote) {
    border-left: 3px solid var(--amber-deep);
    margin-left: 0;
    padding-left: 1.25rem;
    color: var(--ink-2);
    font-style: italic;
  }

  .prose-blog :global(a) {
    color: var(--amber-deep);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .prose-blog :global(a:hover) {
    color: var(--ink);
  }

  .prose-blog :global(hr) {
    border: none;
    border-top: 1px solid var(--line);
    margin: 2.5rem 0;
  }

  /* ── Responsive ─────────────────────────────────────────── */
  @media (max-width: 760px) {
    .post-title {
      font-size: 40px;
    }

    .post-share-row {
      flex-direction: column;
      align-items: flex-start;
    }

    .post-nav-grid {
      grid-template-columns: 1fr;
    }

    .post-nav-card--next {
      text-align: left;
    }

    .post-nav-label--next {
      justify-content: flex-start;
    }

    .post-nav-title--right {
      text-align: left;
    }

    .post-nav-card--offset {
      grid-column-start: auto;
    }
  }

  @media (max-width: 560px) {
    .post-header {
      padding: 48px 20px 36px;
    }

    .post-body-section {
      padding: 36px 20px;
    }

    .post-footer {
      padding: 32px 20px;
    }

    .post-title {
      font-size: 32px;
    }
  }
</style>
