---
import Base from '../layouts/base.astro';

// Canary dates — updated every Monday at 09:00 CET.
// To update: change lastUpdated to today's date and nextDue to next Monday.
const lastUpdated  = '2026-05-04';
const nextDue      = '2026-05-11';
---

<Base
  title="Warrant Canary — Beebeeb"
  description="Beebeeb warrant canary. Updated every Monday. If this page is not updated by the stated date, users should assume the canary is no longer valid."
  path="/warrant-canary"
  noindex={true}
>
  <div class="canary-page">

    <div class="canary-header">
      <div class="section-label canary-label">Legal &amp; trust</div>
      <h1 class="canary-title">
        Warrant Canary
      </h1>
      <div class="canary-dates">
        <span>
          Last updated:
          <span class="canary-date-value">{lastUpdated}</span>
        </span>
        <span>
          Next update due:
          <span class="canary-date-value">{nextDue}</span>
        </span>
      </div>
    </div>

    <div class="prose-bb">
      <p>
        As of the date above, Initlabs B.V. (operator of Beebeeb):
      </p>

      <ol>
        <li>Has not received any National Security Letters or FISA orders.</li>
        <li>Has not received any gag orders or secret court orders.</li>
        <li>Has not been required to modify our systems to allow access or monitoring.</li>
        <li>Has not placed any backdoors in our software or handed over encryption keys.</li>
      </ol>

      <p>
        This canary is updated every Monday at 09:00 CET. If this page is not updated
        by the stated date, users should assume the canary is no longer valid.
      </p>

      <p class="signature">
        Signed: Guus Langelaar, Director, Initlabs B.V.
      </p>
    </div>

  </div>
</Base>

<style>
  .canary-page {
    padding: 80px 32px;
    max-width: 680px;
    margin: 0 auto;
  }

  .canary-header {
    margin-bottom: 40px;
  }

  .canary-label {
    margin-bottom: 16px;
  }

  .canary-title {
    font-size: 40px;
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.1;
    margin-bottom: 16px;
  }

  .canary-dates {
    display: flex;
    flex-wrap: wrap;
    gap: 24px;
    font-size: 13px;
    color: var(--ink-3);
  }

  .canary-date-value {
    font-weight: 600;
    color: var(--ink);
  }

  .prose-bb {
    font-size: 15px;
    line-height: 1.7;
    color: var(--ink-2);
  }
  .prose-bb p {
    margin-bottom: 1.25rem;
  }
  .prose-bb ol {
    list-style: decimal;
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .prose-bb li {
    color: var(--ink-2);
  }
  .prose-bb .signature {
    margin-top: 2rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--line);
    font-size: 13px;
    color: var(--ink-3);
    font-style: italic;
  }

  @media (max-width: 560px) {
    .canary-page {
      padding: 48px 20px;
    }

    .canary-title {
      font-size: 32px;
    }
  }
</style>
