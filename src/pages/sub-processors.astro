---
import Base from '../layouts/base.astro';
import LegalText from '../components/blocks/LegalText.astro';

const body = `
<p class="text-[13px] text-ink-3">Last updated: 4 May 2026</p>

<p>
  Initlabs B.V. uses the following sub-processors in the delivery of Beebeeb.
  Each sub-processor is bound by a data processing agreement with equivalent
  obligations to those in our <a href="/dpa">DPA</a>.
</p>
<p>
  We notify customers of any new sub-processors via the
  <a href="/changelog">changelog</a> with at least 14 days' notice before they
  are engaged. Customers who object may terminate their subscription and receive
  a pro-rated refund.
</p>

<h2>Infrastructure &amp; storage</h2>
<table style="width:100%;border-collapse:collapse;font-size:14px;margin-bottom:1.5rem;">
  <thead>
    <tr style="border-bottom:1px solid var(--color-line);">
      <th style="text-align:left;padding:8px 12px 8px 0;font-weight:600;color:var(--color-ink);">Provider</th>
      <th style="text-align:left;padding:8px 12px;font-weight:600;color:var(--color-ink);">Purpose</th>
      <th style="text-align:left;padding:8px 12px;font-weight:600;color:var(--color-ink);">Location</th>
      <th style="text-align:left;padding:8px 0 8px 12px;font-weight:600;color:var(--color-ink);">Certifications</th>
    </tr>
  </thead>
  <tbody>
    <tr style="border-bottom:1px solid var(--color-line-2);">
      <td style="padding:10px 12px 10px 0;vertical-align:top;">
        <strong>Hetzner Online GmbH</strong><br />
        <span style="font-size:12px;color:var(--color-ink-3);">hetzner.com</span>
      </td>
      <td style="padding:10px 12px;vertical-align:top;color:var(--color-ink-2);">Server infrastructure, object storage (encrypted file blobs)</td>
      <td style="padding:10px 12px;vertical-align:top;color:var(--color-ink-2);">Falkenstein, Germany &middot; Helsinki, Finland (EEA)</td>
      <td style="padding:10px 0 10px 12px;vertical-align:top;color:var(--color-ink-2);">ISO 27001</td>
    </tr>
  </tbody>
</table>

<h2>Payments</h2>
<table style="width:100%;border-collapse:collapse;font-size:14px;margin-bottom:1.5rem;">
  <thead>
    <tr style="border-bottom:1px solid var(--color-line);">
      <th style="text-align:left;padding:8px 12px 8px 0;font-weight:600;color:var(--color-ink);">Provider</th>
      <th style="text-align:left;padding:8px 12px;font-weight:600;color:var(--color-ink);">Purpose</th>
      <th style="text-align:left;padding:8px 12px;font-weight:600;color:var(--color-ink);">Location</th>
      <th style="text-align:left;padding:8px 0 8px 12px;font-weight:600;color:var(--color-ink);">Certifications</th>
    </tr>
  </thead>
  <tbody>
    <tr style="border-bottom:1px solid var(--color-line-2);">
      <td style="padding:10px 12px 10px 0;vertical-align:top;">
        <strong>Stripe Inc</strong><br />
        <span style="font-size:12px;color:var(--color-ink-3);">stripe.com</span>
      </td>
      <td style="padding:10px 12px;vertical-align:top;color:var(--color-ink-2);">Payment processing, subscription management, invoicing</td>
      <td style="padding:10px 12px;vertical-align:top;color:var(--color-ink-2);">EU region (Ireland)</td>
      <td style="padding:10px 0 10px 12px;vertical-align:top;color:var(--color-ink-2);">PCI DSS Level 1, ISO 27001</td>
    </tr>
  </tbody>
</table>

<h2>What we don't use</h2>
<p>
  We do not use third-party analytics (no Google Analytics, Mixpanel, or similar).
  We do not use advertising networks. We do not use AI training services that would
  process your data. Site analytics, if any, use privacy-preserving methods with
  no personal data leaving our infrastructure.
</p>
`;
---

<Base
  title="Sub-processors — Beebeeb"
  description="Complete list of Beebeeb sub-processors: Hetzner (infrastructure) and Stripe (payments). Updated May 2026."
  path="/sub-processors"
>
  <LegalText title="Sub-processor List" body={body} />
</Base>
