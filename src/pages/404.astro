---
import Base from '../layouts/base.astro';
---

<Base title="Page not found — Beebeeb" noindex={true} path="/404">
  <section class="px-8 py-32 text-center">
    <div class="max-w-[500px] mx-auto">
      <div class="font-mono text-[72px] font-bold text-amber leading-none mb-4">404</div>
      <h1 class="text-[28px] font-bold tracking-[-0.02em] mb-3">This page doesn't exist.</h1>
      <p class="text-[15px] text-ink-2 leading-relaxed mb-8">
        You might have followed a broken link, or this page has moved. Either way, there's nothing here.
      </p>
      <a href="/" class="btn btn-amber btn-md no-underline">
        Back to home
        <svg class="w-[13px] h-[13px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
      </a>
    </div>
  </section>
</Base>
