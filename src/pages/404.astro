---
import Base from '../layouts/base.astro';
---

<Base title="Page not found — Beebeeb" noindex={true} path="/404">
  <section class="not-found">
    <div class="not-found__shell">
      <div class="not-found__code t-mono" aria-hidden="true">404</div>

      <div class="not-found__content">
        <p class="not-found__label t-label">Page not found</p>
        <h1>This page doesn't exist.</h1>
        <p class="not-found__body">
          The link may be outdated, or the page may have moved. Start again from the
          homepage or jump to a current Beebeeb section.
        </p>

        <div class="not-found__actions" aria-label="Page recovery links">
          <a href="/" class="not-found__primary">
            Back to home
            <svg aria-hidden="true" viewBox="0 0 24 24" fill="none">
              <path d="m9 18 6-6-6-6" />
            </svg>
          </a>
          <a href="/security" class="not-found__link">Security</a>
          <a href="/pricing" class="not-found__link">Pricing</a>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .not-found {
    display: grid;
    min-height: min(760px, calc(100vh - 76px));
    padding: 88px 32px 104px;
    place-items: center;
    background:
      radial-gradient(circle at 18% 22%, oklch(0.92 0.06 88 / 0.5), transparent 28%),
      radial-gradient(circle at 82% 76%, oklch(0.90 0.03 120 / 0.35), transparent 30%),
      var(--paper);
  }

  .not-found__shell {
    position: relative;
    display: grid;
    width: min(100%, 920px);
    min-height: 420px;
    align-items: center;
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: 8px;
    background:
      linear-gradient(135deg, oklch(0.985 0.004 85 / 0.94), oklch(0.965 0.008 85 / 0.9)),
      var(--paper);
    box-shadow: var(--shadow-2);
  }

  .not-found__shell::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, oklch(0.18 0.01 70 / 0.05) 0.8px, transparent 1.2px);
    background-size: 22px 22px;
    pointer-events: none;
  }

  .not-found__code {
    position: absolute;
    right: clamp(-18px, -2vw, 8px);
    bottom: clamp(-26px, -3vw, 2px);
    color: oklch(0.20 0.015 70 / 0.06);
    font-size: clamp(148px, 24vw, 280px);
    font-weight: 700;
    letter-spacing: -0.08em;
    line-height: 0.75;
    user-select: none;
  }

  .not-found__content {
    position: relative;
    z-index: 1;
    max-width: 540px;
    padding: clamp(36px, 7vw, 72px);
  }

  .not-found__label {
    margin: 0 0 14px;
  }

  .not-found h1 {
    max-width: 480px;
    margin: 0;
    font-size: clamp(36px, 5vw, 58px);
    font-weight: 600;
    letter-spacing: -0.038em;
    line-height: 1.02;
  }

  .not-found__body {
    max-width: 480px;
    margin: 18px 0 0;
    color: var(--ink-2);
    font-size: 15.5px;
    line-height: 1.7;
  }

  .not-found__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px 16px;
    margin-top: 30px;
  }

  .not-found__primary,
  .not-found__link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 42px;
    border-radius: 6px;
    font-size: 13.5px;
    font-weight: 600;
    text-decoration: none;
    transition:
      background 150ms var(--ease),
      border-color 150ms var(--ease),
      color 150ms var(--ease),
      box-shadow 150ms var(--ease),
      transform 150ms var(--ease);
  }

  .not-found__primary {
    gap: 9px;
    padding: 0 16px;
    border: 1px solid var(--ink);
    background: var(--ink);
    color: var(--paper);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.06) inset,
      0 4px 12px -4px rgba(24, 20, 10, 0.3);
  }

  .not-found__primary:hover {
    background: oklch(0.24 0.012 70);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.08) inset,
      0 8px 20px -6px rgba(24, 20, 10, 0.35);
    transform: translateY(-1px);
  }

  .not-found__primary svg {
    width: 14px;
    height: 14px;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2;
  }

  .not-found__link {
    padding: 0 14px;
    border: 1px solid var(--line-2);
    background: oklch(0.985 0.004 85 / 0.5);
    color: var(--ink-2);
  }

  .not-found__link:hover {
    border-color: var(--ink-3);
    background: var(--paper);
    color: var(--ink);
  }

  @media (max-width: 640px) {
    .not-found {
      min-height: calc(100vh - 64px);
      padding: 48px 20px 72px;
    }

    .not-found__shell {
      min-height: 460px;
    }

    .not-found__content {
      padding: 32px 26px;
    }

    .not-found__code {
      right: -14px;
      bottom: -14px;
      font-size: 136px;
    }

    .not-found__actions {
      align-items: stretch;
      flex-direction: column;
    }
  }
</style>
