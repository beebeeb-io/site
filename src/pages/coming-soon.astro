       ================================================================ -->
  <script is:inline define:vars={{ launchDate }}>
    // === Countdown timer ===
    function updateCountdown() {
      var target = new Date(launchDate).getTime();
      var now = Date.now();
      var diff = Math.max(0, target - now);

      var days = Math.floor(diff / (1000 * 60 * 60 * 24));
      var hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
      var mins = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
      var secs = Math.floor((diff % (1000 * 60)) / 1000);

      var cdDays = document.getElementById('cd-days');
      var cdHours = document.getElementById('cd-hours');
      var cdMins = document.getElementById('cd-mins');
      var cdSecs = document.getElementById('cd-secs');
      var cdStrip = document.getElementById('countdownDays');

      if (cdDays) cdDays.textContent = String(days).padStart(2, '0');
      if (cdHours) cdHours.textContent = String(hours).padStart(2, '0');
      if (cdMins) cdMins.textContent = String(mins).padStart(2, '0');
      if (cdSecs) cdSecs.textContent = String(secs).padStart(2, '0');
      if (cdStrip) cdStrip.textContent = String(days);
    }

    updateCountdown();
    setInterval(updateCountdown, 1000);

    // === Ticking counters ===
    function animateCounters() {
      var counters = document.querySelectorAll('[data-counter]');
      counters.forEach(function(el) {
        var target = parseInt(el.getAttribute('data-counter'), 10);
        var suffix = el.getAttribute('data-suffix') || '';
        var duration = 2000;
        var start = null;

        function step(timestamp) {
          if (!start) start = timestamp;
          var progress = Math.min((timestamp - start) / duration, 1);
          var eased = 1 - Math.pow(1 - progress, 3);
          var current = Math.floor(target * eased);
          el.textContent = current.toLocaleString('nl-NL') + suffix;
          if (progress < 1) requestAnimationFrame(step);
        }

        requestAnimationFrame(step);
      });
    }

    // Trigger counters when they scroll into view
    var counterObserver = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          animateCounters();
          counterObserver.disconnect();
        }
      });
    }, { threshold: 0.3 });

    var statsGrid = document.querySelector('.stats-grid');
    if (statsGrid) counterObserver.observe(statsGrid);

    // === Email capture ===
    var submitBtn = document.getElementById('submitBtn');
    var emailInput = document.getElementById('emailInput');
    var feedback = document.getElementById('submitFeedback');

    if (submitBtn && emailInput) {
      submitBtn.addEventListener('click', function() {
        var email = emailInput.value.trim();
        if (!email || !email.includes('@') || !email.includes('.')) {
          feedback.textContent = 'Please enter a valid email address.';
          feedback.style.display = 'block';
          feedback.style.color = 'oklch(0.62 0.21 25)';
          return;
        }

        // Store in localStorage as a simple waitlist mechanism
        var waitlist = [];
        try {
          waitlist = JSON.parse(localStorage.getItem('bb-waitlist') || '[]');
        } catch (e) { /* ignore */ }

        if (waitlist.indexOf(email) === -1) {
          waitlist.push(email);
          localStorage.setItem('bb-waitlist', JSON.stringify(waitlist));
        }

        // POST to placeholder endpoint (will 404 for now, that's fine)
        try {
          fetch('/api/waitlist', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email: email, ts: new Date().toISOString() }),
          }).catch(function() { /* endpoint doesn't exist yet */ });
        } catch (e) { /* ignore */ }

        feedback.textContent = 'You are on the list. One email when we launch.';
        feedback.style.display = 'block';
        feedback.style.color = 'var(--amber)';
        emailInput.value = '';
        submitBtn.textContent = 'Reserved';
        submitBtn.disabled = true;
        submitBtn.style.opacity = '0.7';
      });

      // Submit on Enter key
      emailInput.addEventListener('keydown', function(e) {
        if (e.key === 'Enter') {
          e.preventDefault();
          submitBtn.click();
        }
      });
    }

    // === Hover effects for submit button ===
    if (submitBtn) {
      submitBtn.addEventListener('mouseenter', function() {
        if (!submitBtn.disabled) {
          submitBtn.style.background = 'oklch(0.66 0.15 72)';
          submitBtn.style.transform = 'translateY(-1px)';
        }
      });
      submitBtn.addEventListener('mouseleave', function() {
        if (!submitBtn.disabled) {
          submitBtn.style.background = 'var(--amber)';
          submitBtn.style.transform = 'translateY(0)';
        }
      });
    }

    // === Nav link hover ===
    document.querySelectorAll('.nav-links a').forEach(function(link) {
      link.addEventListener('mouseenter', function() { link.style.color = 'var(--text-primary)'; });
      link.addEventListener('mouseleave', function() { link.style.color = ''; });
    });
  </script>
</body>
</html>
