---
import Base from '../layouts/base.astro';
import { getLaunchPhase } from '../lib/strapi';
import { phaseConfig } from '../lib/phase';

const phase = await getLaunchPhase();
const cfg = phaseConfig(phase);

interface RoadmapItem {
  name: string;
  description: string;
  phase: 1 | 2 | 3 | 4;
}

const phases = [
  {
    number: 1 as const,
    title: 'Foundation',
    subtitle: 'Marketing site, waitlist, infrastructure',
    items: [
      { name: 'Marketing website', description: 'Product pages, pricing, security docs, blog', phase: 1 as const },
      { name: 'Waitlist signup', description: 'Email collection with plan preference', phase: 1 as const },
      { name: 'Encryption core', description: 'AES-256-GCM, Argon2id, X25519 key exchange', phase: 1 as const },
      { name: 'API server', description: 'Rust + Axum backend with zero-knowledge storage', phase: 1 as const },
      { name: 'EU infrastructure', description: 'Dedicated servers in Falkenstein', phase: 1 as const },
    ],
  },
  {
    number: 2 as const,
    title: 'Launch',
    subtitle: 'Web app, CLI, and first paying customers',
    items: [
      { name: 'Web application', description: 'Upload, download, preview, organize — all encrypted in-browser via WASM', phase: 2 as const },
      { name: 'CLI tool (bb)', description: 'Upload, download, sync from the terminal. Homebrew + direct download.', phase: 2 as const },
      { name: 'Free + Basic + Pro plans', description: 'Stripe billing, storage upgrades, annual discounts', phase: 2 as const },
      { name: 'Encrypted file sharing', description: 'Share files and folders with end-to-end encryption intact', phase: 2 as const },
      { name: 'Photo backup', description: 'Automatic encrypted backup with thumbnail preview', phase: 2 as const },
      { name: 'File versioning', description: '90-day version history on paid plans', phase: 2 as const },
      { name: 'Data export', description: 'Download everything as an encrypted archive', phase: 2 as const },
      { name: 'Warrant canary', description: 'Public transparency report and canary statement', phase: 2 as const },
    ],
  },
  {
    number: 3 as const,
    title: 'All platforms',
    subtitle: 'Native apps for every device',
    items: [
      { name: 'iOS app', description: 'iOS app (React Native) with photo backup, Face ID, share extension', phase: 3 as const },
      { name: 'Android app', description: 'Android app (React Native) with photo backup and share intent', phase: 3 as const },
      { name: 'macOS desktop sync', description: 'Background sync daemon with Finder integration', phase: 3 as const },
      { name: 'Windows desktop sync', description: 'Background sync with Explorer integration', phase: 3 as const },
      { name: 'Linux desktop sync', description: 'Background sync daemon, .deb and AppImage', phase: 3 as const },
    ],
  },
  {
    number: 4 as const,
    title: 'Teams & business',
    subtitle: 'Shared workspaces, admin tools, compliance',
    items: [
      { name: 'Business plan', description: 'Per-seat pricing with dedicated support and SLA', phase: 4 as const },
      { name: 'Team vaults', description: 'Shared encrypted workspaces with per-user key wrapping', phase: 4 as const },
      { name: 'SSO (SAML/OIDC)', description: 'Enterprise single sign-on integration', phase: 4 as const },
      { name: 'Admin console', description: 'User management, storage allocation, audit log', phase: 4 as const },
      { name: 'Client portals', description: 'Encrypted file exchange with external parties', phase: 4 as const },
      { name: 'Data residency controls', description: 'Choose storage region per vault (DE, NL, FR)', phase: 4 as const },
      { name: 'Third-party security audit', description: 'Independent audit of encryption implementation', phase: 4 as const },
    ],
  },
];

function phaseStatus(itemPhase: number, currentPhase: number): 'done' | 'active' | 'upcoming' {
  if (itemPhase < currentPhase) return 'done';
  if (itemPhase === currentPhase) return 'active';
  return 'upcoming';
}

function statusLabel(status: 'done' | 'active' | 'upcoming'): string {
  if (status === 'done') return 'Completed';
  if (status === 'active') return 'Live now';
  return 'Planned';
}
---

<Base
  title="Roadmap — Beebeeb"
  description="What we've shipped, what's live, and what's coming next. Beebeeb product roadmap with honest timelines."
  path="/roadmap"
>
  <section class="roadmap-hero">
    <div class="roadmap-container">
      <div class="bb-eyebrow" style="justify-content: center; display: inline-flex;">Product roadmap</div>
      <h1 class="roadmap-title">What we've built.<br />What's next.</h1>
      <p class="roadmap-subtitle">
        We ship in phases. Each phase is fully usable on its own.
        No half-finished features, no "coming soon" that never arrives.
      </p>
      <div class="roadmap-current">
        Currently in <strong>Phase {phase}</strong> — {phases[phase - 1]?.title}
      </div>
    </div>
  </section>

  <section class="roadmap-timeline">
    <div class="roadmap-container">
      {phases.map((p) => {
        const status = phaseStatus(p.number, phase);
        return (
          <div class:list={['roadmap-phase', `phase-${status}`]}>
            <div class="phase-header">
              <div class="phase-number-wrap">
                <span class="phase-number">{p.number}</span>
                <span class:list={['phase-badge', status]}>{statusLabel(status)}</span>
              </div>
              <h2 class="phase-title">{p.title}</h2>
              <p class="phase-subtitle">{p.subtitle}</p>
            </div>

            <div class="phase-items">
              {p.items.map((item) => (
                <div class:list={['roadmap-item', `item-${status}`]}>
                  <div class="item-dot-wrap">
                    <span class:list={['item-dot', status]} />
                  </div>
                  <div class="item-content">
                    <div class="item-name">{item.name}</div>
                    <div class="item-desc">{item.description}</div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        );
      })}
    </div>
  </section>

  <section class="roadmap-note">
    <div class="roadmap-container">
      <div class="note-card">
        <div class="note-icon">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
        </div>
        <div>
          <div class="note-title">This roadmap is honest.</div>
          <p class="note-body">
            Items marked "Planned" are committed to but not yet scheduled.
            We don't announce dates we can't keep. When something ships,
            it shows up here as "Live now" — not before.
          </p>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .roadmap-hero {
    padding: 72px 32px 48px;
    text-align: center;
    background: linear-gradient(180deg, var(--amber-soft) 0%, var(--paper) 85%);
    border-bottom: 1px solid var(--line);
  }

  .roadmap-container {
    max-width: 760px;
    margin: 0 auto;
  }

  .roadmap-title {
    font-size: clamp(32px, 5vw, 48px);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.08;
    margin: 14px 0 0;
  }

  .roadmap-subtitle {
    font-size: 16px;
    color: var(--ink-2);
    line-height: 1.6;
    margin: 18px auto 0;
    max-width: 520px;
  }

  .roadmap-current {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 24px;
    padding: 8px 16px;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: var(--paper);
    font-size: 13px;
    color: var(--ink-2);
    font-family: var(--font-mono);
  }

  .roadmap-current strong {
    color: var(--ink);
    font-weight: 700;
  }

  .roadmap-timeline {
    padding: 64px 32px;
    background: var(--paper);
  }

  .roadmap-phase {
    position: relative;
    padding-bottom: 48px;
  }

  .roadmap-phase:last-child {
    padding-bottom: 0;
  }

  .roadmap-phase::before {
    content: '';
    position: absolute;
    left: 15px;
    top: 40px;
    bottom: 0;
    width: 1px;
    background: var(--line);
  }

  .roadmap-phase:last-child::before {
    display: none;
  }

  .phase-header {
    margin-bottom: 20px;
  }

  .phase-number-wrap {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 8px;
  }

  .phase-number {
    display: inline-flex;
    width: 32px;
    height: 32px;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 700;
    flex-shrink: 0;
  }

  .phase-done .phase-number {
    background: var(--ink);
    color: var(--paper);
  }

  .phase-active .phase-number {
    background: var(--amber);
    color: var(--ink);
  }

  .phase-upcoming .phase-number {
    background: var(--paper-2);
    color: var(--ink-3);
    border: 1px solid var(--line);
  }

  .phase-badge {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 3px 8px;
    border-radius: 4px;
  }

  .phase-badge.done {
    background: var(--paper-2);
    color: var(--ink-3);
  }

  .phase-badge.active {
    background: oklch(0.95 0.05 155);
    color: oklch(0.35 0.1 155);
    border: 1px solid oklch(0.85 0.08 155);
  }

  .phase-badge.upcoming {
    background: var(--amber-soft);
    color: var(--amber-deep);
    border: 1px solid oklch(0.86 0.07 90);
  }

  .phase-title {
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0 0 4px;
    padding-left: 42px;
  }

  .phase-subtitle {
    font-size: 14px;
    color: var(--ink-2);
    margin: 0;
    padding-left: 42px;
  }

  .phase-items {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding-left: 42px;
  }

  .roadmap-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 10px 14px;
    border-radius: 8px;
    transition: background 150ms ease;
  }

  .roadmap-item:hover {
    background: var(--paper-2);
  }

  .item-dot-wrap {
    padding-top: 5px;
    flex-shrink: 0;
  }

  .item-dot {
    display: block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }

  .item-dot.done {
    background: var(--ink-3);
  }

  .item-dot.active {
    background: oklch(0.55 0.12 155);
  }

  .item-dot.upcoming {
    background: var(--amber);
  }

  .item-name {
    font-size: 14px;
    font-weight: 600;
    color: var(--ink);
    line-height: 1.3;
  }

  .item-desc {
    font-size: 13px;
    color: var(--ink-3);
    line-height: 1.45;
    margin-top: 2px;
  }

  .phase-upcoming .item-name {
    color: var(--ink-2);
  }

  .phase-upcoming .item-desc {
    color: var(--ink-4);
  }

  .roadmap-note {
    padding: 0 32px 64px;
    background: var(--paper);
  }

  .note-card {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 18px 20px;
    border: 1px dashed var(--line-2);
    border-radius: 10px;
    background: var(--paper-2);
  }

  .note-icon {
    width: 32px;
    height: 32px;
    border-radius: 6px;
    background: var(--amber-soft);
    border: 1px solid oklch(0.86 0.07 90);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--amber-deep);
    flex-shrink: 0;
  }

  .note-title {
    font-size: 14px;
    font-weight: 600;
    margin-bottom: 4px;
  }

  .note-body {
    font-size: 13px;
    color: var(--ink-2);
    line-height: 1.55;
    margin: 0;
  }

  @media (max-width: 560px) {
    .roadmap-hero {
      padding: 48px 20px 32px;
    }

    .roadmap-timeline {
      padding: 40px 20px;
    }

    .phase-title,
    .phase-subtitle,
    .phase-items {
      padding-left: 42px;
    }

    .roadmap-note {
      padding: 0 20px 48px;
    }
  }
</style>
