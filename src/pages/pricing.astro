---
import Base from '../layouts/base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';
import Chip from '../components/Chip.astro';

const plans = [
  {
    name: 'Free',
    price: '0',
    period: 'forever',
    desc: 'For trying it out or keeping a few important files encrypted.',
    features: ['10 GB storage', 'E2E encryption', '1 user', 'Web + desktop + mobile', 'Community support'],
    cta: 'Start free',
    variant: 'default' as const,
  },
  {
    name: 'Personal',
    price: '5',
    period: '/month',
    desc: 'For individuals who want encrypted cloud storage they can rely on.',
    features: ['2 TB storage', 'E2E encryption', '1 user', 'All platforms', 'Priority email support', 'File versioning (90 days)', 'Encrypted sharing links'],
    cta: 'Start with Personal',
    variant: 'amber' as const,
    popular: true,
  },
  {
    name: 'Team',
    price: '6',
    period: '/user/month',
    desc: 'For small teams that need shared encrypted vaults and audit trails.',
    features: ['2 TB per user', 'E2E encryption', '5-50 users', 'Shared vaults', 'Team key management', 'Audit logs', 'SSO (SAML / OIDC)', 'Priority support'],
    cta: 'Start with Team',
    variant: 'default' as const,
  },
  {
    name: 'Business',
    price: '12',
    period: '/user/month',
    desc: 'For regulated industries that need compliance and dedicated support.',
    features: ['Unlimited storage', 'E2E encryption', 'Unlimited users', 'Everything in Team', 'Client portals', 'DPA included', 'DORA / NIS2 evidence pack', 'Dedicated account manager', 'Custom data residency'],
    cta: 'Contact sales',
    variant: 'default' as const,
  },
];
---

<Base title="Pricing — Beebeeb" description="Simple, honest pricing. No hidden fees, no dark patterns on the way out.">
  <Nav active="Pricing" />

  <!-- Hero -->
  <section class="px-8 pt-[72px] pb-12 text-center" style="background: linear-gradient(180deg, var(--color-amber-bg) 0%, var(--color-paper) 85%);">
    <div class="text-[11px] font-semibold tracking-[0.04em] uppercase text-amber-deep">Pricing</div>
    <h1 class="text-[52px] leading-[1.05] font-bold tracking-[-0.03em] mt-3 max-w-[900px] mx-auto">
      Simple enough to fit on one page.
    </h1>
    <p class="text-base text-ink-2 mt-5 max-w-[580px] mx-auto leading-relaxed">
      No per-feature pricing. No "contact us for a quote." No dark patterns on the way out. Cancel any time, export everything, leave.
    </p>
  </section>

  <!-- Plan cards -->
  <section class="px-12 pb-20 bg-paper">
    <div class="max-w-[1100px] mx-auto grid grid-cols-4 gap-4">
      {plans.map((plan) => (
        <div class:list={[
          'rounded-xl border p-6 flex flex-col',
          plan.popular ? 'border-amber-deep bg-paper shadow-2' : 'border-line bg-paper',
        ]}>
          <div class="flex items-center gap-2 mb-4">
            <h3 class="text-lg font-bold">{plan.name}</h3>
            {plan.popular && <Chip variant="amber">Popular</Chip>}
          </div>
          <div class="flex items-baseline gap-0.5 mb-3">
            <span class="text-[40px] font-bold tracking-tight leading-none">&euro;{plan.price}</span>
            <span class="text-sm text-ink-3">{plan.period}</span>
          </div>
          <p class="text-[13px] text-ink-2 leading-relaxed mb-6">{plan.desc}</p>
          <ul class="flex flex-col gap-2.5 mb-8 flex-1">
            {plan.features.map((f) => (
              <li class="flex items-start gap-2 text-[13px] text-ink-2">
                <svg class="w-4 h-4 text-[oklch(0.55_0.12_155)] shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                {f}
              </li>
            ))}
          </ul>
          <Button variant={plan.variant} size="md">{plan.cta}</Button>
        </div>
      ))}
    </div>

    <!-- Bottom note -->
    <p class="text-[12px] text-ink-3 text-center mt-8 max-w-[600px] mx-auto">
      All prices exclude VAT. Annual billing saves 20%. Every plan includes E2E encryption, EU-only storage, and our full zero-knowledge architecture.
    </p>
  </section>

  <Footer />
</Base>
