---
import Base from '../layouts/base.astro';
import { getLaunchPhase } from '../lib/strapi';
import { phaseConfig } from '../lib/phase';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import WaitlistModalTrigger from '../components/WaitlistModalTrigger.astro';
import SecFinalCTA from '../components/sections/SecFinalCTA.astro';
import '../styles/landing.css';

const phase = await getLaunchPhase();
const cfg = phaseConfig(phase);

const basicMonthly = 3.99;
const basicAnnual  = 3.25;   // €39/yr ÷ 12
const basicAnnualTotal = 39;

const proMonthly = 9.99;
const proAnnual  = 8.25;     // €99/yr ÷ 12
const proAnnualTotal = 99;
---

<Base
  title="Pricing — Beebeeb"
  description="Simple, honest pricing. Free (5 GB), Basic €3.99/month (1 TB), Pro €9.99/month (10 TB). Zero-knowledge encryption on every plan. EU-only storage."
  path="/pricing"
  chrome={false}
>
  <Nav active="pricing" {cfg} />

  <!-- Hero -->
  <div class="pricing-hero">
    <div class="bb-container pricing-hero-inner">
      <div class="bb-eyebrow" style="justify-content: center; display: inline-flex;">Pricing</div>
      <h1 class="bb-display-l pricing-title">Simple pricing.<br />No surprises.</h1>
      <p class="pricing-subtitle">
        All plans include zero-knowledge encryption. Your files are encrypted before they leave your device.
        EU infrastructure only.
      </p>

      <!-- Billing toggle -->
      <div class="bb-segment" role="tablist" id="billing-toggle" aria-label="Billing period">
        <button id="btn-monthly" class="on" aria-pressed="true" type="button">Monthly</button>
        <button id="btn-annual" aria-pressed="false" type="button">
          Annual <span class="save">SAVE 20%</span>
        </button>
      </div>
    </div>
  </div>

  <!-- Plan cards -->
  <div class="pricing-cards-section">
    <div class="bb-container pricing-grid">

      <!-- Free -->
      <div class="bb-plan">
        <div class="plan-header">
          <div class="t-label plan-name">Free</div>
          <div class="plan-price-row">
            <span class="plan-price">&euro;0</span>
            <span class="plan-price-unit">/mo</span>
          </div>
          <div class="plan-price-note">Always free</div>
        </div>

        <div class="plan-tagline">Try Beebeeb with no commitment.</div>

        <ul class="plan-features" aria-label="Free plan features">
          <li><span class="check" aria-hidden="true">&#10003;</span>5 GB storage</li>
          <li><span class="check" aria-hidden="true">&#10003;</span>Up to 3 devices</li>
          <li><span class="check" aria-hidden="true">&#10003;</span>End-to-end encryption</li>
          <li><span class="check" aria-hidden="true">&#10003;</span>Web access</li>
          <li><span class="check" aria-hidden="true">&#10003;</span>Mobile app</li>
          <li><span class="check" aria-hidden="true">&#10003;</span>Manual backups</li>
        </ul>

        {cfg.isLive ? (
          <a href="https://app.beebeeb.io/signup?plan=free" class="bb-cta ghost plan-cta"
             target="_blank" rel="noopener noreferrer">
            Get started free
          </a>
        ) : (
          <WaitlistModalTrigger source="pricing" plan="free" planLabel="Free" variant="free" buttonClass="plan-card" />
        )}
      </div>

      <!-- Basic (Popular) -->
      <div class="bb-plan popular" aria-label="Most popular plan">
        <div class="bb-plan-badge popular" aria-label="Popular plan badge">Popular</div>

        <div class="plan-header">
          <div class="t-label plan-name">Basic</div>
          <div class="plan-price-row">
            <span class="plan-price" id="basic-price">&euro;3,99</span>
            <span class="plan-price-unit">/mo</span>
          </div>
          <div class="plan-price-note" id="basic-note">billed monthly</div>
        </div>

        <div class="plan-tagline">For people who want real privacy for their personal files.</div>

        <ul class="plan-features" aria-label="Basic plan features">
          <li><span class="check" aria-hidden="true">&#10003;</span>1 TB storage</li>
          <li><span class="check" aria-hidden="true">&#10003;</span>Unlimited devices</li>
          <li><span class="check" aria-hidden="true">&#10003;</span>End-to-end encryption</li>
          <li><span class="check" aria-hidden="true">&#10003;</span>Web access</li>
          <li><span class="check" aria-hidden="true">&#10003;</span>Mobile app</li>
          <li><span class="check" aria-hidden="true">&#10003;</span>Automatic backups</li>
          <li><span class="check" aria-hidden="true">&#10003;</span>Priority support</li>
          <li><span class="check" aria-hidden="true">&#10003;</span>Share links with expiry</li>
        </ul>

        {cfg.isLive ? (
          <a href="https://app.beebeeb.io/signup?plan=basic" class="bb-cta amber plan-cta"
             target="_blank" rel="noopener noreferrer">
            Start Basic
          </a>
        ) : (
          <WaitlistModalTrigger source="pricing" plan="basic" planLabel="Basic" variant="basic" buttonClass="plan-card" />
        )}
      </div>

      <!-- Pro -->
      <div class="bb-plan">
        <div class="plan-header">
          <div class="t-label plan-name">Pro</div>
          <div class="plan-price-row">
            <span class="plan-price" id="pro-price">&euro;9,99</span>
            <span class="plan-price-unit">/mo</span>
          </div>
          <div class="plan-price-note" id="pro-note">billed monthly</div>
        </div>

        <div class="plan-tagline">For power users and creators with serious storage needs.</div>

        <ul class="plan-features" aria-label="Pro plan features">
          <li><span class="check" aria-hidden="true">&#10003;</span>10 TB storage</li>
          <li><span class="check" aria-hidden="true">&#10003;</span>Unlimited devices</li>
          <li><span class="check" aria-hidden="true">&#10003;</span>End-to-end encryption</li>
          <li><span class="check" aria-hidden="true">&#10003;</span>Web access</li>
          <li><span class="check" aria-hidden="true">&#10003;</span>Mobile app</li>
          <li><span class="check" aria-hidden="true">&#10003;</span>Automatic backups</li>
          <li><span class="check" aria-hidden="true">&#10003;</span>Priority support</li>
          <li><span class="check" aria-hidden="true">&#10003;</span>Share links with expiry</li>
          <li><span class="check" aria-hidden="true">&#10003;</span>Proof of existence</li>
          <li><span class="check" aria-hidden="true">&#10003;</span>File request links</li>
          <li><span class="check" aria-hidden="true">&#10003;</span>Admin API access</li>
        </ul>

        {cfg.isLive ? (
          <a href="https://app.beebeeb.io/signup?plan=pro" class="bb-cta plan-cta"
             target="_blank" rel="noopener noreferrer">
            Start Pro
          </a>
        ) : (
          <WaitlistModalTrigger source="pricing" plan="pro" planLabel="Pro" variant="pro" buttonClass="plan-card" />
        )}
      </div>

    </div>

    <!-- Footer note -->
    <div class="bb-container">
      <p class="pricing-footnote">
        All plans include zero-knowledge encryption. No credit card required for the free plan.
        EU data storage only &mdash; Falkenstein, Germany &middot; Hetzner. Cancel anytime.
      </p>
    </div>
  </div>

  <!-- All plans include section -->
  <div class="pricing-all-plans">
    <div class="bb-container-narrow">
      <div class="t-label" style="margin-bottom: 20px; text-align: center; color: var(--ink-3);">All plans include</div>
      <div class="all-plans-grid">
        {[
          'End-to-end encryption (AES-256-GCM)',
          'Zero-knowledge architecture',
          'EU-only storage, under EU law',
          'Version history',
          'Share links with revocation',
          'Open source clients',
          'Same security on every plan',
          'No US Cloud Act exposure',
        ].map(f => (
          <div class="all-plans-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--ink-3)" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
            <span>{f}</span>
          </div>
        ))}
      </div>
      <p class="pricing-region-note">
        Stored in Europe. Operated under EU law &mdash; no US Cloud Act exposure.
        Prices include VAT for EU customers; VAT-exclusive outside the EU.
      </p>
    </div>
  </div>

  <SecFinalCTA {cfg} />
  <Footer {cfg} />
</Base>

<script define:vars={{ basicMonthly, basicAnnual, basicAnnualTotal, proMonthly, proAnnual, proAnnualTotal }}>
  function fmt(n) {
    return '€' + n.toFixed(2).replace('.', ',');
  }

  let billing = 'monthly';

  const btnMonthly = document.getElementById('btn-monthly');
  const btnAnnual  = document.getElementById('btn-annual');

  function setToggle(active) {
    btnMonthly?.classList.toggle('on', active === 'monthly');
    btnAnnual?.classList.toggle('on', active === 'annual');
    btnMonthly?.setAttribute('aria-pressed', String(active === 'monthly'));
    btnAnnual?.setAttribute('aria-pressed', String(active === 'annual'));
  }

  function updatePrices() {
    const isAnnual = billing === 'annual';

    const basicPriceEl = document.getElementById('basic-price');
    const basicNoteEl  = document.getElementById('basic-note');
    if (basicPriceEl) basicPriceEl.textContent = fmt(isAnnual ? basicAnnual : basicMonthly);
    if (basicNoteEl)  basicNoteEl.textContent  = isAnnual
      ? 'billed €' + basicAnnualTotal + '/year'
      : 'billed monthly';

    const proPriceEl = document.getElementById('pro-price');
    const proNoteEl  = document.getElementById('pro-note');
    if (proPriceEl) proPriceEl.textContent = fmt(isAnnual ? proAnnual : proMonthly);
    if (proNoteEl)  proNoteEl.textContent  = isAnnual
      ? 'billed €' + proAnnualTotal + '/year'
      : 'billed monthly';
  }

  if (btnMonthly && btnAnnual) {
    btnMonthly.addEventListener('click', () => { billing = 'monthly'; setToggle('monthly'); updatePrices(); });
    btnAnnual.addEventListener('click',  () => { billing = 'annual';  setToggle('annual');  updatePrices(); });
  }
</script>

<style>
  /* Hero */
  .pricing-hero {
    padding: 80px 32px 40px;
    background: var(--paper);
    border-bottom: 1px solid var(--line);
    text-align: center;
  }

  .pricing-hero-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  .pricing-hero .bb-eyebrow {
    margin-bottom: 20px;
  }

  .pricing-title {
    margin: 0 0 18px;
  }

  .pricing-subtitle {
    font-size: 16px;
    color: var(--ink-2);
    max-width: 540px;
    margin: 0 auto 36px;
    line-height: 1.65;
  }

  /* Cards section */
  .pricing-cards-section {
    padding: 40px 32px 56px;
    background: var(--paper);
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 28px;
  }

  /* Plan internals */
  .plan-header {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .plan-name {
    margin-bottom: 8px;
    color: var(--ink-3);
  }

  .plan-price-row {
    display: flex;
    align-items: baseline;
    gap: 3px;
  }

  .plan-price {
    font-size: 42px;
    font-weight: 600;
    letter-spacing: -0.028em;
    color: var(--ink);
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }

  .plan-price-unit {
    font-size: 14px;
    color: var(--ink-3);
    font-weight: 400;
  }

  .plan-price-note {
    font-size: 11.5px;
    color: var(--ink-4);
    margin-top: 4px;
    font-family: var(--font-mono);
    min-height: 16px;
  }

  .plan-tagline {
    font-size: 13px;
    line-height: 1.55;
    color: var(--ink-2);
  }

  /* Feature list */
  .plan-features {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 7px;
    flex: 1;
  }

  .plan-features li {
    display: flex;
    align-items: flex-start;
    gap: 9px;
    font-size: 13.5px;
    color: var(--ink);
    line-height: 1.45;
  }

  .check {
    flex-shrink: 0;
    width: 16px;
    height: 16px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    color: var(--ink-3);
    margin-top: 1px;
  }

  /* CTA button */
  .plan-cta {
    width: 100%;
    justify-content: center;
    padding: 12px 16px;
    margin-top: auto;
    font-size: 14px;
  }

  /* Footnote */
  .pricing-footnote {
    font-size: 12px;
    color: var(--ink-4);
    text-align: center;
    line-height: 1.6;
    margin: 0;
    font-style: italic;
  }

  /* All plans include */
  .pricing-all-plans {
    padding: 64px 32px;
    background: var(--paper-2);
    border-top: 1px solid var(--line);
  }

  .all-plans-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px 32px;
    margin-bottom: 24px;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 24px 28px;
  }

  .all-plans-item {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 13.5px;
    color: var(--ink);
  }

  .all-plans-item svg {
    flex-shrink: 0;
  }

  .pricing-region-note {
    font-size: 11px;
    color: var(--ink-4);
    text-align: center;
    font-style: italic;
    margin: 0;
    line-height: 1.6;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .pricing-grid {
      grid-template-columns: 1fr;
      max-width: 480px;
      margin-left: auto;
      margin-right: auto;
    }

    .all-plans-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .pricing-hero {
      padding: 60px 20px 32px;
    }

    .pricing-cards-section {
      padding: 32px 20px 48px;
    }

    .pricing-all-plans {
      padding: 48px 20px;
    }

    .plan-price {
      font-size: 36px;
    }
  }
</style>
