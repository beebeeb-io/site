---
import Base from '../layouts/base.astro';

// ─── Plan data ────────────────────────────────────────────────────────────
// Annual prices represent a 20 % discount billed as one yearly charge.
// Prices in EUR, excluding VAT.

const plans = [
  {
    name: 'Free',
    slug: 'free',
    monthly: { price: '0', note: '/mo' },
    annual:  { price: '0', note: '/mo' },
    description: 'Try Beebeeb with no commitment. Full E2E encryption, 5 GB storage.',
    perTb: null,
    features: [
      '5 GB storage',
      'End-to-end encryption',
      'Web + mobile apps',
      'Up to 50 share links',
    ],
    cta: { label: 'Start free', href: 'https://app.beebeeb.io/signup?plan=free' },
    variant: 'outline' as const,
    popular: false,
    badge: null as string | null,
  },
  {
    name: 'Personal',
    slug: 'personal',
    monthly: { price: '8.99', note: '/mo' },
    annual:  { price: '7.19', note: '/mo', billed: 'billed €86.30/year' },
    description: 'For people who want real privacy for their personal files.',
    perTb: '€8.99/TB',
    features: [
      '1 TB storage',
      'Version history (30 days)',
      'All platforms',
      'Unlimited share links',
      'Priority transfers',
    ],
    cta: { label: 'Get Personal', href: 'https://app.beebeeb.io/signup?plan=personal' },
    variant: 'amber' as const,
    popular: true,
    badge: null as string | null,
  },
  {
    name: 'Pro',
    slug: 'pro',
    monthly: { price: '39.95', note: '/mo' },
    annual:  { price: '31.96', note: '/mo', billed: 'billed €383.52/year' },
    description: 'For power users, creators, and developers with serious storage needs.',
    perTb: '€7.99/TB',
    features: [
      '5 TB storage',
      'Unlimited version history',
      'Desktop sync + CLI',
      'Shared folders',
      'Priority support',
    ],
    cta: { label: 'Get Pro', href: 'https://app.beebeeb.io/signup?plan=pro' },
    variant: 'outline' as const,
    popular: false,
    badge: null as string | null,
  },
  {
    name: 'Data Hoarder',
    slug: 'data_hoarder',
    monthly: { price: '139.80', note: '/mo' },
    annual:  { price: '111.84', note: '/mo', billed: 'billed €1,342.08/year' },
    description: 'For archivists, backup addicts, and anyone who needs 20 TB on a budget.',
    perTb: '€6.99/TB',
    features: [
      '20 TB storage',
      'Lowest per-TB price',
      'Unlimited version history',
      'Dedicated support channel',
      'Custom retention policies',
    ],
    cta: { label: 'Get Data Hoarder', href: 'https://app.beebeeb.io/signup?plan=data_hoarder' },
    variant: 'outline' as const,
    popular: false,
    badge: 'Best value' as string | null,
  },
];
---

<Base
  title="Pricing — Beebeeb"
  description="Beebeeb pricing: Free (5 GB), Personal €8.99/mo (1 TB), Pro €39.95/mo (5 TB), Data Hoarder €139.80/mo (20 TB). End-to-end encrypted cloud, EU infrastructure. Annual billing saves 20%."
  path="/pricing"
>

  <!-- ── Hero ─────────────────────────────────────────────────────── -->
  <section class="px-8 pt-[72px] pb-10 text-center">
    <div class="section-label bb-fade-up">Plans &amp; pricing</div>
    <h1 class="text-[48px] font-bold tracking-[-0.03em] mt-3 mb-3 leading-tight bb-fade-up bb-delay-1">
      Simple pricing. No surprises.
    </h1>
    <p class="text-base text-ink-2 max-w-[560px] mx-auto leading-relaxed bb-fade-up bb-delay-2">
      Start free with 5 GB. Upgrade when you need more. All plans include
      EU-only storage, zero-knowledge encryption, and full platform access.
    </p>
  </section>

  <!-- ── Toggle ────────────────────────────────────────────────────── -->
  <div class="flex justify-center mb-10 bb-fade-up bb-delay-3" aria-label="Billing period" role="group">
    <div class="inline-flex items-center p-1 rounded-xl border border-line bg-paper-2 gap-1">
      <button
        id="toggle-monthly"
        data-period="monthly"
        aria-pressed="false"
        class="bb-period-btn px-5 py-2 text-[13px] font-medium rounded-lg transition-all"
      >
        Monthly
      </button>
      <button
        id="toggle-annual"
        data-period="annual"
        aria-pressed="true"
        class="bb-period-btn px-5 py-2 text-[13px] font-medium rounded-lg transition-all flex items-center gap-2"
      >
        Annual
        <span class="px-2 py-0.5 rounded-full text-[10px] font-bold tracking-wide" style="background: oklch(0.88 0.08 155); color: oklch(0.35 0.1 155);">
          Save 20%
        </span>
      </button>
    </div>
  </div>

  <!-- ── Plan grid ──────────────────────────────────────────────────── -->
  <section class="px-8 pb-20">
    <div class="max-w-[1100px] mx-auto">

      <div id="bb-pricing-grid" data-period="annual" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">

        {plans.map((plan) => (
          <div class:list={[
            'relative p-6 rounded-xl border',
            plan.variant === 'amber' ? 'border-amber bg-amber-bg' : 'border-line bg-paper',
          ]}>

            {plan.popular && (
              <div class="absolute -top-3 left-1/2 -translate-x-1/2">
                <span class="px-3 py-1 bg-amber text-ink text-[10px] font-bold tracking-[0.06em] uppercase rounded-full">
                  Most popular
                </span>
              </div>
            )}
            {plan.badge && !plan.popular && (
              <div class="absolute -top-3 left-1/2 -translate-x-1/2">
                <span class="px-3 py-1 bg-paper border border-line-2 text-ink-2 text-[10px] font-bold tracking-[0.06em] uppercase rounded-full shadow-sm">
                  {plan.badge}
                </span>
              </div>
            )}

            <div class="text-[13px] font-semibold text-ink-3 uppercase tracking-[0.04em]">
              {plan.name}
            </div>

            <!-- Monthly price (hidden when annual is active) -->
            <div class="bb-price bb-price-monthly mt-2 mb-1">
              <span class="text-[42px] font-bold tracking-[-0.03em]">&euro;{plan.monthly.price}</span>
              <span class="text-sm text-ink-3 ml-1">{plan.monthly.note}</span>
            </div>

            <!-- Annual price (shown by default) -->
            <div class="bb-price bb-price-annual mt-2 mb-1">
              <span class="text-[42px] font-bold tracking-[-0.03em]">&euro;{plan.annual.price}</span>
              <span class="text-sm text-ink-3 ml-1">{plan.annual.note}</span>
              {plan.annual.billed && (
                <div class="text-[11px] text-ink-4 mt-0.5">{plan.annual.billed}</div>
              )}
            </div>

            {plan.perTb && (
              <div class="text-[11px] font-mono text-ink-4 -mt-0.5 mb-1">{plan.perTb}</div>
            )}
            <p class="text-[13px] text-ink-2 mb-5 leading-relaxed">{plan.description}</p>

            <ul class="space-y-2 mb-6">
              {plan.features.map((f) => (
                <li class="flex items-start gap-2 text-[13px] text-ink-2">
                  <svg class="w-[14px] h-[14px] text-green mt-0.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                  {f}
                </li>
              ))}
            </ul>

            <a
              href={plan.cta.href}
              class:list={[
                'btn w-full justify-center',
                plan.variant === 'amber' ? 'btn-amber btn-md' : 'btn-outline btn-md',
              ]}
            >
              {plan.cta.label}
            </a>
          </div>
        ))}

      </div>

      <p class="text-[11px] text-ink-4 text-center mt-8 italic">
        All plans include EU-only storage (Hetzner · Germany + Finland), zero-knowledge encryption,
        and full platform access. Prices exclude VAT.
      </p>
    </div>
  </section>

</Base>

<!-- ── Toggle behaviour ──────────────────────────────────────────────────── -->
<script>
  (function () {
    var grid  = document.getElementById('bb-pricing-grid');
    var btns  = document.querySelectorAll('.bb-period-btn');

    if (!grid || !btns.length) return;

    function activate(period) {
      grid.setAttribute('data-period', period);
      btns.forEach(function (btn) {
        var isActive = btn.getAttribute('data-period') === period;
        btn.setAttribute('aria-pressed', String(isActive));
      });
    }

    btns.forEach(function (btn) {
      btn.addEventListener('click', function () {
        activate(btn.getAttribute('data-period'));
      });
    });

    // Also re-apply on Astro client-side navigation
    document.addEventListener('astro:after-swap', function () {
      var savedGrid = document.getElementById('bb-pricing-grid');
      var savedBtns = document.querySelectorAll('.bb-period-btn');
      if (savedGrid && savedBtns.length) {
        activate('annual'); // reset to default
      }
    });
  })();
</script>

<!-- ── Toggle styles ─────────────────────────────────────────────────────── -->
<style>
  /* Active toggle button */
  .bb-period-btn[aria-pressed="true"] {
    background: var(--color-paper);
    color: var(--color-ink);
    font-weight: 600;
    box-shadow: var(--shadow-1);
  }
  .bb-period-btn[aria-pressed="false"] {
    color: var(--color-ink-3);
  }
  .bb-period-btn[aria-pressed="false"]:hover {
    color: var(--color-ink-2);
  }

  /* Price visibility */
  #bb-pricing-grid[data-period="annual"]  .bb-price-monthly { display: none; }
  #bb-pricing-grid[data-period="monthly"] .bb-price-annual  { display: none; }

  /* Smooth price swap: fade on the price container */
  .bb-price {
    transition: opacity 0.15s ease;
  }
</style>
