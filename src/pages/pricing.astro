---
import Base from '../layouts/base.astro';
import { getLaunchPhase } from '../lib/strapi';
import { phaseConfig } from '../lib/phase';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import WaitlistModalTrigger from '../components/WaitlistModalTrigger.astro';
import PlatformIcon from '../components/PlatformIcon.astro';
import SecFinalCTA from '../components/sections/SecFinalCTA.astro';
import '../styles/landing.css';

const phase = await getLaunchPhase();
const cfg = phaseConfig(phase);

const fmtEUR = (n: number) => '€' + n.toFixed(2).replace('.', ',');

// Annual = save 2 months (10/12)
const basicMonthly = 10.99;
const basicAnnual = +(basicMonthly * 10 / 12).toFixed(2);
const proBaseMonthly = 54.95;
const proBaseAnnual = +(proBaseMonthly * 10 / 12).toFixed(2);
const bizBaseMonthly = 109.90;
const bizBaseAnnual = +(bizBaseMonthly * 10 / 12).toFixed(2);

const platforms = [
  { key: 'web', label: 'Web app', live: cfg.webLive },
  { key: 'cli', label: 'CLI', live: cfg.cliLive },
  { key: 'macos', label: 'macOS', live: cfg.desktopLive },
  { key: 'windows', label: 'Windows', live: cfg.desktopLive },
  { key: 'linux', label: 'Linux', live: cfg.desktopLive },
  { key: 'ios', label: 'iOS', live: cfg.iosLive },
  { key: 'android', label: 'Android', live: cfg.androidLive },
  { key: 'rclone', label: 'rclone', live: cfg.rcloneLive },
];
const livePlatforms = platforms.filter(p => p.live);
const comingPlatforms = platforms.filter(p => !p.live);
const bizComing = !cfg.bizLive ? [
  'Shared workspaces (Business)',
  'Admin console (Business)',
  'Priority support + SLA (Business)',
] : [];
---

<Base
  title="Pricing — Beebeeb"
  description="Simple pricing. Free (5 GB), Basic €10.99/mo (1 TB), Pro €54.95/mo (5 TB+), Business €109.90/mo (10 TB + teams). EU-only encrypted cloud storage."
  path="/pricing"
  chrome={false}
>
  <Nav active="pricing" {cfg} />

  <!-- Hero -->
  <div style="padding: 72px 32px 32px; background: var(--paper); border-bottom: 1px solid var(--line); text-align: center;">
    <div class="bb-container" style="padding: 0;">
      <div class="bb-eyebrow" style="margin: 0 auto 18px; justify-content: center; display: inline-flex;">Pricing</div>
      <h1 class="bb-display-l" style="margin: 0 0 16px;">Simple pricing.<br />No surprises.</h1>
      <p style="font-size: 17px; color: var(--ink-2); max-width: 580px; margin: 0 auto 36px; line-height: 1.6;">
        Storage you can&rsquo;t be reasoned out of trusting. All plans, EU-only,
        end-to-end encrypted, full open source clients.
      </p>
      <div class="bb-segment" role="tablist" id="billing-toggle">
        <button id="btn-monthly" class="on" aria-pressed="true">Monthly</button>
        <button id="btn-annual" aria-pressed="false">
          Annual <span class="save">SAVE 2 MONTHS</span>
        </button>
      </div>
    </div>
  </div>

  <!-- Plan cards -->
  <div id="waitlist" style="padding: 32px 32px 64px; background: var(--paper); scroll-margin-top: 96px;">
    <div class="bb-container" style="padding: 0; display: grid; grid-template-columns: repeat(4, 1fr); gap: 18px;">

      <!-- Free -->
      <div class="bb-plan">
        <div>
          <div class="t-label" style="margin-bottom: 10px;">Free</div>
          <div style="font-size: 40px; font-weight: 600; letter-spacing: -0.025em; display: flex; align-items: baseline; gap: 4px;">
            &euro;0<span style="font-size: 14px; color: var(--ink-3); font-weight: 400;">/mo</span>
          </div>
          <div style="font-size: 12px; color: var(--ink-3); margin-top: 4px; height: 16px;">Always &euro;0</div>
        </div>
        <div style="font-size: 13.5px; line-height: 1.55; color: var(--ink-2); min-height: 38px;">
          Try Beebeeb with no commitment.
        </div>
        <div style="padding: 14px; background: var(--paper-2); border: 1px solid var(--line); border-radius: 8px;">
          <div class="t-label" style="margin-bottom: 6px;">What you get</div>
          <div style="font-family: var(--font-mono); font-size: 12.5px; color: var(--ink); display: flex; flex-direction: column; gap: 3px;">
            <span>5 GB storage</span>
            <span>1 user</span>
          </div>
        </div>
        {cfg.isLive ? (
          <a href="https://app.beebeeb.io/signup?plan=free" class="bb-cta plan-cta free"
             target="_blank" rel="noopener noreferrer">
            {cfg.freeCTA}
          </a>
        ) : (
          <button type="button" class="bb-cta plan-cta free pricing-waitlist-btn" data-preselect="free">Join the waitlist</button>
        )}
      </div>

      <!-- Basic -->
      <div class:list={['bb-plan', cfg.isLive ? 'popular' : '']}>
        {cfg.isLive && <div class="bb-plan-badge popular">Most popular</div>}
        <div>
          <div class="t-label" style="margin-bottom: 10px;">Basic</div>
          <div style="font-size: 40px; font-weight: 600; letter-spacing: -0.025em; display: flex; align-items: baseline; gap: 4px;">
            <span id="basic-price">&euro;{basicMonthly.toFixed(2).replace('.', ',')}</span>
            <span style="font-size: 14px; color: var(--ink-3); font-weight: 400;">/mo</span>
          </div>
          <div id="basic-note" style="font-size: 12px; color: var(--ink-3); margin-top: 4px; height: 16px;">billed monthly</div>
        </div>
        <div style="font-size: 13.5px; line-height: 1.55; color: var(--ink-2); min-height: 38px;">
          For people who want real privacy for their personal files.
        </div>
        <div style="padding: 14px; background: var(--paper-2); border: 1px solid var(--line); border-radius: 8px;">
          <div class="t-label" style="margin-bottom: 6px;">What you get</div>
          <div style="font-family: var(--font-mono); font-size: 12.5px; color: var(--ink); display: flex; flex-direction: column; gap: 3px;">
            <span>1 TB storage</span>
            <span>1 user</span>
          </div>
        </div>
        {cfg.isLive ? (
          <a href="https://app.beebeeb.io/signup?plan=basic" class="bb-cta plan-cta basic"
             target="_blank" rel="noopener noreferrer">
            {cfg.basicCTA}
          </a>
        ) : (
          <button type="button" class="bb-cta plan-cta basic pricing-waitlist-btn" data-preselect="basic">Join the waitlist</button>
        )}
      </div>

      <!-- Pro -->
      <div class="bb-plan">
        <div>
          <div class="t-label" style="margin-bottom: 10px;">Pro</div>
          <div style="font-size: 40px; font-weight: 600; letter-spacing: -0.025em; display: flex; align-items: baseline; gap: 4px; min-height: 48px;" aria-live="polite">
            <span id="pro-price">&euro;{proBaseMonthly.toFixed(2).replace('.', ',')}</span>
            <span id="pro-unit" style="font-size: 14px; color: var(--ink-3); font-weight: 400;">/mo</span>
          </div>
          <div id="pro-note" style="font-size: 12px; color: var(--ink-3); margin-top: 4px; height: 16px;">billed monthly</div>
        </div>
        <div style="font-size: 13.5px; line-height: 1.55; color: var(--ink-2); min-height: 38px;">
          For power users with serious storage needs.
        </div>
        <div style="padding: 14px; background: var(--paper-2); border: 1px solid var(--line); border-radius: 8px;">
          <div style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 4px;">
            <span class="t-label">Storage</span>
            <span id="pro-tb-label" style="font-family: var(--font-mono); font-size: 14px; font-weight: 600; color: var(--ink);">5 TB</span>
          </div>
          <input type="range" class="bb-slider" id="pro-slider"
                 min="5" max="100" step="1" value="5"
                 aria-label="Storage in TB" aria-valuemin="5" aria-valuemax="100"
                 aria-valuenow="5" aria-valuetext="5 TB" />
          <div style="display: flex; justify-content: space-between; font-family: var(--font-mono); font-size: 10px; color: var(--ink-4); margin-top: 2px;">
            <span>5 TB</span><span>99 TB</span><span>100+</span>
          </div>
          <div style="font-size: 11.5px; color: var(--ink-3); margin-top: 8px; font-family: var(--font-mono);">
            1 user &middot; &euro;10,99 / extra TB
          </div>
        </div>
        {cfg.isLive ? (
          <a id="pro-cta"
             href="https://app.beebeeb.io/signup?plan=pro"
             target="_blank" rel="noopener noreferrer"
             class="bb-cta plan-cta pro">
            {cfg.proCTA}
          </a>
        ) : (
          <button type="button" class="bb-cta plan-cta pro pricing-waitlist-btn" data-preselect="pro">Join the waitlist</button>
        )}
      </div>

      <!-- Business -->
      <div class:list={['bb-plan', !cfg.bizLive ? 'coming' : '']}>
        {cfg.bizBadge && <div class="bb-plan-badge coming">{cfg.bizBadge}</div>}
        <div>
          <div class="t-label" style="margin-bottom: 10px;">Business</div>
          <div style={`font-size: 40px; font-weight: 600; letter-spacing: -0.025em; display: flex; align-items: baseline; gap: 4px; min-height: 48px; color: ${cfg.bizLive ? 'var(--ink)' : 'var(--ink-3)'};`} aria-live="polite">
            <span id="biz-price">&euro;{bizBaseMonthly.toFixed(2).replace('.', ',')}</span>
            <span id="biz-unit" style="font-size: 14px; color: var(--ink-3); font-weight: 400;">/mo</span>
          </div>
          <div id="biz-note" style="font-size: 12px; color: var(--ink-3); margin-top: 4px; height: 16px;">billed monthly</div>
        </div>
        <div style="font-size: 13.5px; line-height: 1.55; color: var(--ink-2); min-height: 38px;">
          For teams. Shared workspaces, admin console, SLA.
        </div>
        <div style={`padding: 14px; background: var(--paper-2); border: 1px solid var(--line); border-radius: 8px; opacity: ${cfg.bizLive ? '1' : '0.85'};`}>
          <div style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 4px;">
            <span class="t-label">Storage</span>
            <span id="biz-tb-label" style="font-family: var(--font-mono); font-size: 13px; font-weight: 600; color: var(--ink);">10 TB</span>
          </div>
          <input type="range" class="bb-slider" id="biz-tb-slider"
                 min="10" max="100" step="1" value="10"
                 aria-label="Business storage in TB" />
          <div style="height: 10px;"></div>
          <div style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 4px;">
            <span class="t-label">Users</span>
            <span id="biz-user-label" style="font-family: var(--font-mono); font-size: 13px; font-weight: 600; color: var(--ink);">3</span>
          </div>
          <input type="range" class="bb-slider" id="biz-user-slider"
                 min="3" max="50" step="1" value="3"
                 aria-label="Business team size" />
          <div style="font-size: 11.5px; color: var(--ink-3); margin-top: 8px; font-family: var(--font-mono);">
            &euro;10,99/extra TB &middot; &euro;4,99/extra user
          </div>
        </div>
        {cfg.bizLive ? (
          <a id="biz-cta" href="https://app.beebeeb.io/signup?plan=business" class="bb-cta plan-cta business"
             target="_blank" rel="noopener noreferrer">
            {cfg.bizCTA}
          </a>
        ) : (
          <button type="button" class="bb-cta plan-cta business-muted pricing-waitlist-btn" data-preselect="business">Join the waitlist</button>
        )}
      </div>

    </div>

    <WaitlistModalTrigger source="pricing-picker" renderButton={false} />
  </div>

  <script>
    function initPricingWaitlist() {
      const modalId = 'waitlist-modal-pricing-picker';
      const dialog = document.getElementById(modalId);
      if (!dialog || dialog.dataset.pricingBound) return;
      dialog.dataset.pricingBound = 'true';

      const PRICES = {
        free:     { base: 0,      perTb: 0,     perUser: 0,    baseTb: 5,  baseUsers: 1 },
        basic:    { base: 10.99,  perTb: 0,     perUser: 0,    baseTb: 1,  baseUsers: 1 },
        pro:      { base: 54.95,  perTb: 10.99, perUser: 0,    baseTb: 5,  baseUsers: 1 },
        business: { base: 109.90, perTb: 10.99, perUser: 4.99, baseTb: 10, baseUsers: 3 },
      };

      function fmtEUR(n) {
        return '€' + n.toFixed(2).replace('.', ',');
      }

      function getSelectedPlan() {
        const sel = dialog.querySelector('[data-waitlist-plan-option].selected');
        return sel?.dataset.waitlistPlanOption || 'free';
      }

      function getSliderValue(attr) {
        const el = dialog.querySelector(`[${attr}]`);
        return el ? Number(el.value) : 0;
      }

      function calcPrice(plan) {
        const p = PRICES[plan];
        if (!p) return { monthly: 0, breakdown: '' };
        let monthly = p.base;
        const parts = [fmtEUR(p.base) + '/mo base'];

        if (plan === 'pro') {
          const tb = getSliderValue('data-waitlist-generic-pro-storage');
          const extraTb = Math.max(0, tb - p.baseTb);
          monthly += extraTb * p.perTb;
          if (extraTb > 0) parts.push('+' + fmtEUR(extraTb * p.perTb) + ' (' + extraTb + ' extra TB)');
        }
        if (plan === 'business') {
          const tb = getSliderValue('data-waitlist-generic-business-storage');
          const users = getSliderValue('data-waitlist-generic-business-users');
          const extraTb = Math.max(0, tb - p.baseTb);
          const extraUsers = Math.max(0, users - p.baseUsers);
          monthly += extraTb * p.perTb + extraUsers * p.perUser;
          if (extraTb > 0) parts.push('+' + fmtEUR(extraTb * p.perTb) + ' (' + extraTb + ' extra TB)');
          if (extraUsers > 0) parts.push('+' + fmtEUR(extraUsers * p.perUser) + ' (' + extraUsers + ' extra users)');
        }
        return { monthly, breakdown: parts.length > 1 ? parts.join(' ') : '' };
      }

      function ensurePriceRow() {
        let row = dialog.querySelector('[data-pricing-row]');
        if (!row) {
          const summary = dialog.querySelector('.modal-summary');
          if (!summary) return null;
          row = document.createElement('div');
          row.setAttribute('data-pricing-row', '');
          row.style.cssText = 'display:flex;min-height:28px;align-items:center;justify-content:space-between;gap:14px;';
          const label = document.createElement('span');
          label.textContent = 'Price';
          label.style.cssText = 'color:var(--ink-3);font-family:var(--font-mono);font-size:10.5px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;';
          const value = document.createElement('strong');
          value.setAttribute('data-pricing-value', '');
          value.style.cssText = 'display:inline-flex;align-items:center;justify-content:center;padding:4px 9px;border:1px solid var(--line-2);border-radius:999px;background:var(--paper);color:var(--ink);font-size:12.5px;font-weight:700;line-height:1.2;';
          row.appendChild(label);
          row.appendChild(value);
          summary.insertBefore(row, summary.firstChild);

          const breakdown = document.createElement('div');
          breakdown.setAttribute('data-pricing-breakdown', '');
          breakdown.style.cssText = 'font-size:11px;color:var(--ink-3);font-family:var(--font-mono);padding:2px 2px 0;';
          summary.insertBefore(breakdown, row.nextSibling);
        }
        return row;
      }

      function updatePrice() {
        const plan = getSelectedPlan();
        const { monthly, breakdown } = calcPrice(plan);
        const row = ensurePriceRow();
        if (!row) return;
        const valueEl = row.querySelector('[data-pricing-value]');
        const breakdownEl = dialog.querySelector('[data-pricing-breakdown]');
        if (valueEl) {
          valueEl.textContent = plan === 'free' ? 'Free' : fmtEUR(monthly) + '/mo';
        }
        if (breakdownEl) {
          breakdownEl.textContent = breakdown;
          breakdownEl.style.display = breakdown ? '' : 'none';
        }
      }

      function selectPlan(plan) {
        dialog.querySelectorAll('[data-waitlist-plan-option]').forEach((option) => {
          const selected = option.dataset.waitlistPlanOption === plan;
          option.classList.toggle('selected', selected);
          option.setAttribute('aria-pressed', String(selected));
        });
        const proControls = dialog.querySelector('[data-waitlist-generic-pro-controls]');
        const bizControls = dialog.querySelector('[data-waitlist-generic-business-controls]');
        if (proControls) proControls.hidden = plan !== 'pro';
        if (bizControls) bizControls.hidden = plan !== 'business';

        const summaryPlan = dialog.querySelector('[data-waitlist-summary-plan]');
        if (summaryPlan) summaryPlan.textContent = plan.charAt(0).toUpperCase() + plan.slice(1);
        const storageRow = dialog.querySelector('[data-waitlist-summary-storage]');
        const usersRow = dialog.querySelector('[data-waitlist-summary-users]');
        if (storageRow) storageRow.hidden = plan !== 'pro' && plan !== 'business';
        if (usersRow) usersRow.hidden = plan !== 'business';

        const planField = dialog.querySelector('input[name="plan"]');
        if (planField) planField.value = plan;
        updatePrice();
      }

      dialog.querySelectorAll('[data-waitlist-plan-option]').forEach((btn) => {
        btn.addEventListener('click', () => {
          selectPlan(btn.dataset.waitlistPlanOption || 'free');
        });
      });

      dialog.querySelectorAll('[data-waitlist-generic-pro-storage], [data-waitlist-generic-business-storage], [data-waitlist-generic-business-users]').forEach((input) => {
        input.addEventListener('input', updatePrice);
      });

      document.querySelectorAll('.pricing-waitlist-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          selectPlan(btn.dataset.preselect || 'free');
          if (typeof dialog.showModal === 'function') dialog.showModal();
          dialog.querySelector('input[type="email"]')?.focus();
        });
      });
    }
    initPricingWaitlist();
    document.addEventListener('astro:after-swap', initPricingWaitlist);
  </script>

  <!-- Features section -->
  <div style="padding: 64px 32px; background: var(--paper-2); border-top: 1px solid var(--line);">
    <div class="bb-container" style="padding: 0;">
      <div class="t-label" style="margin-bottom: 12px; color: var(--ink-3);">All plans include</div>
      <div style="background: var(--paper); border-radius: 12px; border: 1px solid var(--line); overflow: hidden;">

        <!-- Guaranteed forever -->
        <div style="padding: 24px; border-bottom: 1px solid var(--line);">
          <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 14px;">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="var(--amber-deep)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            <span style="font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--amber-deep); font-weight: 600;">Guaranteed forever</span>
          </div>
          <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px 24px;">
            {['End-to-end encryption (AES-256-GCM)', 'Zero-knowledge architecture',
              'EU-only storage, under EU law', 'Same security on every plan',
              'Version history', 'Share links with revocation', 'Open source clients'].map(f => (
              <div style="display: flex; align-items: center; gap: 10px; font-size: 13.5px; color: var(--ink);">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--ink)" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                {f}
              </div>
            ))}
          </div>
        </div>

        <!-- Available platforms -->
        {livePlatforms.length > 0 && (
          <div style={`padding: 22px 24px; border-bottom: ${(comingPlatforms.length || bizComing.length) ? '1px solid var(--line)' : 'none'};`}>
            <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 14px;">
              <span style={`width: 6px; height: 6px; border-radius: 999px; background: ${cfg.isLive ? 'var(--green)' : 'var(--amber)'}; box-shadow: ${cfg.isLive ? '0 0 0 3px oklch(0.6 0.16 145 / 0.2)' : '0 0 0 3px oklch(0.82 0.17 84 / 0.2)'};`}></span>
              <span style={`font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: ${cfg.isLive ? 'oklch(0.4 0.1 155)' : 'var(--amber-deep)'}; font-weight: 600;`}>{cfg.availLabel}</span>
            </div>
            <div style="display: flex; gap: 10px; flex-wrap: wrap;">
              {livePlatforms.map(p => (
                <div class="bb-platform">
                  <span class="platform-glyph" aria-hidden="true"><PlatformIcon name={p.key} /></span>
                  <span>{p.label}</span>
                </div>
              ))}
            </div>
          </div>
        )}

        <!-- Coming soon platforms -->
        {(comingPlatforms.length > 0 || bizComing.length > 0) && (
          <div style="padding: 22px 24px; background: var(--paper-2);">
            <div class="t-label" style="margin-bottom: 14px; color: var(--ink-3);">Coming soon</div>
            {comingPlatforms.length > 0 && (
              <div style={`display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: ${bizComing.length ? '14px' : '0'};`}>
                {comingPlatforms.map(p => (
                  <div class="bb-platform coming">
                    <span class="platform-glyph" aria-hidden="true"><PlatformIcon name={p.key} /></span>
                    <span>{p.label}</span>
                  </div>
                ))}
              </div>
            )}
            {bizComing.length > 0 && (
              <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px 24px;">
                {bizComing.map(f => (
                  <div style="display: flex; align-items: center; gap: 10px; font-size: 13.5px; color: var(--ink-3);">
                    <span style="width: 14px; height: 14px; display: inline-flex; align-items: center; justify-content: center; border-radius: 999px; border: 1px dashed var(--ink-4); flex-shrink: 0;">
                      <span style="width: 4px; height: 4px; border-radius: 999px; background: var(--ink-4);"></span>
                    </span>
                    {f}
                  </div>
                ))}
              </div>
            )}
          </div>
        )}
      </div>

      <div style="font-size: 11px; color: var(--ink-4); text-align: center; margin-top: 16px; font-style: italic;">
        Stored in Europe. Operated under EU law &mdash; no US Cloud Act exposure.
        Prices include VAT for EU customers; VAT-exclusive outside the EU.
      </div>
    </div>
  </div>

  <SecFinalCTA {cfg} />
  <Footer {cfg} />
</Base>

<script define:vars={{
  basicMonthly,
  basicAnnual,
  proBaseMonthly,
  proBaseAnnual,
  bizBaseMonthly,
  bizBaseAnnual,
  isLive: cfg.isLive,
  bizLive: cfg.bizLive,
  proCTA: cfg.proCTA,
  bizCTA: cfg.bizCTA,
}}>
  let billing = 'monthly';

  function fmt(n) {
    return '€' + n.toFixed(2).replace('.', ',');
  }

  // Billing toggle
  const btnMonthly = document.getElementById('btn-monthly');
  const btnAnnual  = document.getElementById('btn-annual');
  if (btnMonthly && btnAnnual) {
    btnMonthly.addEventListener('click', () => { billing = 'monthly'; updateAll(); setToggle('monthly'); });
    btnAnnual.addEventListener('click',  () => { billing = 'annual';  updateAll(); setToggle('annual');  });
  }

  function setToggle(active) {
    btnMonthly?.classList.toggle('on', active === 'monthly');
    btnAnnual?.classList.toggle('on', active === 'annual');
    btnMonthly?.setAttribute('aria-pressed', String(active === 'monthly'));
    btnAnnual?.setAttribute('aria-pressed', String(active === 'annual'));
  }

  // Basic
  function updateBasic() {
    const price = billing === 'annual' ? basicAnnual : basicMonthly;
    const note  = billing === 'annual'
      ? 'billed €' + (basicAnnual * 12).toFixed(2).replace('.', ',') + '/year'
      : 'billed monthly';
    const el = document.getElementById('basic-price');
    const nl = document.getElementById('basic-note');
    if (el) el.textContent = fmt(price);
    if (nl) nl.textContent = note;
  }

  // Pro
  const proSlider = document.getElementById('pro-slider');
  function updatePro() {
    const tb = parseInt(proSlider?.value ?? '5', 10);
    const isQuote = tb >= 100;
    const priceEl = document.getElementById('pro-price');
    const unitEl  = document.getElementById('pro-unit');
    const noteEl  = document.getElementById('pro-note');
    const ctaEl   = document.getElementById('pro-cta');
    const tbLabel = document.getElementById('pro-tb-label');
    if (tbLabel) tbLabel.textContent = isQuote ? '100+ TB' : tb + ' TB';
    if (proSlider) {
      proSlider.setAttribute('aria-valuenow', String(tb));
      proSlider.setAttribute('aria-valuetext', isQuote ? 'over 99 TB — get a quote' : tb + ' TB');
    }
    if (isQuote) {
      if (priceEl) priceEl.textContent = 'Get a quote';
      if (unitEl)  unitEl.textContent = '';
      if (noteEl)  noteEl.textContent = 'Beyond 99 TB';
      if (ctaEl)   { ctaEl.textContent = 'Get a quote →'; ctaEl.href = 'mailto:sales@beebeeb.io'; ctaEl.className = 'bb-cta plan-cta free'; }
    } else {
      const monthly = proBaseMonthly + Math.max(0, tb - 5) * 10.99;
      const annual  = proBaseAnnual  + Math.max(0, tb - 5) * 10.99;
      const price = billing === 'annual' ? annual : monthly;
      const hasExtras = tb > 5;
      if (priceEl) priceEl.textContent = fmt(price);
      if (unitEl)  unitEl.textContent = '/mo';
      if (noteEl)  noteEl.textContent = billing === 'annual'
        ? (hasExtras ? 'Base annual · add-ons monthly' : 'billed €' + (proBaseAnnual * 12).toFixed(2).replace('.', ',') + '/year')
        : 'billed monthly';
      if (ctaEl && isLive) { ctaEl.textContent = proCTA; ctaEl.href = 'https://app.beebeeb.io/signup?plan=pro'; ctaEl.className = 'bb-cta plan-cta pro'; }
    }
  }
  if (proSlider) proSlider.addEventListener('input', updatePro);

  // Business
  const bizTbSlider   = document.getElementById('biz-tb-slider');
  const bizUserSlider = document.getElementById('biz-user-slider');
  function updateBiz() {
    const tb    = parseInt(bizTbSlider?.value ?? '10', 10);
    const users = parseInt(bizUserSlider?.value ?? '3', 10);
    const isQuote = tb >= 100 || users >= 50;
    const priceEl = document.getElementById('biz-price');
    const unitEl  = document.getElementById('biz-unit');
    const noteEl  = document.getElementById('biz-note');
    const ctaEl   = document.getElementById('biz-cta');
    if (document.getElementById('biz-tb-label'))   document.getElementById('biz-tb-label').textContent = tb >= 100 ? '100+ TB' : tb + ' TB';
    if (document.getElementById('biz-user-label')) document.getElementById('biz-user-label').textContent = users >= 50 ? '50+' : String(users);
    if (isQuote) {
      if (priceEl) priceEl.textContent = 'Get a quote';
      if (unitEl)  unitEl.textContent = '';
      if (noteEl)  noteEl.textContent = 'Beyond 99 TB or 49 users';
      if (ctaEl && bizLive) { ctaEl.textContent = 'Get a quote →'; ctaEl.href = 'mailto:sales@beebeeb.io'; ctaEl.className = 'bb-cta plan-cta business-muted'; }
    } else {
      const monthly = bizBaseMonthly + Math.max(0, tb - 10) * 10.99 + Math.max(0, users - 3) * 4.99;
      const annual  = bizBaseAnnual  + Math.max(0, tb - 10) * 10.99 + Math.max(0, users - 3) * 4.99;
      const hasExtras = tb > 10 || users > 3;
      const price = billing === 'annual' ? annual : monthly;
      if (priceEl) priceEl.textContent = fmt(price);
      if (unitEl)  unitEl.textContent = '/mo';
      if (noteEl)  noteEl.textContent = billing === 'annual'
        ? (hasExtras ? 'Base annual · add-ons monthly' : 'billed €' + (bizBaseAnnual * 12).toFixed(2).replace('.', ',') + '/year')
        : 'billed monthly';
      if (ctaEl && bizLive) { ctaEl.textContent = bizCTA; ctaEl.href = 'https://app.beebeeb.io/signup?plan=business'; ctaEl.className = 'bb-cta plan-cta business'; }
    }
  }
  if (bizTbSlider)   bizTbSlider.addEventListener('input', updateBiz);
  if (bizUserSlider) bizUserSlider.addEventListener('input', updateBiz);

  function updateAll() {
    updateBasic();
    updatePro();
    if (bizLive) updateBiz();
  }
</script>

<style>
  .platform-glyph {
    display: inline-flex;
    width: 14px;
    height: 14px;
    align-items: center;
    justify-content: center;
    color: var(--ink-2);
    flex: 0 0 auto;
    line-height: 1;
  }

  .platform-glyph :global(svg) {
    width: 14px;
    height: 14px;
    display: block;
  }

  .bb-platform.coming .platform-glyph {
    color: var(--ink-4);
  }

  .plan-cta {
    width: 100%;
    justify-content: center;
    padding: 12px 14px;
    margin-top: auto;
  }

  .plan-cta.free {
    border-color: var(--line-2);
    background: transparent;
    color: var(--ink);
    box-shadow: none;
  }

  .plan-cta.free:hover {
    border-color: var(--ink-3);
    background: var(--paper-2);
  }

  .plan-cta.basic {
    border-color: var(--amber-deep);
    background: var(--amber);
    color: var(--ink);
  }

  .plan-cta.pro {
    border-color: var(--ink);
    background: var(--ink);
    color: var(--paper);
  }

  .plan-cta.business,
  .plan-cta.business-muted {
    border-color: oklch(0.34 0.012 75);
    background: oklch(0.30 0.010 75);
    color: var(--paper);
    box-shadow: none;
  }

  .plan-cta.business:hover,
  .plan-cta.business-muted:hover {
    background: oklch(0.34 0.012 75);
  }

  @media (max-width: 760px) {
    div[style*='grid-template-columns: repeat(2, 1fr)'] {
      grid-template-columns: 1fr !important;
    }
  }
</style>
