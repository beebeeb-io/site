---
import Base from '../layouts/base.astro';
import { getLaunchPhase } from '../lib/strapi';
import { phaseConfig } from '../lib/phase';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import SecProblem from '../components/sections/SecProblem.astro';
import SecApproach from '../components/sections/SecApproach.astro';
import SecProduct from '../components/sections/SecProduct.astro';
import SecHowItWorks from '../components/sections/SecHowItWorks.astro';
import SecCLI from '../components/sections/SecCLI.astro';
import SecPricingTeaser from '../components/sections/SecPricingTeaser.astro';
import SecFinalCTA from '../components/sections/SecFinalCTA.astro';
import '../styles/landing.css';

const phase = await getLaunchPhase();
const cfg = phaseConfig(phase);
---

<Base
  title="Beebeeb - End-to-end encrypted cloud storage"
  description="Your files are encrypted on your device before they leave it. EU-only infrastructure. Open source clients. Zero knowledge by architecture."
  chrome={false}
>
  <Nav active="home" {cfg} />
  <main id="top">
    <Hero {cfg} />
    <SecProblem />
    <SecApproach />
    <SecProduct {cfg} />
    <SecHowItWorks />
    <SecCLI />
    <SecPricingTeaser {cfg} />
    <SecFinalCTA {cfg} />
  </main>
  <Footer {cfg} />
</Base>
