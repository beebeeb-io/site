---
import Base from '../layouts/base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';
import Chip from '../components/Chip.astro';
---

<Base title="Beebeeb — Storage that can't be read. Not even by us.">
  <Nav />

  <!-- Hero -->
  <section class="relative overflow-hidden px-8 pt-[72px] pb-12 text-center">
    <!-- Honeycomb backdrop gradient -->
    <div class="absolute inset-0 opacity-35" style="background-image: radial-gradient(circle at 2px 2px, oklch(0.85 0.04 85 / 0.5) 1px, transparent 1px); background-size: 24px 24px;"></div>
    <!-- Amber glow -->
    <div class="absolute top-10 left-1/2 -translate-x-1/2 w-[600px] h-[300px] rounded-full blur-[40px]" style="background: radial-gradient(circle, oklch(0.92 0.1 85 / 0.45), transparent 70%);"></div>

    <div class="relative max-w-[880px] mx-auto">
      <!-- Announcement pill -->
      <div class="flex justify-center mb-6">
        <div class="inline-flex items-center gap-2 py-[5px] pl-[5px] pr-3 bg-paper border border-line-2 rounded-full shadow-1">
          <span class="px-2 py-0.5 bg-ink text-amber rounded-full font-mono text-[10px] tracking-[0.06em] uppercase font-semibold">New</span>
          <span class="text-xs text-ink-2">Built for NIS2 &amp; DORA — read our compliance note</span>
          <svg class="w-[11px] h-[11px] text-ink-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </div>
      </div>

      <!-- Headline -->
      <h1 class="text-[64px] leading-[1.02] tracking-[-0.035em] font-bold mb-5">
        Storage that can't be read<br />
        <span class="text-amber-deep">— not even by us.</span>
      </h1>

      <!-- Subtitle -->
      <p class="text-[17px] text-ink-2 max-w-[620px] mx-auto mb-7 leading-relaxed">
        Beebeeb is the European cloud for people who want their files encrypted before they leave their device, stored on EU soil, and governed by EU law — nothing more, nothing less.
      </p>

      <!-- CTAs -->
      <div class="flex gap-2.5 justify-center mb-[18px]">
        <Button variant="amber" size="lg">
          Start free &middot; 10 GB
          <svg class="w-[13px] h-[13px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </Button>
        <Button size="lg">
          <svg class="w-[13px] h-[13px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Download desktop app
        </Button>
      </div>

      <!-- Trust badges -->
      <div class="flex gap-3.5 justify-center text-xs text-ink-3">
        <span class="flex items-center gap-[5px]">
          <svg class="w-[11px] h-[11px] text-[oklch(0.55_0.12_155)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          No card
        </span>
        <span class="flex items-center gap-[5px]">
          <svg class="w-[11px] h-[11px] text-[oklch(0.55_0.12_155)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          Open-source clients
        </span>
        <span class="flex items-center gap-[5px]">
          <svg class="w-[11px] h-[11px] text-[oklch(0.55_0.12_155)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          Audit our code on GitHub
        </span>
      </div>
    </div>

    <!-- Product preview -->
    <div class="relative max-w-[1040px] mx-auto mt-14 rounded-2xl bg-paper border border-line-2 overflow-hidden" style="box-shadow: 0 40px 80px -30px rgba(24,20,10,0.25), 0 10px 30px -10px rgba(24,20,10,0.1);">
      <!-- Window chrome -->
      <div class="flex items-center gap-1.5 px-3.5 py-2.5 bg-paper-2 border-b border-line">
        <span class="w-2.5 h-2.5 rounded-full bg-[#ff5f57]"></span>
        <span class="w-2.5 h-2.5 rounded-full bg-[#febc2e]"></span>
        <span class="w-2.5 h-2.5 rounded-full bg-[#28c840]"></span>
        <span class="ml-3.5 font-mono text-[11px] text-ink-3">beebeeb.io / drive</span>
      </div>
      <!-- File header -->
      <div class="grid grid-cols-[24px_1fr_110px_110px_100px] gap-3.5 px-5 py-2.5 border-b border-line bg-paper">
        <span></span>
        <span class="text-[10.5px] font-semibold tracking-[0.04em] uppercase text-ink-3">Name</span>
        <span class="text-[10.5px] font-semibold tracking-[0.04em] uppercase text-ink-3">Size</span>
        <span class="text-[10.5px] font-semibold tracking-[0.04em] uppercase text-ink-3">Modified</span>
        <span class="text-[10.5px] font-semibold tracking-[0.04em] uppercase text-ink-3">Shared</span>
      </div>
      <!-- File rows -->
      {[
        { type: 'folder', name: 'Contracts', size: '—', modified: '2d ago', shared: 3 },
        { type: 'folder', name: 'Q2 Financials', size: '—', modified: '4h ago', shared: 2 },
        { type: 'file', name: 'board-deck-apr.pdf', size: '4.2 MB', modified: '12m ago', shared: 4, encrypted: true },
        { type: 'file', name: 'term-sheet-v3.docx', size: '88 KB', modified: '1h ago', shared: 2 },
      ].map((row) => (
        <div class="grid grid-cols-[24px_1fr_110px_110px_100px] gap-3.5 items-center px-5 py-[11px] border-b border-line">
          <!-- Icon -->
          {row.type === 'folder' ? (
            <svg class="w-5 h-5 text-amber" viewBox="0 0 24 24" fill="currentColor"><path d="M2 6a2 2 0 0 1 2-2h5l2 2h9a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6Z"/></svg>
          ) : (
            <svg class="w-5 h-5 text-ink-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z"/><polyline points="14 2 14 8 20 8"/></svg>
          )}
          <div class="flex items-center gap-2">
            <span class="text-[13px] font-medium">{row.name}</span>
            {row.encrypted && (
              <span class="inline-flex items-center gap-1 px-1.5 py-0.5 bg-amber-bg border border-amber-deep/30 text-amber-deep rounded font-mono text-[9.5px] font-medium">
                <svg class="w-[9px] h-[9px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                E2EE
              </span>
            )}
          </div>
          <span class="font-mono text-[11px] text-ink-3">{row.size}</span>
          <span class="font-mono text-[11px] text-ink-3">{row.modified}</span>
          <!-- Avatar stack -->
          <div class="flex -space-x-1.5">
            {Array.from({ length: row.shared }).map((_, i) => (
              <div class="w-6 h-6 rounded-full border-2 border-paper" style={`background: oklch(${0.7 + i * 0.05} ${0.1 + i * 0.02} ${60 + i * 30})`}></div>
            ))}
          </div>
        </div>
      ))}

      <!-- Floating encryption pill -->
      <div class="absolute bottom-5 right-6 flex items-center gap-1.5 px-3 py-2 rounded-full bg-ink text-amber font-mono text-[11px]" style="box-shadow: 0 10px 24px -8px rgba(0,0,0,0.3);">
        <span class="w-1.5 h-1.5 rounded-full bg-amber" style="box-shadow: 0 0 8px var(--color-amber);"></span>
        encrypting &middot; AES-256-GCM &middot; 14 MB/s
      </div>
    </div>
  </section>

  <!-- Trust bar -->
  <section class="px-8 py-7 border-t border-b border-line bg-paper-2">
    <div class="flex items-center gap-7 flex-wrap justify-center max-w-[1100px] mx-auto">
      <span class="text-[10.5px] font-semibold tracking-[0.04em] uppercase text-ink-3">Built on EU infrastructure</span>
      <span class="font-mono text-xs text-ink-2 font-medium">Hetzner &middot; Germany</span>
      <span class="font-mono text-xs text-ink-2 font-medium">Leaseweb &middot; Netherlands</span>
      <span class="text-line-2">&middot;</span>
      <div class="flex gap-2.5">
        <Chip>GDPR</Chip>
        <Chip>NIS2</Chip>
        <Chip>DORA</Chip>
        <Chip>ISO 27001 — in progress</Chip>
      </div>
    </div>
  </section>

  <!-- Four pillars -->
  <section class="px-8 py-20 bg-paper">
    <div class="max-w-[1100px] mx-auto">
      <div class="text-[10.5px] font-semibold tracking-[0.04em] uppercase text-ink-3 text-center mb-2.5">Why Beebeeb</div>
      <h2 class="text-[40px] font-bold tracking-[-0.025em] text-center mb-14 leading-tight">Four promises. No fine print.</h2>
      <div class="grid grid-cols-2 gap-[18px]">
        {[
          {
            n: '01',
            icon: 'shield',
            title: 'Zero-knowledge, architecturally.',
            desc: "Files are encrypted on your device with a key we never see. Our servers store opaque blobs — if subpoenaed, we hand over encrypted garbage, and that's the point.",
            stat: 'AES-256-GCM · Argon2id · X25519',
          },
          {
            n: '02',
            icon: 'cloud',
            title: 'European soil, European law.',
            desc: 'Every byte lives in an EU-operated data centre. No CLOUD Act exposure, no US subprocessors, no fine print that moves your data to Oregon overnight.',
            stat: 'Choice of region · DE · NL · FR',
          },
          {
            n: '03',
            icon: 'users',
            title: 'Built for small teams that act big.',
            desc: 'Shared vaults, team keys, client portals, audit logs, SSO. Everything regulated industries need — without the enterprise ceremony or pricing.',
            stat: 'From 5 seats · €9.99 / seat',
          },
          {
            n: '04',
            icon: 'key',
            title: 'Open where it counts.',
            desc: "Every client app — web, iOS, Android, desktop — is open source and reproducibly built. Read the code, compile it yourself, run it offline. We earn trust, we don't ask for it.",
            stat: 'AGPL-3.0 · audited by Cure53',
          },
        ].map((pillar) => (
          <div class="p-7 border border-line rounded-lg bg-paper relative overflow-hidden">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-[10px] bg-amber-bg text-amber-deep border border-[oklch(0.86_0.07_90)] flex items-center justify-center shrink-0">
                {pillar.icon === 'shield' && (
                  <svg class="w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                )}
                {pillar.icon === 'cloud' && (
                  <svg class="w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"/></svg>
                )}
                {pillar.icon === 'users' && (
                  <svg class="w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                )}
                {pillar.icon === 'key' && (
                  <svg class="w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="m21 2-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0 3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg>
                )}
              </div>
              <div class="flex-1">
                <div class="font-mono text-[10.5px] text-ink-4 tracking-[0.08em] mb-1">{pillar.n}</div>
                <h3 class="text-xl font-bold tracking-[-0.02em] mb-2 leading-tight">{pillar.title}</h3>
                <p class="text-[13.5px] text-ink-2 leading-relaxed mb-3.5">{pillar.desc}</p>
                <span class="inline-flex px-2.5 py-1 bg-paper-2 border border-line rounded-md font-mono text-[11px] text-ink-3">{pillar.stat}</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Comparison table -->
  <section class="px-8 py-[72px] bg-paper-2 border-t border-line">
    <div class="max-w-[1000px] mx-auto">
      <div class="text-[10.5px] font-semibold tracking-[0.04em] uppercase text-ink-3 text-center mb-2.5">The honest comparison</div>
      <h2 class="text-[40px] font-bold tracking-[-0.025em] text-center mb-9 leading-tight">How we stack up — without the spin.</h2>

      <div class="border border-line rounded-xl bg-paper overflow-hidden">
        <!-- Header -->
        <div class="grid grid-cols-[2fr_1fr_1fr_1fr_1fr] gap-3.5 px-[22px] py-3.5 bg-paper border-b border-line">
          <span></span>
          <div class="text-center flex flex-col items-center gap-0.5">
            <span class="text-[15px] font-bold tracking-tight">beebeeb<span class="text-amber">.io</span></span>
            <span class="text-xs font-bold">Beebeeb</span>
          </div>
          <div class="text-center text-xs font-medium text-ink-3">Dropbox</div>
          <div class="text-center text-xs font-medium text-ink-3">Proton</div>
          <div class="text-center text-xs font-medium text-ink-3">Tresorit</div>
        </div>

        <!-- Rows -->
        {[
          ['End-to-end encryption by default', 'y', 'n', 'y', 'y'],
          ['Zero-knowledge keys', 'y', 'n', 'y', 'y'],
          ['EU-only infrastructure', 'y', 'opt', 'y', 'opt'],
          ['Not subject to US CLOUD Act', 'y', 'n', 'y', 'n'],
          ['Open-source client apps', 'y', 'n', 'partial', 'n'],
          ['SSO + audit logs on Team tier', 'y', 'addon', 'addon', 'y'],
          ["Honest \"we can't recover your data\" UX", 'y', 'n', 'partial', 'partial'],
        ].map((row, i, arr) => (
          <div class:list={['grid grid-cols-[2fr_1fr_1fr_1fr_1fr] gap-3.5 px-[22px] py-[13px] items-center', i < arr.length - 1 ? 'border-b border-line' : '']}>
            <span class="text-[13px] text-ink-2">{row[0]}</span>
            {[1, 2, 3, 4].map((j) => (
              <div class="text-center">
                {row[j] === 'y' ? (
                  <span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-[oklch(0.94_0.06_155)] text-[oklch(0.35_0.12_155)]">
                    <svg class="w-[11px] h-[11px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                  </span>
                ) : row[j] === 'n' ? (
                  <span class="font-mono text-[11px] text-ink-4">&mdash;</span>
                ) : (
                  <span class="font-mono text-[10.5px] text-ink-3 bg-paper-2 px-1.5 py-0.5 rounded">{row[j]}</span>
                )}
              </div>
            ))}
          </div>
        ))}
      </div>

      <p class="text-[11px] text-ink-4 text-center mt-3.5 italic">
        Comparison as of April 2026 based on public documentation. We keep this table current — including when competitors catch up.
      </p>
    </div>
  </section>

  <!-- Founder quote -->
  <section class="px-8 py-[72px] bg-paper">
    <div class="max-w-[780px] mx-auto text-center">
      <div class="text-[10.5px] font-semibold tracking-[0.04em] uppercase text-ink-3 mb-2.5">A note from the founders</div>
      <blockquote class="text-[22px] leading-relaxed text-ink-2 tracking-[-0.015em] italic mb-7">
        "We're two brothers from Wijchen who spent years building reliable systems at other companies. Every European SMB we know is one CLOUD Act away from an uncomfortable conversation with their customers. We wanted one answer: encrypted on your device, stored in the EU, governed by EU law. That's the whole product."
      </blockquote>
      <div class="flex gap-4 justify-center items-center">
        <div class="flex gap-2.5 items-center">
          <div class="w-9 h-9 rounded-full bg-amber font-bold text-xs flex items-center justify-center">ID</div>
          <div class="text-left">
            <div class="text-[13px] font-semibold">Bram &amp; Guus Langelaar</div>
            <div class="text-[11px] text-ink-3">CEO &amp; CTO &middot; Wijchen, NL</div>
          </div>
        </div>
        <div class="w-px h-6 bg-line-2"></div>
        <span class="font-mono text-[11px] text-ink-3">beebeeb.io</span>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative px-8 py-[72px] bg-ink text-paper overflow-hidden">
    <!-- Honeycomb pattern -->
    <div class="absolute inset-0 opacity-[0.08]" style="background-image: radial-gradient(circle at 50% 50%, oklch(0.82 0.17 84 / 0.5) 1.5px, transparent 1.8px); background-size: 24px 24px;"></div>

    <div class="relative max-w-[780px] mx-auto text-center">
      <h2 class="text-[44px] leading-[1.05] tracking-[-0.03em] font-bold mb-4">
        Start encrypting<br />
        <span class="text-amber">in the next 90 seconds.</span>
      </h2>
      <p class="text-[15px] text-[oklch(0.78_0.01_80)] max-w-[520px] mx-auto mb-7 leading-relaxed">
        10 GB free forever. No card, no upsell email storm, no dark patterns on the way out.
      </p>
      <div class="flex gap-2.5 justify-center">
        <Button variant="amber" size="lg">
          Create your account
          <svg class="w-[13px] h-[13px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </Button>
        <button class="inline-flex items-center gap-2 font-medium cursor-pointer transition-colors duration-150 border text-sm px-5 py-3 rounded-lg bg-transparent text-paper border-[oklch(0.35_0.01_70)] hover:border-[oklch(0.5_0.01_70)]">
          Read the whitepaper
        </button>
      </div>
    </div>
  </section>

  <Footer />
</Base>
