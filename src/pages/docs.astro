---
import Base from '../layouts/base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const categories = [
  {
    title: 'Getting started',
    desc: 'First upload, recovery phrase, adding a device.',
    items: ['Quickstart', 'Installing the desktop app', 'Importing from Dropbox', 'Mobile apps'],
    highlight: false,
  },
  {
    title: 'Sharing & teams',
    desc: 'Links, permissions, team keys.',
    items: ['Public links', 'Share with a person', 'Team workspaces', 'Rotating team keys'],
    highlight: false,
  },
  {
    title: 'Security & crypto',
    desc: 'How zero-knowledge actually works.',
    items: ['Threat model', 'Key derivation (Argon2id)', 'File format', 'Audit reports'],
    highlight: true,
  },
  {
    title: 'Developers',
    desc: 'API, CLI, SDK.',
    items: ['REST API', 'bb CLI', 'JS / Go / Python SDK', 'Webhooks'],
    highlight: false,
  },
  {
    title: 'Admin & compliance',
    desc: 'SSO, audit, DPA.',
    items: ['SAML SSO setup', 'Audit log export', 'GDPR / DPA', 'Data export'],
    highlight: false,
  },
  {
    title: 'Billing',
    desc: 'Plans, invoicing, VAT.',
    items: ['Upgrading & downgrading', 'Invoice delivery', 'VAT & reverse charge', 'Education discount'],
    highlight: false,
  },
];
---

<Base title="Documentation — Beebeeb" description="Everything about using Beebeeb — and how the encryption actually works." path="/docs">
  <Nav />

  <section class="px-8 pt-12 pb-16 bg-paper">
    <div class="max-w-[960px] mx-auto">
      <h1 class="text-[32px] font-semibold tracking-[-0.03em]">Documentation</h1>
      <p class="text-sm text-ink-2 mt-1.5">Everything about using Beebeeb — and how the encryption actually works.</p>

      <!-- Search bar -->
      <div class="mt-6 px-4 py-3 border border-line-2 rounded-[10px] bg-paper-2 flex items-center gap-2.5">
        <svg class="w-[13px] h-[13px] text-ink-3 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <span class="text-[13.5px] text-ink-3 flex-1">Search docs&hellip;</span>
        <span class="font-mono text-[10.5px] px-1.5 py-0.5 bg-paper border border-line-2 rounded text-ink-3">&lcub;K</span>
      </div>

      <!-- Card grid -->
      <div class="mt-8 grid grid-cols-3 gap-4">
        {categories.map((c) => (
          <div class:list={['p-5 rounded-[10px] border', c.highlight ? 'bg-amber-bg border-amber-deep/30' : 'bg-paper border-line-2']}>
            <div class="text-sm font-semibold flex items-center gap-2">
              {c.highlight && (
                <svg class="w-2.5 h-2.5 text-amber-deep" viewBox="0 0 20 20"><polygon points="10,0 12.5,7.5 20,7.5 14,12.5 16,20 10,15 4,20 6,12.5 0,7.5 7.5,7.5" fill="currentColor"/></svg>
              )}
              {c.title}
            </div>
            <p class="text-[12.5px] text-ink-2 mt-1 leading-relaxed">{c.desc}</p>
            <div class="mt-3 flex flex-col gap-[5px]">
              {c.items.map((item) => (
                <a class="text-xs text-ink-2 py-[3px] cursor-default">&rarr; {item}</a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</Base>
