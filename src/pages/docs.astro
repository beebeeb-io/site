---
import Base from '../layouts/base.astro';
import HeroSimple from '../components/blocks/HeroSimple.astro';
import CtaSection from '../components/blocks/CtaSection.astro';
---

<Base
  title="Documentation — Beebeeb"
  description="Everything about using Beebeeb — getting started, API reference, encryption architecture, sharing, CLI commands, and frequently asked questions."
  path="/docs"
>
  <!-- ═══════════════════════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════════════════════ -->
  <HeroSimple
    label="Documentation"
    title="Everything you need to know."
    description="From your first upload to scripting with the CLI. How the encryption works, how sharing works, and how to get the most out of Beebeeb."
  />

  <!-- ═══════════════════════════════════════════════════════════
       CATEGORY GRID
       ═══════════════════════════════════════════════════════════ -->
  <section class="docs-grid-section">
    <div class="docs-grid-container">

      <div class="docs-grid" data-stagger>

        <!-- Getting started -->
        <div class="docs-card bb-fade-up">
          <div class="docs-card-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="16 12 12 8 8 12"/><line x1="12" y1="16" x2="12" y2="8"/></svg>
          </div>
          <div class="docs-card-title">Getting started</div>
          <p class="docs-card-desc">
            First upload, recovery phrase, adding a second device. Everything you need to go from zero to encrypted.
          </p>
          <div class="docs-card-links">
            <a href="https://app.beebeeb.io/signup" class="docs-card-link">
              <span class="docs-card-arrow">&rarr;</span> Web app quickstart
            </a>
            <a href="/docs" class="docs-card-link">
              <span class="docs-card-arrow">&rarr;</span> Installing the CLI
            </a>
            <a href="/docs" class="docs-card-link">
              <span class="docs-card-arrow">&rarr;</span> Mobile apps (iOS + Android)
            </a>
            <a href="/docs" class="docs-card-link">
              <span class="docs-card-arrow">&rarr;</span> Importing from Dropbox
            </a>
          </div>
        </div>

        <!-- API Reference — coming when developer access opens -->
        <div class="docs-card docs-card--dimmed bb-fade-up">
          <div class="docs-card-icon docs-card-icon--muted">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
          </div>
          <div class="docs-card-title-row">
            <div class="docs-card-title">API reference</div>
            <span class="docs-card-badge">Coming soon</span>
          </div>
          <p class="docs-card-desc docs-card-desc--muted">
            REST API documentation will be available when developer access opens.
          </p>
        </div>

        <!-- Encryption (highlighted) -->
        <div class="docs-card docs-card--amber bb-fade-up">
          <div class="docs-card-icon docs-card-icon--amber-invert">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          </div>
          <div class="docs-card-title">Security and encryption</div>
          <p class="docs-card-desc">
            How zero-knowledge actually works. Key derivation, file format, threat model, and the full audit trail.
          </p>
          <div class="docs-card-links">
            <a href="/security" class="docs-card-link">
              <span class="docs-card-arrow">&rarr;</span> Encryption architecture
            </a>
            <a href="/security" class="docs-card-link">
              <span class="docs-card-arrow">&rarr;</span> Key derivation (Argon2id)
            </a>
            <a href="/security" class="docs-card-link">
              <span class="docs-card-arrow">&rarr;</span> Threat model
            </a>
            <a href="/security" class="docs-card-link">
              <span class="docs-card-arrow">&rarr;</span> Audit reports
            </a>
          </div>
        </div>

        <!-- Sharing & teams -->
        <div class="docs-card bb-fade-up">
          <div class="docs-card-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/></svg>
          </div>
          <div class="docs-card-title">Sharing and teams</div>
          <p class="docs-card-desc">
            Share folders with end-to-end encryption intact. Public links, per-person sharing, team workspaces, and key rotation.
          </p>
          <div class="docs-card-links">
            <a href="/security" class="docs-card-link">
              <span class="docs-card-arrow">&rarr;</span> How encrypted sharing works
            </a>
            <a href="/docs" class="docs-card-link">
              <span class="docs-card-arrow">&rarr;</span> Public links
            </a>
            <a href="/docs" class="docs-card-link">
              <span class="docs-card-arrow">&rarr;</span> Team workspaces
            </a>
            <a href="/docs" class="docs-card-link">
              <span class="docs-card-arrow">&rarr;</span> Rotating team keys
            </a>
          </div>
        </div>

        <!-- CLI Reference -->
        <div class="docs-card bb-fade-up">
          <div class="docs-card-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>
          </div>
          <div class="docs-card-title">CLI reference</div>
          <p class="docs-card-desc">
            The <span class="docs-mono">bb</span> command-line tool. Upload, download, sync, and manage your encrypted vault from the terminal. Scriptable. Cron-friendly.
          </p>
          <div class="docs-card-links">
            <a href="https://github.com/beebeeb-io/cli" class="docs-card-link" target="_blank" rel="noopener noreferrer">
              <span class="docs-card-arrow">&rarr;</span> Installation
            </a>
            <a href="https://github.com/beebeeb-io/cli" class="docs-card-link" target="_blank" rel="noopener noreferrer">
              <span class="docs-card-arrow">&rarr;</span> bb login / bb push / bb pull
            </a>
            <a href="https://github.com/beebeeb-io/cli" class="docs-card-link" target="_blank" rel="noopener noreferrer">
              <span class="docs-card-arrow">&rarr;</span> bb sync (background daemon)
            </a>
            <a href="https://github.com/beebeeb-io/cli" class="docs-card-link" target="_blank" rel="noopener noreferrer">
              <span class="docs-card-arrow">&rarr;</span> Environment variables
            </a>
          </div>
        </div>

        <!-- FAQ -->
        <div class="docs-card bb-fade-up">
          <div class="docs-card-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
          </div>
          <div class="docs-card-title">FAQ</div>
          <p class="docs-card-desc">
            Common questions about accounts, storage limits, data recovery, platform availability, and how Beebeeb compares.
          </p>
          <div class="docs-card-links">
            <a href="/docs#faq" class="docs-card-link">
              <span class="docs-card-arrow">&rarr;</span> Can you recover my files?
            </a>
            <a href="/docs#faq" class="docs-card-link">
              <span class="docs-card-arrow">&rarr;</span> What happens if I lose my password?
            </a>
            <a href="/docs#faq" class="docs-card-link">
              <span class="docs-card-arrow">&rarr;</span> Is there a file size limit?
            </a>
            <a href="/docs#faq" class="docs-card-link">
              <span class="docs-card-arrow">&rarr;</span> How does Beebeeb compare to Filen?
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       FAQ SECTION
       ═══════════════════════════════════════════════════════════ -->
  <section id="faq" class="docs-faq-section">
    <div class="docs-faq-container">
      <div class="section-label bb-fade-up">Frequently asked questions</div>
      <h2 class="docs-faq-heading bb-fade-up bb-delay-1">
        Common questions, honest answers.
      </h2>

      <div class="bb-fade-up bb-delay-2">
        <div class="faq-item">
          <button class="faq-question">
            Can you recover my files if I lose my password?
            <span class="faq-icon"></span>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">
              No. Your password derives your master key, and we never have access to either. If you lose your password and your recovery phrase, your data is gone. This is the trade-off of zero-knowledge encryption: the security guarantee requires that no one -- including us -- can bypass it. Write down your recovery phrase and store it somewhere safe.
            </div>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question">
            What happens to my files if Beebeeb shuts down?
            <span class="faq-icon"></span>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">
              All client code is open source. You can export your encrypted vault at any time using the CLI (<span class="docs-mono">bb export</span>) or the web app. The export includes your encrypted data and the metadata needed to decrypt it locally. Your data is yours, and it stays yours regardless of what happens to us.
            </div>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question">
            Is there a file size limit?
            <span class="faq-icon"></span>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">
              No hard limit per file. Files are chunked and encrypted individually, so even large files (videos, disk images, archives) are handled efficiently. Your total storage is determined by your plan -- 5 GB free, up to 10 TB on the Business plan.
            </div>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question">
            Which platforms are supported?
            <span class="faq-icon"></span>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">
              Web (any modern browser), macOS, Windows, Linux, iOS, and Android. The web app uses WebAssembly for client-side encryption. Desktop and mobile apps use native Rust bindings. The CLI runs anywhere Rust compiles.
            </div>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question">
            How does Beebeeb compare to Filen, Proton Drive, or Tresorit?
            <span class="faq-icon"></span>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">
              All four offer end-to-end encryption. The differences are in jurisdiction, transparency, and architecture. Beebeeb is EU-only (Dutch company, German and Dutch servers), fully open-source on the client side, and uses OPAQUE for authentication so your password never leaves your device in any form. We also publish our infrastructure providers by name and operate without US cloud dependencies.
            </div>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question">
            Can I use Beebeeb for my business or team?
            <span class="faq-icon"></span>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">
              Yes. Team workspaces support shared folders with per-user key wrapping. Each team member has their own identity key pair, and folder keys are wrapped for each member individually using X25519 key exchange. Admins can manage members and rotate keys without re-encrypting stored data.
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       OPEN SOURCE CALLOUT
       ═══════════════════════════════════════════════════════════ -->
  <section class="docs-oss-section">
    <div class="docs-oss-container">
      <div class="docs-oss-card bb-fade-up">
        <div class="docs-card-icon docs-card-icon--shrink">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="m21 2-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0 3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg>
        </div>
        <div>
          <div class="docs-oss-title">All client code is open source.</div>
          <p class="docs-oss-desc">
            The crypto engine, web app, CLI, mobile apps, and desktop sync -- every line of code that touches your data is public. Read it, audit it, or build your own client.
          </p>
          <a href="https://github.com/beebeeb-io" class="btn btn-outline btn-sm" target="_blank" rel="noopener noreferrer">
            View repositories on GitHub
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       CTA
       ═══════════════════════════════════════════════════════════ -->
  <CtaSection
    title="Ready to get started?"
    title_highlight="5 GB free. No credit card."
    description="Create an account in 30 seconds. Your files are encrypted before they leave your device."
    cta_primary_label="Get started free"
    cta_primary_href="https://app.beebeeb.io/signup"
    cta_secondary_label="How the encryption works"
    cta_secondary_href="/security"
    dark_bg={true}
  />
</Base>

<style>
  /* ── Category grid section ──────────────────────────────── */
  .docs-grid-section {
    padding: 72px 32px;
    background: var(--paper);
  }

  .docs-grid-container {
    max-width: 1000px;
    margin: 0 auto;
  }

  .docs-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  /* ── Card base ──────────────────────────────────────────── */
  .docs-card {
    padding: 24px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--paper);
    transition: border-color 200ms var(--ease), transform 200ms var(--ease), box-shadow 200ms var(--ease);
  }

  .docs-card:hover {
    border-color: var(--line-2);
    transform: translateY(-2px);
    box-shadow: var(--shadow-1);
  }

  .docs-card--dimmed {
    opacity: 0.6;
  }

  .docs-card--amber {
    background: var(--amber-soft);
    border-color: oklch(0.86 0.07 90);
  }

  .docs-card--amber:hover {
    border-color: var(--amber-deep);
  }

  /* ── Card icon ──────────────────────────────────────────── */
  .docs-card-icon {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: var(--amber-soft);
    color: var(--amber-deep);
    border: 1px solid oklch(0.86 0.07 90);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 16px;
  }

  .docs-card-icon--muted {
    background: var(--paper-2);
    color: var(--ink-3);
    border-color: var(--line);
  }

  .docs-card-icon--amber-invert {
    background: var(--paper);
    color: var(--amber-deep);
    border-color: oklch(0.86 0.07 90);
  }

  .docs-card-icon--shrink {
    flex-shrink: 0;
  }

  /* ── Card title ─────────────────────────────────────────── */
  .docs-card-title {
    font-size: 15px;
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-bottom: 6px;
  }

  .docs-card-title-row {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 6px;
  }

  .docs-card-title-row .docs-card-title {
    margin-bottom: 0;
  }

  .docs-card-badge {
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 2px 6px;
    border-radius: 4px;
    background: var(--paper-3);
    color: var(--ink-3);
    border: 1px solid var(--line);
  }

  /* ── Card description ───────────────────────────────────── */
  .docs-card-desc {
    font-size: 12.5px;
    color: var(--ink-2);
    line-height: 1.6;
    margin: 0 0 16px;
  }

  .docs-card-desc--muted {
    color: var(--ink-3);
    margin-bottom: 0;
  }

  /* ── Card links ─────────────────────────────────────────── */
  .docs-card-links {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .docs-card-link {
    font-size: 12.5px;
    color: var(--ink-2);
    text-decoration: none;
    transition: color 150ms var(--ease);
  }

  .docs-card-link:hover {
    color: var(--amber-deep);
  }

  .docs-card-arrow {
    color: var(--ink-3);
    margin-right: 6px;
  }

  .docs-mono {
    font-family: var(--font-mono);
    font-size: 11px;
  }

  /* ── FAQ section ────────────────────────────────────────── */
  .docs-faq-section {
    padding: 72px 32px;
    background: var(--paper-2);
    border-top: 1px solid var(--line);
  }

  .docs-faq-container {
    max-width: 780px;
    margin: 0 auto;
  }

  .docs-faq-heading {
    font-size: 32px;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0 0 32px;
  }

  /* ── FAQ items (accordion) ──────────────────────────────── */
  .faq-item {
    border-bottom: 1px solid var(--line);
  }

  .faq-item:first-child {
    border-top: 1px solid var(--line);
  }

  .faq-question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 18px 0;
    border: none;
    background: transparent;
    color: var(--ink);
    font-family: var(--font-sans);
    font-size: 15px;
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.4;
    text-align: left;
    cursor: pointer;
    transition: color 150ms var(--ease);
  }

  .faq-question:hover {
    color: var(--amber-deep);
  }

  .faq-icon {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    position: relative;
    margin-left: 16px;
  }

  .faq-icon::before,
  .faq-icon::after {
    content: '';
    position: absolute;
    background: var(--ink-3);
    border-radius: 1px;
    transition: transform 200ms var(--ease);
  }

  .faq-icon::before {
    top: 50%;
    left: 3px;
    right: 3px;
    height: 1.5px;
    transform: translateY(-50%);
  }

  .faq-icon::after {
    left: 50%;
    top: 3px;
    bottom: 3px;
    width: 1.5px;
    transform: translateX(-50%);
  }

  .faq-item.open .faq-icon::after {
    transform: translateX(-50%) rotate(90deg);
    opacity: 0;
  }

  .faq-answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height 300ms var(--ease);
  }

  .faq-item.open .faq-answer {
    max-height: 400px;
  }

  .faq-answer-inner {
    padding: 0 0 20px;
    font-size: 14px;
    line-height: 1.65;
    color: var(--ink-2);
  }

  /* ── Open source callout ────────────────────────────────── */
  .docs-oss-section {
    padding: 72px 32px;
    background: var(--paper);
    border-top: 1px solid var(--line);
  }

  .docs-oss-container {
    max-width: 900px;
    margin: 0 auto;
  }

  .docs-oss-card {
    border: 1px dashed var(--line-2);
    border-radius: 8px;
    background: var(--paper-2);
    padding: 24px;
    display: flex;
    align-items: flex-start;
    gap: 16px;
  }

  .docs-oss-title {
    font-size: 15px;
    font-weight: 700;
    margin-bottom: 4px;
  }

  .docs-oss-desc {
    font-size: 13px;
    color: var(--ink-2);
    line-height: 1.6;
    margin: 0 0 12px;
  }

  /* ── Responsive ─────────────────────────────────────────── */
  @media (max-width: 760px) {
    .docs-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .docs-faq-heading {
      font-size: 26px;
    }
  }

  @media (max-width: 560px) {
    .docs-grid-section,
    .docs-faq-section,
    .docs-oss-section {
      padding: 48px 20px;
    }

    .docs-grid {
      grid-template-columns: 1fr;
    }

    .docs-oss-card {
      flex-direction: column;
    }

    .docs-faq-heading {
      font-size: 24px;
    }
  }
</style>
