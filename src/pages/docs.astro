---
import Base from '../layouts/base.astro';
import HeroSimple from '../components/blocks/HeroSimple.astro';
import CtaSection from '../components/blocks/CtaSection.astro';
---

<Base
  title="Documentation — Beebeeb"
  description="Everything about using Beebeeb — getting started, API reference, encryption architecture, sharing, CLI commands, and frequently asked questions."
  path="/docs"
>
  <!-- ═══════════════════════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════════════════════ -->
  <HeroSimple
    label="Documentation"
    title="Everything you need to know."
    description="From your first upload to scripting with the CLI. How the encryption works, how sharing works, and how to get the most out of Beebeeb."
  />

  <!-- ═══════════════════════════════════════════════════════════
       CATEGORY GRID
       ═══════════════════════════════════════════════════════════ -->
  <section class="px-8 py-[72px] bg-paper">
    <div class="max-w-[1000px] mx-auto">

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4" data-stagger>

        <!-- Getting started -->
        <div class="p-6 border border-line rounded-lg bg-paper bb-fade-up bb-lift">
          <div class="w-10 h-10 rounded-[10px] bg-amber-bg text-amber-deep border border-[oklch(0.86_0.07_90)] flex items-center justify-center mb-4">
            <svg class="w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="16 12 12 8 8 12"/><line x1="12" y1="16" x2="12" y2="8"/></svg>
          </div>
          <div class="text-[15px] font-bold tracking-tight mb-1.5">Getting started</div>
          <p class="text-[12.5px] text-ink-2 leading-relaxed mb-4">
            First upload, recovery phrase, adding a second device. Everything you need to go from zero to encrypted.
          </p>
          <div class="flex flex-col gap-2">
            <a href="https://app.beebeeb.io/signup" class="text-[12.5px] text-ink-2 hover:text-amber-deep transition-colors">
              <span class="text-ink-3 mr-1.5">&rarr;</span> Web app quickstart
            </a>
            <a href="/docs" class="text-[12.5px] text-ink-2 hover:text-amber-deep transition-colors">
              <span class="text-ink-3 mr-1.5">&rarr;</span> Installing the CLI
            </a>
            <a href="/docs" class="text-[12.5px] text-ink-2 hover:text-amber-deep transition-colors">
              <span class="text-ink-3 mr-1.5">&rarr;</span> Mobile apps (iOS + Android)
            </a>
            <a href="/docs" class="text-[12.5px] text-ink-2 hover:text-amber-deep transition-colors">
              <span class="text-ink-3 mr-1.5">&rarr;</span> Importing from Dropbox
            </a>
          </div>
        </div>

        <!-- API Reference -->
        <div class="p-6 border border-line rounded-lg bg-paper bb-fade-up bb-lift">
          <div class="w-10 h-10 rounded-[10px] bg-amber-bg text-amber-deep border border-[oklch(0.86_0.07_90)] flex items-center justify-center mb-4">
            <svg class="w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
          </div>
          <div class="text-[15px] font-bold tracking-tight mb-1.5">API reference</div>
          <p class="text-[12.5px] text-ink-2 leading-relaxed mb-4">
            REST API for file operations, user management, sharing, and account administration. All endpoints require authentication.
          </p>
          <div class="flex flex-col gap-2">
            <a href="/api" class="text-[12.5px] text-ink-2 hover:text-amber-deep transition-colors">
              <span class="text-ink-3 mr-1.5">&rarr;</span> Full API documentation
            </a>
            <a href="/api" class="text-[12.5px] text-ink-2 hover:text-amber-deep transition-colors">
              <span class="text-ink-3 mr-1.5">&rarr;</span> Authentication (OPAQUE)
            </a>
            <a href="/api" class="text-[12.5px] text-ink-2 hover:text-amber-deep transition-colors">
              <span class="text-ink-3 mr-1.5">&rarr;</span> File upload + download
            </a>
            <a href="/api" class="text-[12.5px] text-ink-2 hover:text-amber-deep transition-colors">
              <span class="text-ink-3 mr-1.5">&rarr;</span> Webhooks
            </a>
          </div>
        </div>

        <!-- Encryption (highlighted) -->
        <div class="p-6 border border-[oklch(0.86_0.07_90)] rounded-lg bg-amber-bg bb-fade-up bb-lift">
          <div class="w-10 h-10 rounded-[10px] bg-paper text-amber-deep border border-[oklch(0.86_0.07_90)] flex items-center justify-center mb-4">
            <svg class="w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          </div>
          <div class="text-[15px] font-bold tracking-tight mb-1.5">Security and encryption</div>
          <p class="text-[12.5px] text-ink-2 leading-relaxed mb-4">
            How zero-knowledge actually works. Key derivation, file format, threat model, and the full audit trail.
          </p>
          <div class="flex flex-col gap-2">
            <a href="/security" class="text-[12.5px] text-ink-2 hover:text-amber-deep transition-colors">
              <span class="text-ink-3 mr-1.5">&rarr;</span> Encryption architecture
            </a>
            <a href="/security" class="text-[12.5px] text-ink-2 hover:text-amber-deep transition-colors">
              <span class="text-ink-3 mr-1.5">&rarr;</span> Key derivation (Argon2id)
            </a>
            <a href="/security" class="text-[12.5px] text-ink-2 hover:text-amber-deep transition-colors">
              <span class="text-ink-3 mr-1.5">&rarr;</span> Threat model
            </a>
            <a href="/security" class="text-[12.5px] text-ink-2 hover:text-amber-deep transition-colors">
              <span class="text-ink-3 mr-1.5">&rarr;</span> Audit reports
            </a>
          </div>
        </div>

        <!-- Sharing & teams -->
        <div class="p-6 border border-line rounded-lg bg-paper bb-fade-up bb-lift">
          <div class="w-10 h-10 rounded-[10px] bg-amber-bg text-amber-deep border border-[oklch(0.86_0.07_90)] flex items-center justify-center mb-4">
            <svg class="w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/></svg>
          </div>
          <div class="text-[15px] font-bold tracking-tight mb-1.5">Sharing and teams</div>
          <p class="text-[12.5px] text-ink-2 leading-relaxed mb-4">
            Share folders with end-to-end encryption intact. Public links, per-person sharing, team workspaces, and key rotation.
          </p>
          <div class="flex flex-col gap-2">
            <a href="/security" class="text-[12.5px] text-ink-2 hover:text-amber-deep transition-colors">
              <span class="text-ink-3 mr-1.5">&rarr;</span> How encrypted sharing works
            </a>
            <a href="/docs" class="text-[12.5px] text-ink-2 hover:text-amber-deep transition-colors">
              <span class="text-ink-3 mr-1.5">&rarr;</span> Public links
            </a>
            <a href="/docs" class="text-[12.5px] text-ink-2 hover:text-amber-deep transition-colors">
              <span class="text-ink-3 mr-1.5">&rarr;</span> Team workspaces
            </a>
            <a href="/docs" class="text-[12.5px] text-ink-2 hover:text-amber-deep transition-colors">
              <span class="text-ink-3 mr-1.5">&rarr;</span> Rotating team keys
            </a>
          </div>
        </div>

        <!-- CLI Reference -->
        <div class="p-6 border border-line rounded-lg bg-paper bb-fade-up bb-lift">
          <div class="w-10 h-10 rounded-[10px] bg-amber-bg text-amber-deep border border-[oklch(0.86_0.07_90)] flex items-center justify-center mb-4">
            <svg class="w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>
          </div>
          <div class="text-[15px] font-bold tracking-tight mb-1.5">CLI reference</div>
          <p class="text-[12.5px] text-ink-2 leading-relaxed mb-4">
            The <span class="font-mono text-[11px]">bb</span> command-line tool. Upload, download, sync, and manage your encrypted vault from the terminal. Scriptable. Cron-friendly.
          </p>
          <div class="flex flex-col gap-2">
            <a href="https://github.com/beebeeb-io/cli" class="text-[12.5px] text-ink-2 hover:text-amber-deep transition-colors" target="_blank" rel="noopener noreferrer">
              <span class="text-ink-3 mr-1.5">&rarr;</span> Installation
            </a>
            <a href="https://github.com/beebeeb-io/cli" class="text-[12.5px] text-ink-2 hover:text-amber-deep transition-colors" target="_blank" rel="noopener noreferrer">
              <span class="text-ink-3 mr-1.5">&rarr;</span> bb login / bb push / bb pull
            </a>
            <a href="https://github.com/beebeeb-io/cli" class="text-[12.5px] text-ink-2 hover:text-amber-deep transition-colors" target="_blank" rel="noopener noreferrer">
              <span class="text-ink-3 mr-1.5">&rarr;</span> bb sync (background daemon)
            </a>
            <a href="https://github.com/beebeeb-io/cli" class="text-[12.5px] text-ink-2 hover:text-amber-deep transition-colors" target="_blank" rel="noopener noreferrer">
              <span class="text-ink-3 mr-1.5">&rarr;</span> Environment variables
            </a>
          </div>
        </div>

        <!-- FAQ -->
        <div class="p-6 border border-line rounded-lg bg-paper bb-fade-up bb-lift">
          <div class="w-10 h-10 rounded-[10px] bg-amber-bg text-amber-deep border border-[oklch(0.86_0.07_90)] flex items-center justify-center mb-4">
            <svg class="w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
          </div>
          <div class="text-[15px] font-bold tracking-tight mb-1.5">FAQ</div>
          <p class="text-[12.5px] text-ink-2 leading-relaxed mb-4">
            Common questions about accounts, storage limits, data recovery, platform availability, and how Beebeeb compares.
          </p>
          <div class="flex flex-col gap-2">
            <a href="/docs#faq" class="text-[12.5px] text-ink-2 hover:text-amber-deep transition-colors">
              <span class="text-ink-3 mr-1.5">&rarr;</span> Can you recover my files?
            </a>
            <a href="/docs#faq" class="text-[12.5px] text-ink-2 hover:text-amber-deep transition-colors">
              <span class="text-ink-3 mr-1.5">&rarr;</span> What happens if I lose my password?
            </a>
            <a href="/docs#faq" class="text-[12.5px] text-ink-2 hover:text-amber-deep transition-colors">
              <span class="text-ink-3 mr-1.5">&rarr;</span> Is there a file size limit?
            </a>
            <a href="/docs#faq" class="text-[12.5px] text-ink-2 hover:text-amber-deep transition-colors">
              <span class="text-ink-3 mr-1.5">&rarr;</span> How does Beebeeb compare to Filen?
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       FAQ SECTION
       ═══════════════════════════════════════════════════════════ -->
  <section id="faq" class="px-8 py-[72px] bg-paper-2 border-t border-line">
    <div class="max-w-[780px] mx-auto">
      <div class="section-label bb-fade-up">Frequently asked questions</div>
      <h2 class="text-[32px] font-bold tracking-[-0.02em] mb-8 bb-fade-up bb-delay-1">
        Common questions, honest answers.
      </h2>

      <div class="bb-fade-up bb-delay-2">
        <div class="faq-item">
          <button class="faq-question">
            Can you recover my files if I lose my password?
            <span class="faq-icon"></span>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">
              No. Your password derives your master key, and we never have access to either. If you lose your password and your recovery phrase, your data is gone. This is the trade-off of zero-knowledge encryption: the security guarantee requires that no one -- including us -- can bypass it. Write down your recovery phrase and store it somewhere safe.
            </div>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question">
            What happens to my files if Beebeeb shuts down?
            <span class="faq-icon"></span>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">
              All client code is open source. You can export your encrypted vault at any time using the CLI (<span class="font-mono text-[13px]">bb export</span>) or the web app. The export includes your encrypted data and the metadata needed to decrypt it locally. Your data is yours, and it stays yours regardless of what happens to us.
            </div>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question">
            Is there a file size limit?
            <span class="faq-icon"></span>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">
              No hard limit per file. Files are chunked and encrypted individually, so even large files (videos, disk images, archives) are handled efficiently. Your total storage is determined by your plan -- 5 GB free, up to 10 TB on the Business plan.
            </div>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question">
            Which platforms are supported?
            <span class="faq-icon"></span>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">
              Web (any modern browser), macOS, Windows, Linux, iOS, and Android. The web app uses WebAssembly for client-side encryption. Desktop and mobile apps use native Rust bindings. The CLI runs anywhere Rust compiles.
            </div>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question">
            How does Beebeeb compare to Filen, Proton Drive, or Tresorit?
            <span class="faq-icon"></span>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">
              All four offer end-to-end encryption. The differences are in jurisdiction, transparency, and architecture. Beebeeb is EU-only (Dutch company, German and Dutch servers), fully open-source on the client side, and uses OPAQUE for authentication so your password never leaves your device in any form. We also publish our infrastructure providers by name and operate without US cloud dependencies.
            </div>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question">
            Can I use Beebeeb for my business or team?
            <span class="faq-icon"></span>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">
              Yes. Team workspaces support shared folders with per-user key wrapping. Each team member has their own identity key pair, and folder keys are wrapped for each member individually using X25519 key exchange. Admins can manage members and rotate keys without re-encrypting stored data.
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       OPEN SOURCE CALLOUT
       ═══════════════════════════════════════════════════════════ -->
  <section class="px-8 py-[72px] bg-paper border-t border-line">
    <div class="max-w-[900px] mx-auto">
      <div class="border border-dashed border-line-2 rounded-lg bg-paper-2 p-6 flex items-start gap-4 bb-fade-up">
        <div class="w-10 h-10 rounded-[10px] bg-amber-bg text-amber-deep border border-[oklch(0.86_0.07_90)] flex items-center justify-center shrink-0">
          <svg class="w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="m21 2-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0 3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg>
        </div>
        <div>
          <div class="text-[15px] font-bold mb-1">All client code is open source.</div>
          <p class="text-[13px] text-ink-2 leading-relaxed mb-3">
            The crypto engine, web app, CLI, mobile apps, and desktop sync -- every line of code that touches your data is public. Read it, audit it, or build your own client.
          </p>
          <a href="https://github.com/beebeeb-io" class="btn btn-outline btn-sm" target="_blank" rel="noopener noreferrer">
            View repositories on GitHub
            <svg class="w-[12px] h-[12px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       CTA
       ═══════════════════════════════════════════════════════════ -->
  <CtaSection
    title="Ready to get started?"
    title_highlight="5 GB free. No credit card."
    description="Create an account in 30 seconds. Your files are encrypted before they leave your device."
    cta_primary_label="Get started free"
    cta_primary_href="https://app.beebeeb.io/signup"
    cta_secondary_label="How the encryption works"
    cta_secondary_href="/security"
    dark_bg={true}
  />
</Base>
