---
import Base from '../layouts/base.astro';
import CtaSection from '../components/blocks/CtaSection.astro';

// Platform download links
// Placeholders marked with '#' will be updated when builds are published.
const platforms = [
  {
    id: 'web',
    name: 'Web',
    subtitle: 'No install needed',
    description: 'Open your vault in any modern browser. Nothing to install — works on Chrome, Firefox, Safari, and Edge.',
    href: 'https://app.beebeeb.io',
    cta: 'Open web app',
    primary: true,
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="28" height="28"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>`,
  },
  {
    id: 'ios',
    name: 'iOS',
    subtitle: 'iPhone and iPad',
    description: 'Auto-photo backup, Files.app integration, Face ID vault lock, and offline access. Requires iOS 16 or later.',
    href: '#',
    cta: 'App Store — coming soon',
    primary: false,
    icon: `<svg viewBox="0 0 24 24" fill="currentColor" width="28" height="28"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>`,
  },
  {
    id: 'android',
    name: 'Android',
    subtitle: 'Phone and tablet',
    description: 'Encrypted photo backup in the background, share-sheet integration, and biometric unlock. Requires Android 10 or later.',
    href: '#',
    cta: 'Google Play — coming soon',
    primary: false,
    icon: `<svg viewBox="0 0 24 24" fill="currentColor" width="28" height="28"><path d="M6 18c0 .55.45 1 1 1h1v3.5c0 .83.67 1.5 1.5 1.5s1.5-.67 1.5-1.5V19h2v3.5c0 .83.67 1.5 1.5 1.5s1.5-.67 1.5-1.5V19h1c.55 0 1-.45 1-1V8H6v10zM3.5 8C2.67 8 2 8.67 2 9.5v7c0 .83.67 1.5 1.5 1.5S5 17.33 5 16.5v-7C5 8.67 4.33 8 3.5 8zm17 0c-.83 0-1.5.67-1.5 1.5v7c0 .83.67 1.5 1.5 1.5s1.5-.67 1.5-1.5v-7c0-.83-.67-1.5-1.5-1.5zm-4.97-5.84l1.3-1.3c.2-.2.2-.51 0-.71-.2-.2-.51-.2-.71 0l-1.48 1.48A5.84 5.84 0 0 0 12 1.5c-.96 0-1.86.23-2.66.63L7.85.65c-.2-.2-.51-.2-.71 0-.2.2-.2.51 0 .71l1.31 1.31A5.983 5.983 0 0 0 6 7h12c0-1.99-.97-3.75-2.47-4.84zM10 5H9V4h1v1zm5 0h-1V4h1v1z"/></svg>`,
  },
  {
    id: 'macos',
    name: 'macOS',
    subtitle: 'Native desktop app',
    description: 'Finder integration, menubar quick-upload, selective sync, and background file watching. macOS 12 Monterey or later.',
    href: 'https://github.com/beebeeb-io/desktop/releases/latest',
    cta: 'Download for macOS',
    primary: false,
    icon: `<svg viewBox="0 0 24 24" fill="currentColor" width="28" height="28"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>`,
  },
  {
    id: 'windows',
    name: 'Windows',
    subtitle: 'Sync client',
    description: 'Explorer integration, system-tray sync status, and selective folder sync. Windows 10 (64-bit) or later.',
    href: 'https://github.com/beebeeb-io/desktop/releases/latest',
    cta: 'Download for Windows',
    primary: false,
    icon: `<svg viewBox="0 0 24 24" fill="currentColor" width="28" height="28"><path d="M0 3.449L9.75 2.1v9.451H0m10.949-9.602L24 0v11.4H10.949M0 12.6h9.75v9.451L0 20.699M10.949 12.6H24V24l-12.9-1.801"/></svg>`,
  },
  {
    id: 'linux',
    name: 'Linux',
    subtitle: 'AppImage — any distro',
    description: 'Single portable binary, no root required, runs on any distribution. x86_64 and arm64 builds available.',
    href: 'https://github.com/beebeeb-io/desktop/releases/latest',
    cta: 'Download AppImage',
    primary: false,
    icon: `<svg viewBox="0 0 24 24" fill="currentColor" width="28" height="28"><path d="M12.504 0c-.155 0-.315.008-.48.021-4.226.333-3.105 4.807-3.17 6.298-.076 1.092-.3 1.953-1.05 3.02-.885 1.051-2.127 2.75-2.716 4.521-.278.832-.41 1.684-.287 2.489a.424.424 0 00-.11.135c-.26.268-.45.6-.663.839-.199.199-.485.267-.797.4-.313.136-.658.269-.864.68-.09.189-.136.39-.132.602 0 .199.027.4.055.536.058.399.116.728.04.97-.249.68-.28 1.145-.106 1.484.174.334.535.47.94.601.81.2 1.91.135 2.774.6.926.466 1.866.67 2.616.47.526-.116.97-.4 1.294-.87.124.096.246.196.383.288.372.235.744.402 1.132.503.45.126.821.19 1.109.14l.064-.016c.325-.078.64-.218.953-.352.76-.322 1.509-.688 1.541-1.35.013-.45-.162-.944-.436-1.554-.055-.114-.12-.238-.19-.368.37-.04.733-.116 1.09-.284.303-.14.581-.327.842-.587.284-.281.479-.622.589-.982.113-.378.12-.793.012-1.159-.203-.73-.663-1.21-1.252-1.558a5.272 5.272 0 00-1.458-.49l-.116-.023c.053-.177.087-.361.087-.554 0-.65-.348-1.23-.872-1.574l-.014-.009a3.226 3.226 0 00-.67-.295l-.01-.003a2.9 2.9 0 00-.8-.119c-.162 0-.322.013-.48.038l-.01.001-.021.005c-.15.027-.3.069-.444.128l-.008.003a2.498 2.498 0 00-.437.246l-.013.009a2.45 2.45 0 00-.364.329l-.007.008a2.44 2.44 0 00-.283.438l-.004.008a2.353 2.353 0 00-.166.559l-.001.009a2.403 2.403 0 00-.007.47l.001.007c.012.16.036.317.075.47l.004.017a2.62 2.62 0 00.16.44l.008.017c.072.147.16.285.259.412l.011.013-.025.016a3.71 3.71 0 00-.49.381l-.011.01c-.145.138-.28.29-.401.454l-.009.013a3.65 3.65 0 00-.302.54l-.006.014a3.595 3.595 0 00-.177.613l-.003.013a3.616 3.616 0 00-.04.649l.001.01c.01.215.038.428.083.636l.004.017c.046.2.11.393.19.577l.006.015c.083.185.183.358.296.518l.009.013c.115.16.244.305.385.436l.011.01c.143.13.298.244.463.34l.012.007c.166.096.342.175.524.235l.013.004c.183.061.37.102.56.121h.012c.19.02.38.02.57.002l.013-.002c.19-.02.376-.06.556-.117l.013-.004c.18-.058.353-.133.517-.226l.013-.007c.164-.093.318-.2.46-.322l.012-.01c.14-.122.267-.257.38-.402l.01-.013c.112-.146.21-.303.29-.468l.007-.015c.078-.166.14-.34.184-.518l.004-.017c.043-.18.067-.362.073-.547l.001-.01a3.64 3.64 0 00-.043-.648l-.003-.013a3.617 3.617 0 00-.18-.606l-.006-.015a3.638 3.638 0 00-.304-.533l-.009-.013a3.668 3.668 0 00-.403-.448l-.011-.01a3.72 3.72 0 00-.492-.374l-.025-.016.011-.013c.1-.127.186-.265.257-.411l.008-.017c.072-.152.13-.312.17-.476l.004-.017c.04-.163.063-.33.075-.5l.001-.007c.01-.16.007-.318-.007-.476l-.001-.009a2.42 2.42 0 00-.167-.558l-.004-.008a2.44 2.44 0 00-.282-.437l-.007-.008a2.455 2.455 0 00-.362-.328l-.013-.009a2.5 2.5 0 00-.435-.247l-.008-.003a2.514 2.514 0 00-.443-.128l-.021-.005-.01-.001a2.905 2.905 0 00-.48-.039z"/></svg>`,
  },
  {
    id: 'cli',
    name: 'CLI',
    subtitle: 'Command-line interface',
    description: 'Full access to your vault from the terminal. Scriptable, pipeable, and WebDAV-mountable. One binary, no runtime.',
    href: 'https://docs.beebeeb.io/cli/install',
    cta: 'CLI docs',
    primary: false,
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="28" height="28"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>`,
  },
];
---

<Base
  title="Download — Beebeeb"
  description="Get Beebeeb on every device. Web, iOS, Android, macOS, Windows, Linux, and CLI. One account, all platforms, end-to-end encrypted."
  path="/download"
>

  <!-- Hero -->
  <section class="dl-hero" style="background: linear-gradient(180deg, var(--amber-soft) 0%, var(--paper) 85%);">
    <div class="section-label bb-fade-up">All platforms</div>
    <h1 class="dl-hero-title bb-fade-up bb-delay-1">
      Get Beebeeb on <span class="dl-hero-accent">every device.</span>
    </h1>
    <p class="dl-hero-desc bb-fade-up bb-delay-2">
      One account. All platforms. Your encrypted files, always available — web, mobile, desktop, and terminal.
    </p>
  </section>

  <!-- Platform cards -->
  <section class="dl-cards-section">
    <div class="dl-cards-container">
      <div class="dl-cards-grid" data-stagger>
        {platforms.map((p) => (
          <div class="dl-card bb-fade-up">
            <div class="dl-card-icon" set:html={p.icon} />
            <div class="dl-card-body">
              <div class="dl-card-title-row">
                <h2 class="dl-card-name">{p.name}</h2>
                <span class="dl-card-subtitle">{p.subtitle}</span>
              </div>
              <p class="dl-card-desc">{p.description}</p>
            </div>
            <a
              href={p.href}
              class:list={[
                'dl-card-cta',
                p.primary && 'dl-card-cta--primary',
                p.href === '#' && 'dl-card-cta--disabled',
                !p.primary && p.href !== '#' && 'dl-card-cta--secondary',
              ]}
              {...(p.href !== '#' && !p.href.startsWith('https://app') ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
            >
              {p.href !== '#' && p.href !== 'https://app.beebeeb.io' && p.id !== 'cli' && (
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                  <polyline points="7 10 12 15 17 10"/>
                  <line x1="12" y1="15" x2="12" y2="3"/>
                </svg>
              )}
              {p.cta}
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CLI detail -->
  <section class="dl-cli-section">
    <div class="dl-cli-dots"></div>
    <div class="dl-cli-inner">
      <div class="section-label dl-cli-label">Command line</div>
      <h2 class="dl-cli-title bb-fade-up">
        Power users, this one's for you.
      </h2>
      <p class="dl-cli-desc bb-fade-up bb-delay-1">
        The <code class="dl-cli-code">bb</code> CLI gives you full programmatic access to your vault. Scriptable, pipeable, and mountable as a WebDAV drive.
      </p>

      <div class="dl-cli-install-grid bb-fade-up bb-delay-2">
        {[
          { label: 'Homebrew (macOS / Linux)', cmd: 'brew install beebeeb-io/tap/bb' },
          { label: 'Cargo (Rust)', cmd: 'cargo install bb-cli' },
          { label: 'Direct download', cmd: 'github.com/beebeeb-io/cli/releases' },
        ].map(({ label, cmd }) => (
          <div class="dl-cli-install-card">
            <div class="dl-cli-install-label">{label}</div>
            <div class="dl-cli-install-cmd">
              <code>{cmd}</code>
            </div>
          </div>
        ))}
      </div>

      <div class="dl-cli-cols">
        <div class="bb-fade-up">
          <h3 class="dl-cli-col-title">Common commands</h3>
          <div class="dl-cli-cmd-list">
            {[
              ['bb upload ./report.pdf', 'Encrypt and upload a file'],
              ['bb ls', 'List files in your vault'],
              ['bb download file-id ./local/', 'Download and decrypt'],
              ['bb share file-id --expires 7d', 'Create a 7-day share link'],
              ['bb mount ~/beebeeb', 'Mount as a local drive (WebDAV)'],
            ].map(([cmd, desc]) => (
              <div class="dl-cli-cmd-row">
                <code class="dl-cli-cmd">{cmd}</code>
                <span class="dl-cli-cmd-desc"># {desc}</span>
              </div>
            ))}
          </div>
        </div>
        <div class="bb-fade-up bb-delay-1">
          <h3 class="dl-cli-col-title">WebDAV mount</h3>
          <p class="dl-cli-col-text">
            Mount your Beebeeb vault as a WebDAV drive. Every read decrypts locally. Every write encrypts before upload. Works with Finder, Windows Explorer, and any WebDAV client.
          </p>
          <code class="dl-cli-webdav">bb mount ~/beebeeb --webdav-port 8081</code>
        </div>
      </div>

      <div class="dl-cli-docs bb-fade-up">
        <a href="https://docs.beebeeb.io/cli/install" target="_blank" rel="noopener noreferrer"
           class="dl-cli-docs-btn">
          Full CLI documentation
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- All platforms / sync explanation -->
  <section class="dl-sync-section">
    <div class="dl-sync-inner">
      <h2 class="dl-sync-title bb-fade-up">
        All platforms. One account.
      </h2>
      <p class="dl-sync-desc bb-fade-up bb-delay-1">
        Sign in on any platform and your files are there, decrypted locally. Edits sync in real-time across every device. There is no "primary" device — your vault lives on our servers as ciphertext, and every client holds the key.
      </p>
      <div class="dl-sync-cta bb-fade-up bb-delay-2">
        <a href="https://app.beebeeb.io/signup" class="btn btn-amber">Get started free</a>
        <a href="/features" class="btn btn-ghost">Explore features</a>
      </div>
    </div>
  </section>

</Base>

<style>
  /* ── Hero ────────────────────────────────────────────────── */
  .dl-hero {
    padding: 72px 32px 64px;
    text-align: center;
    position: relative;
  }

  .dl-hero-title {
    font-size: 54px;
    line-height: 1.05;
    font-weight: 700;
    letter-spacing: -0.03em;
    margin-top: 14px;
    max-width: 760px;
    margin-left: auto;
    margin-right: auto;
  }

  .dl-hero-accent {
    color: var(--amber-deep);
  }

  .dl-hero-desc {
    font-size: 15px;
    color: var(--ink-2);
    margin-top: 22px;
    max-width: 560px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.65;
  }

  /* ── Platform cards ─────────────────────────────────────── */
  .dl-cards-section {
    padding: 80px 32px;
    background: var(--paper);
    border-top: 1px solid var(--line);
  }

  .dl-cards-container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .dl-cards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .dl-card {
    display: flex;
    flex-direction: column;
    padding: 24px;
    border: 1px solid var(--line);
    border-radius: 12px;
    background: var(--paper);
    transition: border-color 200ms var(--ease);
  }

  .dl-card:hover {
    border-color: var(--line-2);
  }

  .dl-card-icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: var(--amber-soft);
    color: var(--amber-deep);
    border: 1px solid oklch(0.86 0.07 90);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
    flex-shrink: 0;
  }

  .dl-card-body {
    flex: 1;
  }

  .dl-card-title-row {
    display: flex;
    align-items: baseline;
    gap: 8px;
    margin-bottom: 4px;
  }

  .dl-card-name {
    font-size: 17px;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .dl-card-subtitle {
    font-size: 12px;
    color: var(--ink-3);
  }

  .dl-card-desc {
    font-size: 13px;
    color: var(--ink-2);
    line-height: 1.65;
    margin-bottom: 20px;
  }

  .dl-card-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 10px 16px;
    border-radius: 8px;
    font-size: 13px;
    font-weight: 600;
    text-decoration: none;
    transition: all 150ms var(--ease);
  }

  .dl-card-cta--primary {
    background: var(--amber);
    color: var(--ink);
  }

  .dl-card-cta--primary:hover {
    filter: brightness(1.05);
  }

  .dl-card-cta--secondary {
    background: var(--paper-2);
    color: var(--ink);
    border: 1px solid var(--line);
  }

  .dl-card-cta--secondary:hover {
    border-color: var(--line-2);
    background: var(--paper-3);
  }

  .dl-card-cta--disabled {
    background: var(--paper-2);
    color: var(--ink-3);
    border: 1px solid var(--line);
    cursor: default;
    pointer-events: none;
  }

  /* ── CLI section ────────────────────────────────────────── */
  .dl-cli-section {
    padding: 80px 32px;
    background: var(--ink);
    color: var(--paper);
    border-top: 1px solid var(--line);
    position: relative;
    overflow: hidden;
  }

  .dl-cli-dots {
    position: absolute;
    inset: 0;
    opacity: 0.06;
    background-image: radial-gradient(circle at 50% 50%, oklch(0.82 0.17 84 / 0.5) 1.5px, transparent 1.8px);
    background-size: 24px 24px;
  }

  .dl-cli-inner {
    position: relative;
    max-width: 860px;
    margin: 0 auto;
  }

  .dl-cli-label {
    text-align: center;
    color: oklch(0.82 0.17 84 / 0.7);
  }

  .dl-cli-title {
    font-size: 38px;
    font-weight: 700;
    letter-spacing: -0.025em;
    text-align: center;
    margin-bottom: 16px;
    line-height: 1.15;
  }

  .dl-cli-desc {
    font-size: 15px;
    color: oklch(0.985 0.004 85 / 0.7);
    text-align: center;
    max-width: 540px;
    margin: 0 auto 40px;
    line-height: 1.65;
  }

  .dl-cli-code {
    font-family: var(--font-mono);
    color: var(--amber);
    font-size: 15px;
  }

  .dl-cli-install-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-bottom: 40px;
  }

  .dl-cli-install-card {
    border-radius: 8px;
    border: 1px solid oklch(0.985 0.004 85 / 0.1);
    background: oklch(0.985 0.004 85 / 0.05);
    overflow: hidden;
  }

  .dl-cli-install-label {
    padding: 8px 16px;
    border-bottom: 1px solid oklch(0.985 0.004 85 / 0.1);
    font-size: 11px;
    font-family: var(--font-mono);
    color: oklch(0.985 0.004 85 / 0.4);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .dl-cli-install-cmd {
    padding: 12px 16px;
  }

  .dl-cli-install-cmd code {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--amber);
    word-break: break-all;
  }

  .dl-cli-cols {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 32px;
  }

  .dl-cli-col-title {
    font-size: 16px;
    font-weight: 700;
    margin-bottom: 12px;
  }

  .dl-cli-cmd-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .dl-cli-cmd-row {
    display: flex;
    align-items: flex-start;
    gap: 12px;
  }

  .dl-cli-cmd {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--amber);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .dl-cli-cmd-desc {
    font-size: 12px;
    color: oklch(0.985 0.004 85 / 0.5);
  }

  .dl-cli-col-text {
    font-size: 13px;
    color: oklch(0.985 0.004 85 / 0.6);
    line-height: 1.65;
    margin-bottom: 12px;
  }

  .dl-cli-webdav {
    display: block;
    font-family: var(--font-mono);
