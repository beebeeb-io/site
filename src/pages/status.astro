---
import Base from '../layouts/base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Chip from '../components/Chip.astro';

const services = [
  { name: 'Web app', status: 'ok' },
  { name: 'API', status: 'ok' },
  { name: 'File storage · Amsterdam (primary)', status: 'ok' },
  { name: 'File storage · EU failover', status: 'ok' },
  { name: 'Desktop sync', status: 'ok' },
  { name: 'Mobile push', status: 'ok' },
  { name: 'Share links', status: 'ok' },
  { name: 'Billing · Stripe EU', status: 'ok' },
];
---

<Base title="Status — Beebeeb" description="Live system status for all Beebeeb services. Uptime target 99.9% at GA." path="/status">
  <Nav />

  <section class="px-8 pt-12 pb-16 bg-paper">
    <div class="max-w-[860px] mx-auto">
      <!-- Pre-launch notice -->
      <div class="mb-4 px-3 py-2 bg-paper-2 border border-dashed border-line-2 rounded-lg text-[11.5px] text-ink-3 inline-flex items-center gap-2">
        <span class="w-1.5 h-1.5 rounded-full bg-amber-deep"></span>
        Pre-launch preview &middot; live metrics start at GA
      </div>

      <!-- Header -->
      <div class="flex items-center gap-3.5 mb-1.5">
        <span class="w-3 h-3 rounded-full bg-green" style="box-shadow: 0 0 0 4px oklch(0.96 0.04 155);"></span>
        <h1 class="text-[26px] font-semibold tracking-[-0.02em]">All systems operational</h1>
      </div>
      <p class="text-[13.5px] text-ink-2 mb-7">Staging environment &middot; auto-refresh every 60s</p>

      <!-- Service grid -->
      <div class="border border-line-2 rounded-[10px] overflow-hidden">
        {services.map((s, i) => (
          <div class:list={['px-[18px] py-3.5 flex items-center gap-3', i < services.length - 1 ? 'border-b border-line' : '']}>
            <span class="w-2 h-2 rounded-full bg-green"></span>
            <span class="text-[13px]">{s.name}</span>
            <span class="ml-auto flex gap-[2px]">
              {Array.from({ length: 90 }).map(() => (
                <span class="w-[3px] h-[22px] rounded-[1px] bg-green"></span>
              ))}
            </span>
            <span class="w-[52px] text-right font-mono text-[10.5px] text-ink-3">100%</span>
          </div>
        ))}
      </div>

      <!-- Recent incidents -->
      <div class="mt-[30px]">
        <div class="text-[10.5px] font-semibold tracking-[0.04em] uppercase text-ink-3 mb-2.5">Recent incidents</div>
        <div class="px-4 py-3.5 text-[12.5px] text-ink-3 bg-paper-2 border border-line rounded-[10px]">
          No incidents to report. Once we're live, every outage — including brief ones — will be posted here with a post-mortem.
        </div>
      </div>

      <!-- Subscribe footer -->
      <div class="mt-[30px] p-[18px] border border-line-2 rounded-[10px] flex items-center gap-3.5">
        <svg class="w-3.5 h-3.5 text-ink-2 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        <div class="text-[13px]">
          Uptime target <strong>99.9%</strong> at GA &middot; <a class="text-amber-deep" href="#">subscribe to incidents via email or RSS</a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Base>
