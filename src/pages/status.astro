---
/**
 * Public status page — /status
 *
 * Fetches GET /api/v1/status (live component health) and
 * GET /api/v1/status/history (90-day uptime bars + response time) and
 * GET /api/v1/status/incidents from the Beebeeb API.
 *
 * Polls live status every 60s; history refreshes every 5 minutes.
 */
import Base from '../layouts/base.astro';

const API_BASE = 'https://status.beebeeb.io';
---

<Base
  title="Status — Beebeeb"
  description="Live status for the Beebeeb API, database, storage, and other services."
  path="/status"
>
  <section class="status-hero" id="status-hero">
    <div class="status-container">
      <!-- Overall status banner -->
      <div id="overall-banner" class="status-banner">
        <span id="overall-dot" class="status-dot status-dot--pulse"></span>
        <span id="overall-label" class="status-banner-label">Loading status…</span>
        <span id="overall-updated" class="status-banner-updated t-mono"></span>
      </div>

      <div class="status-section-header">
        <h2 class="status-section-title">Components</h2>
        <span id="refresh-label" class="status-refresh-label t-mono">Auto-refresh in 60s</span>
      </div>

      <!-- Component cards with uptime bars — rendered by JS -->
      <div id="component-list" class="status-component-list">
        {[...Array(5)].map((_, i) => (
          <div class="status-skeleton-card" key={i}>
            <div class="status-skeleton-header"></div>
            <div class="status-skeleton-bars"></div>
          </div>
        ))}
      </div>

      <!-- Incident history -->
      <div class="status-section-header" style="margin-top: 40px;">
        <h2 class="status-section-title">Recent incidents</h2>
      </div>
      <div id="incident-list">
        <div class="status-loading-text">Loading…</div>
      </div>
    </div>
  </section>
</Base>

<script define:vars={{ API_BASE }}>
  const POLL_MS = 60_000;
  const HISTORY_POLL_MS = 300_000;

  const STATUS_CONFIG = {
    operational: {
      dot: 'oklch(0.55 0.12 155)',
      bg: 'oklch(0.97 0.015 155)',
      border: 'oklch(0.88 0.05 155)',
      label: 'All systems operational',
    },
    degraded: {
      dot: 'oklch(0.66 0.15 72)',
      bg: 'oklch(0.96 0.04 88)',
      border: 'oklch(0.82 0.17 84)',
      label: 'Partial degradation',
    },
    outage: {
      dot: 'oklch(0.62 0.21 25)',
      bg: 'oklch(0.97 0.02 25)',
      border: 'oklch(0.85 0.1 25)',
      label: 'Service outage',
    },
    unknown: {
      dot: 'oklch(0.68 0.008 80)',
      bg: 'var(--paper-2)',
      border: 'var(--line)',
      label: 'Unable to reach Beebeeb servers',
    },
  };

  const COMPONENT_LABELS = {
    api: 'API',
    database: 'Database',
    storage: 'Object Storage',
    websocket: 'WebSocket',
    email: 'Email',
  };

  const SEVERITY_COLORS = {
    critical: { bg: '#fef2f2', color: '#dc2626', border: '#fecaca', label: 'Critical' },
    major:    { bg: '#fff7ed', color: '#c2410c', border: '#fed7aa', label: 'Major' },
    minor:    { bg: 'oklch(0.96 0.04 88)', color: 'oklch(0.50 0.13 68)', border: 'oklch(0.82 0.17 84)', label: 'Minor' },
    maintenance: { bg: 'var(--paper-2)', color: 'var(--ink-3)', border: 'var(--line)', label: 'Maintenance' },
  };

  const INCIDENT_STATUS_LABELS = {
    investigating: 'Investigating',
    identified: 'Identified',
    monitoring: 'Monitoring',
    resolved: 'Resolved',
  };

  // ── State ──────────────────────────────────────────────────────────────

  let liveData = null;
  let historyData = null;

  // ── Helpers ────────────────────────────────────────────────────────────

  function dotColor(status) {
    if (status === 'operational') return 'oklch(0.55 0.12 155)';
    if (status === 'degraded') return 'oklch(0.66 0.15 72)';
    if (status === 'outage' || status === 'down') return 'oklch(0.62 0.21 25)';
    return 'oklch(0.68 0.008 80)';
  }

  function barColor(uptimePct) {
    if (uptimePct >= 99.5) return 'oklch(0.55 0.12 155)';
    if (uptimePct >= 95) return 'oklch(0.66 0.15 72)';
    return 'oklch(0.62 0.21 25)';
  }

  function formatTime(iso) {
    if (!iso) return '';
    const d = new Date(iso);
    const now = new Date();
    const diff = now - d;
    if (diff < 60_000) return 'Just now';
    if (diff < 3_600_000) return `${Math.floor(diff / 60_000)}m ago`;
    if (diff < 86_400_000) return `${Math.floor(diff / 3_600_000)}h ago`;
    return d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
  }

  function formatAbsTime(iso) {
    if (!iso) return '';
    return new Date(iso).toLocaleString('en-GB', {
      day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit',
    });
  }

  function formatDate(dateStr) {
    const d = new Date(dateStr + 'T00:00:00');
    return d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short' });
  }

  function escHtml(s) {
    return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  // ── Render functions ───────────────────────────────────────────────────

  function renderBanner(overallStatus, updatedAt) {
    const cfg = STATUS_CONFIG[overallStatus] || STATUS_CONFIG.unknown;
    const banner = document.getElementById('overall-banner');
    const dot = document.getElementById('overall-dot');
    const label = document.getElementById('overall-label');
    const updated = document.getElementById('overall-updated');

    if (banner) { banner.style.background = cfg.bg; banner.style.borderColor = cfg.border; }
    if (dot) { dot.style.background = cfg.dot; dot.classList.remove('status-dot--pulse'); }
    if (label) { label.textContent = cfg.label; label.style.color = 'var(--ink)'; }
    if (updated && updatedAt) { updated.textContent = `Updated ${formatTime(updatedAt)}`; }
  }

  function renderComponents() {
    const list = document.getElementById('component-list');
    if (!list) return;

    const entries = Object.entries(COMPONENT_LABELS);
    list.innerHTML = entries.map(([key, displayName]) => {
      const comp = liveData?.components?.[key];
      const status = comp?.status || 'unknown';
      const color = dotColor(status);
      const statusLabel = status.charAt(0).toUpperCase() + status.slice(1);

      // History data for this component
      const hist = historyData?.components?.[key];
      const uptime90d = hist?.uptime_90d ?? null;
      const avgLatency = hist?.avg_latency_30d ?? null;
      const days = hist?.days || [];

      // Stats line
      const statsFragments = [];
      if (uptime90d !== null) statsFragments.push(`${uptime90d.toFixed(2)}%`);
      if (avgLatency !== null) statsFragments.push(`${avgLatency}ms avg`);
      const statsLine = statsFragments.join(' · ');

      // Uptime bars (90 days, newest on right)
      const sortedDays = [...days].sort((a, b) => a.date.localeCompare(b.date));
      const barsHtml = sortedDays.length > 0
        ? sortedDays.map(d => {
            const pct = d.uptime_pct ?? 100;
            const bc = barColor(pct);
            const latStr = d.avg_latency_ms != null ? ` · ${d.avg_latency_ms}ms avg` : '';
            const tooltip = `${formatDate(d.date)} — ${pct.toFixed(1)}% uptime${latStr}`;
            return `<div class="uptime-bar" style="background:${bc};" title="${escHtml(tooltip)}"></div>`;
          }).join('')
        : '<div class="uptime-bar-empty">No history data yet</div>';

      // Sparkline SVG (30 day response time) — only for components with latency
      let sparklineHtml = '';
      if (avgLatency !== null && sortedDays.length > 0) {
        const recent30 = sortedDays.slice(-30);
        const latencies = recent30.map(d => d.avg_latency_ms ?? 0);
        const max = Math.max(...latencies, 1);
        const w = 400;
        const h = 40;
        const points = latencies.map((v, i) => {
          const x = (i / Math.max(latencies.length - 1, 1)) * w;
          const y = h - (v / max) * (h - 4) - 2;
          return `${x},${y}`;
        });
        const linePath = `M${points.join(' L')}`;
        const areaPath = `M0,${h} L${points.join(' L')} L${w},${h} Z`;

        const lineColor = avgLatency > 500 ? 'oklch(0.62 0.21 25)' :
                          avgLatency > 200 ? 'oklch(0.66 0.15 72)' :
                          'oklch(0.55 0.12 155)';

        sparklineHtml = `
          <div class="sparkline-section">
            <div class="sparkline-label">Response time (30d)</div>
            <svg class="sparkline-svg" viewBox="0 0 ${w} ${h}" preserveAspectRatio="none">
              <defs>
                <linearGradient id="grad-${key}" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="0%" stop-color="${lineColor}" stop-opacity="0.15"/>
                  <stop offset="100%" stop-color="${lineColor}" stop-opacity="0"/>
                </linearGradient>
              </defs>
              <path d="${areaPath}" fill="url(#grad-${key})"/>
              <path d="${linePath}" fill="none" stroke="${lineColor}" stroke-width="1.5"/>
            </svg>
          </div>`;
      }

      return `
        <div class="status-component-card">
          <div class="status-component-header">
            <div class="status-component-left">
              <span class="status-component-dot" style="background:${color};"></span>
              <span class="status-component-name">${displayName}</span>
              <span class="status-component-status">${statusLabel}</span>
            </div>
            <span class="status-component-stats t-mono">${statsLine}</span>
          </div>
          <div class="uptime-bars">${barsHtml}</div>
          <div class="uptime-labels">
            <span>90 days ago</span>
            <span>Today</span>
          </div>
          ${sparklineHtml}
        </div>`;
    }).join('');
  }

  function renderIncidents(incidents) {
    const list = document.getElementById('incident-list');
    if (!list) return;

    if (!incidents || incidents.length === 0) {
      list.innerHTML = `
        <div class="status-empty-incidents">
          <div class="status-empty-text">No incidents in the past 90 days.</div>
        </div>`;
      return;
    }

    list.innerHTML = `
      <div class="status-incident-list">
        ${incidents.map((inc) => {
          const sev = SEVERITY_COLORS[inc.severity] || SEVERITY_COLORS.minor;
          const statusLabel = INCIDENT_STATUS_LABELS[inc.status] || inc.status;
          const isOpen = inc.status !== 'resolved';
          return `
            <div class="status-incident${isOpen ? ' status-incident--open' : ''}">
              <div class="status-incident-row">
                <span class="status-severity-badge"
                      style="background:${sev.bg};color:${sev.color};border-color:${sev.border};">
                  ${sev.label}
                </span>
                <div class="status-incident-body">
                  <div class="status-incident-title">${escHtml(inc.title)}</div>
                  <div class="status-incident-meta">
                    <span class="status-incident-status">${statusLabel}</span>
                    <span class="status-incident-sep">·</span>
                    <span class="status-incident-time t-mono" title="${inc.started_at}">
                      Started ${formatAbsTime(inc.started_at)}
                    </span>
                    ${inc.resolved_at ? `
                      <span class="status-incident-sep">·</span>
                      <span class="status-incident-time t-mono" title="${inc.resolved_at}">
                        Resolved ${formatAbsTime(inc.resolved_at)}
                      </span>` : ''}
                  </div>
                  ${inc.message ? `<p class="status-incident-message">${escHtml(inc.message)}</p>` : ''}
                </div>
              </div>
            </div>`;
        }).join('')}
      </div>`;
  }

  function renderError() {
    renderBanner('unknown', null);
    const list = document.getElementById('component-list');
    if (list) list.innerHTML = `
      <div class="status-error-full">Component status unavailable — check back shortly.</div>`;
    const incList = document.getElementById('incident-list');
    if (incList) incList.innerHTML = `
      <div class="status-error-text">Incident history unavailable while the API is unreachable.</div>`;
  }

  // ── Fetch and render ───────────────────────────────────────────────────

  async function refreshLive() {
    try {
      const res = await fetch(`${API_BASE}/api/v1/status`, { cache: 'no-store' });
      if (res.ok) {
        liveData = await res.json();
        renderBanner(liveData.status || 'unknown', liveData.updated_at || new Date().toISOString());
      } else {
        liveData = null;
        renderBanner('unknown', null);
      }
    } catch {
      liveData = null;
      renderBanner('unknown', null);
    }
    renderComponents();
  }

  async function refreshHistory() {
    try {
      const res = await fetch(`${API_BASE}/api/v1/status/history`, { cache: 'no-store' });
      if (res.ok) {
        historyData = await res.json();
      }
    } catch {
      // Keep existing history data on failure
    }
    renderComponents();
  }

  async function refreshIncidents() {
    try {
      const res = await fetch(`${API_BASE}/api/v1/status/incidents`, { cache: 'no-store' });
      if (res.ok) {
        const data = await res.json();
        renderIncidents(data.incidents || []);
      } else {
        renderIncidents([]);
      }
    } catch {
      renderIncidents([]);
    }
  }

  // ── Countdown refresh label ────────────────────────────────────────────

  let countdown = POLL_MS / 1000;
  function tickCountdown() {
    countdown -= 1;
    const el = document.getElementById('refresh-label');
    if (el) el.textContent = countdown > 0 ? `Auto-refresh in ${countdown}s` : 'Refreshing…';
    if (countdown <= 0) {
      countdown = POLL_MS / 1000;
      refreshLive();
      refreshIncidents();
    }
  }

  // ── Boot ───────────────────────────────────────────────────────────────
  refreshLive();
  refreshHistory();
  refreshIncidents();
  setInterval(tickCountdown, 1_000);
  setInterval(refreshHistory, HISTORY_POLL_MS);
</script>

<style is:global>
  .status-hero {
    padding: 72px 32px 40px;
    border-bottom: 1px solid var(--line);
  }

  .status-container {
    max-width: 860px;
    margin: 0 auto;
  }

  /* ── Overall banner ──────────────────────────────────── */
  .status-banner {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px;
    border-radius: 12px;
    border: 1px solid var(--line);
    background: var(--paper-2);
    margin-bottom: 32px;
  }

  .status-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    flex-shrink: 0;
    background: var(--ink-4);
  }

  .status-dot--pulse {
    animation: statusPulse 2s ease-in-out infinite;
  }

  @keyframes statusPulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .status-banner-label {
    font-size: 16px;
    font-weight: 600;
    color: var(--ink-3);
  }

  .status-banner-updated {
    margin-left: auto;
    font-size: 11px;
    color: var(--ink-4);
  }

  /* ── Section headers ─────────────────────────────────── */
  .status-section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 16px;
  }

  .status-section-title {
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-3);
    margin: 0;
  }

  .status-refresh-label {
    font-size: 11px;
    color: var(--ink-4);
  }

  /* ── Component list ──────────────────────────────────── */
  .status-component-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  /* ── Component card ──────────────────────────────────── */
  .status-component-card {
    border-radius: 12px;
    border: 1px solid var(--line);
    background: var(--paper);
    padding: 20px;
  }

  .status-component-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
  }

  .status-component-left {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .status-component-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .status-component-name {
    font-size: 14px;
    font-weight: 600;
    color: var(--ink);
  }

  .status-component-status {
    font-size: 12px;
    color: var(--ink-3);
  }

  .status-component-stats {
    font-size: 12px;
    color: var(--ink-3);
  }

  /* ── Uptime bars ─────────────────────────────────────── */
  .uptime-bars {
    display: flex;
    gap: 1.5px;
    height: 28px;
    align-items: stretch;
  }

  .uptime-bar {
    flex: 1;
    min-width: 0;
    border-radius: 1.5px;
    cursor: default;
    transition: opacity 0.1s;
  }

  .uptime-bar:hover {
    opacity: 0.7;
  }

  .uptime-bar-empty {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    color: var(--ink-4);
    background: var(--paper-2);
    border-radius: 4px;
  }

  .uptime-labels {
    display: flex;
    justify-content: space-between;
    margin-top: 4px;
    font-size: 10px;
    color: var(--ink-4);
  }

  /* ── Sparkline ───────────────────────────────────────── */
  .sparkline-section {
    border-top: 1px solid var(--line);
    margin-top: 12px;
    padding-top: 10px;
  }

  .sparkline-label {
    font-size: 10px;
    color: var(--ink-4);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 6px;
  }

  .sparkline-svg {
    width: 100%;
    height: 40px;
    display: block;
  }

  /* ── Skeleton loading ────────────────────────────────── */
  .status-skeleton-card {
    border-radius: 12px;
    border: 1px solid var(--line);
    background: var(--paper);
    padding: 20px;
    animation: statusPulse 2s ease-in-out infinite;
  }

  .status-skeleton-header {
    height: 16px;
    width: 200px;
    background: var(--paper-2);
    border-radius: 4px;
    margin-bottom: 16px;
  }

  .status-skeleton-bars {
    height: 28px;
    background: var(--paper-2);
    border-radius: 4px;
  }

  .status-loading-text {
    font-size: 13px;
    color: var(--ink-4);
    padding: 16px 0;
    animation: statusPulse 2s ease-in-out infinite;
  }

  /* ── Empty incidents ─────────────────────────────────── */
  .status-empty-incidents {
    border-radius: 12px;
    border: 1px solid var(--line);
    background: var(--paper-2);
    padding: 32px 20px;
    text-align: center;
  }

  .status-empty-text {
    font-size: 13px;
    color: var(--ink-3);
  }

  /* ── Incident list ───────────────────────────────────── */
  .status-incident-list {
    border-radius: 12px;
    border: 1px solid var(--line);
    overflow: hidden;
  }

  .status-incident {
    padding: 20px;
    background: var(--paper);
  }

  .status-incident + .status-incident {
    border-top: 1px solid var(--line);
  }

  .status-incident--open {
    background: oklch(0.96 0.04 88 / 0.3);
  }

  .status-incident-row {
    display: flex;
    align-items: flex-start;
    gap: 12px;
  }

  .status-severity-badge {
    display: inline-block;
    margin-top: 2px;
    flex-shrink: 0;
    font-size: 10px;
    font-weight: 600;
    padding: 2px 6px;
    border-radius: 4px;
    border: 1px solid;
  }

  .status-incident-body {
    flex: 1;
    min-width: 0;
  }

  .status-incident-title {
    font-size: 13.5px;
    font-weight: 600;
    color: var(--ink);
    line-height: 1.4;
  }

  .status-incident-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 4px;
    flex-wrap: wrap;
  }

  .status-incident-status {
    font-size: 11.5px;
    color: var(--ink-3);
  }

  .status-incident-sep {
    color: var(--ink-4);
  }

  .status-incident-time {
    font-size: 10.5px;
    color: var(--ink-4);
  }

  .status-incident-message {
    font-size: 12px;
    color: var(--ink-3);
    margin: 8px 0 0;
    line-height: 1.6;
  }

  /* ── Error states ────────────────────────────────────── */
  .status-error-full {
    text-align: center;
    padding: 24px;
    font-size: 13px;
    color: var(--ink-3);
  }

  .status-error-text {
    font-size: 13px;
    color: var(--ink-4);
    padding: 16px 0;
  }

  /* ── Responsive ──────────────────────────────────────── */
  @media (max-width: 560px) {
    .status-hero {
      padding: 48px 20px 32px;
    }

    .status-banner {
      flex-wrap: wrap;
    }

    .status-banner-updated {
      width: 100%;
      margin-left: 24px;
    }

    .status-component-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 4px;
    }

    .status-component-stats {
      margin-left: 16px;
    }
  }
</style>
