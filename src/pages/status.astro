---
/**
 * Public status page — /status
 *
 * Static Astro shell with a small client-side <script> that fetches
 * GET /api/v1/status and GET /api/v1/status/incidents from the Beebeeb API,
 * renders the component grid and incident timeline, and polls every 60 seconds.
 *
 * If the API is unreachable, the page itself IS the outage indicator.
 */
import Base from '../layouts/base.astro';

const API_BASE = 'https://api.beebeeb.io';
---

<Base
  title="Status — Beebeeb"
  description="Live status for the Beebeeb API, database, storage, and other services."
  path="/status"
>
  <!-- ── Page header ──────────────────────────────────────────────────── -->
  <section class="status-hero" id="status-hero">
    <div class="status-container">
      <!-- Overall status banner — replaced by JS once data loads -->
      <div id="overall-banner" class="status-banner">
        <span id="overall-dot" class="status-dot status-dot--pulse"></span>
        <span id="overall-label" class="status-banner-label">
          Loading status…
        </span>
        <span id="overall-updated" class="status-banner-updated t-mono"></span>
      </div>

      <div class="status-section-header">
        <h2 class="status-section-title">Components</h2>
        <span id="refresh-label" class="status-refresh-label t-mono">Auto-refresh in 60s</span>
      </div>

      <!-- Component grid — rendered by JS -->
      <div id="component-grid" class="status-component-grid">
        {/* Loading skeleton */}
        {[...Array(5)].map((_, i) => (
          <div class="status-skeleton" key={i} />
        ))}
      </div>

      <!-- Incident history -->
      <div class="status-section-header">
        <h2 class="status-section-title">Recent incidents</h2>
      </div>
      <div id="incident-list">
        <div class="status-loading-text">Loading…</div>
      </div>
    </div>
  </section>
</Base>

<!-- ── Client-side status engine ─────────────────────────────────────────── -->
<script define:vars={{ API_BASE }}>
  // ── Constants ──────────────────────────────────────────────────────────
  const POLL_MS = 60_000

  const STATUS_CONFIG = {
    operational: {
      dot: 'oklch(0.55 0.12 155)',
      bg: 'oklch(0.97 0.015 155)',
      border: 'oklch(0.88 0.05 155)',
      label: 'All systems operational',
    },
    degraded: {
      dot: 'oklch(0.66 0.15 72)',
      bg: 'oklch(0.96 0.04 88)',
      border: 'oklch(0.82 0.17 84)',
      label: 'Partial degradation',
    },
    outage: {
      dot: 'oklch(0.62 0.21 25)',
      bg: 'oklch(0.97 0.02 25)',
      border: 'oklch(0.85 0.1 25)',
      label: 'Service outage',
    },
    unknown: {
      dot: 'oklch(0.68 0.008 80)',
      bg: 'var(--paper-2)',
      border: 'var(--line)',
      label: 'Unable to reach Beebeeb servers',
    },
  }

  const COMPONENT_LABELS = {
    api: 'API',
    database: 'Database',
    storage: 'Object Storage',
    websocket: 'WebSocket',
    email: 'Email',
  }

  const SEVERITY_COLORS = {
    critical: { bg: '#fef2f2', color: '#dc2626', border: '#fecaca', label: 'Critical' },
    major:    { bg: '#fff7ed', color: '#c2410c', border: '#fed7aa', label: 'Major' },
    minor:    { bg: 'oklch(0.96 0.04 88)', color: 'oklch(0.50 0.13 68)', border: 'oklch(0.82 0.17 84)', label: 'Minor' },
    maintenance: { bg: 'var(--paper-2)', color: 'var(--ink-3)', border: 'var(--line)', label: 'Maintenance' },
  }

  const INCIDENT_STATUS_LABELS = {
    investigating: '🔍 Investigating',
    identified: '🔎 Identified',
    monitoring: '👀 Monitoring',
    resolved: '✓ Resolved',
  }

  // ── Helpers ────────────────────────────────────────────────────────────

  function dotColor(status) {
    if (status === 'operational') return 'oklch(0.55 0.12 155)'
    if (status === 'degraded') return 'oklch(0.66 0.15 72)'
    if (status === 'outage' || status === 'down') return 'oklch(0.62 0.21 25)'
    return 'oklch(0.68 0.008 80)'
  }

  function componentDetail(name, comp) {
    if (!comp) return ''
    if (name === 'api' && comp.latency_ms != null) return `${comp.latency_ms} ms`
    if (name === 'database' && comp.latency_ms != null) return `${comp.latency_ms} ms`
    if (name === 'storage' && comp.pool_count != null) return `${comp.pool_count} pool${comp.pool_count !== 1 ? 's' : ''}`
    if (name === 'websocket' && comp.connections != null) return `${comp.connections} conn`
    return ''
  }

  function formatTime(iso) {
    if (!iso) return '—'
    const d = new Date(iso)
    const now = new Date()
    const diff = now - d
    if (diff < 60_000) return 'Just now'
    if (diff < 3_600_000) return `${Math.floor(diff / 60_000)}m ago`
    if (diff < 86_400_000) return `${Math.floor(diff / 3_600_000)}h ago`
    return d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })
  }

  function formatAbsTime(iso) {
    if (!iso) return '—'
    return new Date(iso).toLocaleString('en-GB', {
      day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit',
    })
  }

  // ── Render functions ───────────────────────────────────────────────────

  function renderBanner(overallStatus, updatedAt) {
    const cfg = STATUS_CONFIG[overallStatus] ?? STATUS_CONFIG.unknown
    const banner = document.getElementById('overall-banner')
    const dot = document.getElementById('overall-dot')
    const label = document.getElementById('overall-label')
    const updated = document.getElementById('overall-updated')

    if (banner) {
      banner.style.background = cfg.bg
      banner.style.borderColor = cfg.border
    }
    if (dot) {
      dot.style.background = cfg.dot
      dot.classList.remove('status-dot--pulse')
    }
    if (label) {
      label.textContent = cfg.label
      label.style.color = 'var(--ink)'
    }
    if (updated && updatedAt) {
      updated.textContent = `Updated ${formatTime(updatedAt)}`
    }
  }

  function renderComponents(components) {
    const grid = document.getElementById('component-grid')
    if (!grid) return

    const entries = Object.entries(COMPONENT_LABELS)
    grid.innerHTML = entries.map(([key, displayName]) => {
      const comp = components?.[key]
      const status = comp?.status ?? 'unknown'
      const detail = componentDetail(key, comp)
      const color = dotColor(status)
      const statusLabel = status.charAt(0).toUpperCase() + status.slice(1)

      return `
        <div class="status-component-card">
          <span class="status-component-dot" style="background: ${color};"></span>
          <div class="status-component-info">
            <div class="status-component-name">${displayName}</div>
            <div class="status-component-detail">${statusLabel}${detail ? ` · ${detail}` : ''}</div>
          </div>
        </div>`
    }).join('')
  }

  function renderIncidents(incidents) {
    const list = document.getElementById('incident-list')
    if (!list) return

    if (!incidents || incidents.length === 0) {
      list.innerHTML = `
        <div class="status-empty-incidents">
          <div class="status-empty-text">No incidents in the past 90 days.</div>
        </div>`
      return
    }

    list.innerHTML = `
      <div class="status-incident-list">
        ${incidents.map((inc) => {
          const sev = SEVERITY_COLORS[inc.severity] ?? SEVERITY_COLORS.minor
          const statusLabel = INCIDENT_STATUS_LABELS[inc.status] ?? inc.status
          const isOpen = inc.status !== 'resolved'
          return `
            <div class="status-incident${isOpen ? ' status-incident--open' : ''}">
              <div class="status-incident-row">
                <span class="status-severity-badge"
                      style="background: ${sev.bg}; color: ${sev.color}; border-color: ${sev.border};">
                  ${sev.label}
                </span>
                <div class="status-incident-body">
                  <div class="status-incident-title">${escHtml(inc.title)}</div>
                  <div class="status-incident-meta">
                    <span class="status-incident-status">${statusLabel}</span>
                    <span class="status-incident-sep">·</span>
                    <span class="status-incident-time t-mono" title="${inc.started_at}">
                      Started ${formatAbsTime(inc.started_at)}
                    </span>
                    ${inc.resolved_at ? `
                      <span class="status-incident-sep">·</span>
                      <span class="status-incident-time t-mono" title="${inc.resolved_at}">
                        Resolved ${formatAbsTime(inc.resolved_at)}
                      </span>` : ''}
                  </div>
                  ${inc.message ? `<p class="status-incident-message">${escHtml(inc.message)}</p>` : ''}
                </div>
              </div>
            </div>`
        }).join('')}
      </div>`
  }

  function renderError() {
    renderBanner('unknown', null)
    const grid = document.getElementById('component-grid')
    if (grid) grid.innerHTML = `
      <div class="status-error-full">
        Component status unavailable — check back shortly.
      </div>`
    const list = document.getElementById('incident-list')
    if (list) list.innerHTML = `
      <div class="status-error-text">
        Incident history unavailable while the API is unreachable.
      </div>`
  }

  function escHtml(s) {
    return String(s)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
  }

  // ── Fetch and render ───────────────────────────────────────────────────

  async function refresh() {
    try {
      const [statusRes, incRes] = await Promise.allSettled([
        fetch(`${API_BASE}/api/v1/status`, { cache: 'no-store' }),
        fetch(`${API_BASE}/api/v1/status/incidents`, { cache: 'no-store' }),
      ])

      // Status data
      if (statusRes.status === 'fulfilled' && statusRes.value.ok) {
        const data = await statusRes.value.json()
        renderBanner(data.status ?? 'unknown', data.updated_at ?? new Date().toISOString())
        renderComponents(data.components)
      } else if (statusRes.status === 'rejected' || statusRes.value?.status === 404) {
        // API not yet deployed or unreachable — show unknown state
        renderBanner('unknown', null)
        renderComponents(null)
      } else {
        renderBanner('unknown', null)
        renderComponents(null)
      }

      // Incident data
      if (incRes.status === 'fulfilled' && incRes.value.ok) {
        const data = await incRes.value.json()
        renderIncidents(data.incidents ?? [])
      } else {
        renderIncidents([])
      }
    } catch {
      renderError()
    }
  }

  // ── Countdown refresh label ────────────────────────────────────────────

  let countdown = POLL_MS / 1000
  function tickCountdown() {
    countdown -= 1
    const el = document.getElementById('refresh-label')
    if (el) el.textContent = countdown > 0 ? `Auto-refresh in ${countdown}s` : 'Refreshing…'
    if (countdown <= 0) {
      countdown = POLL_MS / 1000
      refresh()
    }
  }

  // ── Boot ───────────────────────────────────────────────────────────────
  refresh()
  setInterval(tickCountdown, 1_000)
</script>

<style>
  /* ── Page hero / container ──────────────────────────────── */
  .status-hero {
    padding: 72px 32px 40px;
    border-bottom: 1px solid var(--line);
  }

  .status-container {
    max-width: 860px;
    margin: 0 auto;
  }

  /* ── Overall status banner ──────────────────────────────── */
  .status-banner {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px;
    border-radius: 12px;
    border: 1px solid var(--line);
    background: var(--paper-2);
    margin-bottom: 32px;
  }

  .status-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    flex-shrink: 0;
    background: var(--ink-4);
  }

  .status-dot--pulse {
    animation: statusPulse 2s ease-in-out infinite;
  }

  @keyframes statusPulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .status-banner-label {
    font-size: 16px;
    font-weight: 600;
    color: var(--ink-3);
  }

  .status-banner-updated {
    margin-left: auto;
    font-size: 11px;
    color: var(--ink-4);
  }

  /* ── Section headers ────────────────────────────────────── */
  .status-section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 16px;
  }

  .status-section-title {
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-3);
    margin: 0;
  }

  .status-refresh-label {
    font-size: 11px;
    color: var(--ink-4);
  }

  /* ── Component grid ─────────────────────────────────────── */
  .status-component-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    margin-bottom: 40px;
  }

  /* ── Component card (JS-rendered) ───────────────────────── */
  .status-component-card {
    border-radius: 12px;
    border: 1px solid var(--line);
    background: var(--paper);
    padding: 16px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .status-component-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .status-component-info {
    flex: 1;
    min-width: 0;
  }

  .status-component-name {
    font-size: 13px;
    font-weight: 500;
    color: var(--ink);
  }

  .status-component-detail {
    font-size: 11px;
    color: var(--ink-3);
    margin-top: 2px;
  }

  /* ── Loading skeleton ───────────────────────────────────── */
  .status-skeleton {
    border-radius: 12px;
    border: 1px solid var(--line);
    background: var(--paper-2);
    padding: 16px;
    height: 72px;
    animation: statusPulse 2s ease-in-out infinite;
  }

  .status-loading-text {
    font-size: 13px;
    color: var(--ink-4);
    padding: 16px 0;
    animation: statusPulse 2s ease-in-out infinite;
  }

  /* ── Empty incidents ────────────────────────────────────── */
  .status-empty-incidents {
    border-radius: 12px;
    border: 1px solid var(--line);
    background: var(--paper-2);
    padding: 32px 20px;
    text-align: center;
  }

  .status-empty-text {
    font-size: 13px;
    color: var(--ink-3);
  }

  /* ── Incident list (JS-rendered) ────────────────────────── */
  .status-incident-list {
    border-radius: 12px;
    border: 1px solid var(--line);
    overflow: hidden;
  }

  .status-incident {
    padding: 20px;
    background: var(--paper);
  }

  .status-incident + .status-incident {
    border-top: 1px solid var(--line);
  }

  .status-incident--open {
    background: oklch(0.96 0.04 88 / 0.3);
  }

  .status-incident-row {
    display: flex;
    align-items: flex-start;
    gap: 12px;
  }

  .status-severity-badge {
    display: inline-block;
    margin-top: 2px;
    flex-shrink: 0;
    font-size: 10px;
    font-weight: 600;
    padding: 2px 6px;
    border-radius: 4px;
    border: 1px solid;
  }

  .status-incident-body {
    flex: 1;
    min-width: 0;
  }

  .status-incident-title {
    font-size: 13.5px;
    font-weight: 600;
    color: var(--ink);
    line-height: 1.4;
  }

  .status-incident-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 4px;
    flex-wrap: wrap;
  }

  .status-incident-status {
    font-size: 11.5px;
    color: var(--ink-3);
  }

  .status-incident-sep {
    color: var(--ink-4);
  }

  .status-incident-time {
    font-size: 10.5px;
    color: var(--ink-4);
  }

  .status-incident-message {
    font-size: 12px;
    color: var(--ink-3);
    margin: 8px 0 0;
    line-height: 1.6;
  }

  /* ── Error states (JS-rendered) ─────────────────────────── */
  .status-error-full {
    grid-column: 1 / -1;
    text-align: center;
    padding: 24px;
    font-size: 13px;
    color: var(--ink-3);
  }

  .status-error-text {
    font-size: 13px;
    color: var(--ink-4);
    padding: 16px 0;
  }

  /* ── Responsive ─────────────────────────────────────────── */
  @media (max-width: 760px) {
    .status-component-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 560px) {
    .status-hero {
      padding: 48px 20px 32px;
    }

    .status-component-grid {
      grid-template-columns: 1fr;
    }

    .status-banner {
      flex-wrap: wrap;
    }

    .status-banner-updated {
      width: 100%;
      margin-left: 24px;
    }
  }
</style>
