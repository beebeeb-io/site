---
import Base from '../layouts/base.astro';
import { getLaunchPhase } from '../lib/strapi';
import { phaseConfig } from '../lib/phase';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import SecurityHero from '../components/security/SecurityHero.astro';
import SecurityNav from '../components/security/SecurityNav.astro';
import SecurityZeroKnowledge from '../components/security/SecurityZeroKnowledge.astro';
import SecurityEncryption from '../components/security/SecurityEncryption.astro';
import SecurityKeyDerivation from '../components/security/SecurityKeyDerivation.astro';
import SecuritySharing from '../components/security/SecuritySharing.astro';
import SecurityAuthentication from '../components/security/SecurityAuthentication.astro';
import SecurityInfra from '../components/security/SecurityInfra.astro';
import SecurityLegal from '../components/security/SecurityLegal.astro';
import SecurityWarrantCanary from '../components/security/SecurityWarrantCanary.astro';
import SecurityOpenSource from '../components/security/SecurityOpenSource.astro';
import SecurityAudit from '../components/security/SecurityAudit.astro';
import SecurityFinalCTA from '../components/security/SecurityFinalCTA.astro';
import '../components/security/security.css';

const phase = await getLaunchPhase();
const cfg = phaseConfig(phase);
---

<Base
  title="Security — Beebeeb"
  description="How Beebeeb's end-to-end encryption works. AES-256-GCM, OPAQUE PAKE, HKDF, X25519."
  path="/security"
  chrome={false}
>
  <Nav active="security" cfg={cfg} />
  <main class="security-page">
    <SecurityNav showCanary={cfg.phase >= 2} />
    <SecurityHero />
    <SecurityZeroKnowledge />
    <SecurityEncryption />
    <SecurityKeyDerivation />
    <SecuritySharing />
    <SecurityAuthentication />
    <SecurityInfra />
    <SecurityLegal />
    {cfg.phase >= 2 && <SecurityWarrantCanary />}
    <SecurityOpenSource />
    <SecurityAudit />
    <SecurityFinalCTA />
  </main>
  <Footer cfg={cfg} />
</Base>
