---
import Base from '../layouts/base.astro';
import CtaSection from '../components/blocks/CtaSection.astro';
---

<Base
  title="Features — Beebeeb"
  description="End-to-end encrypted cloud storage with photo backup, secure sharing, file preview, version history, and cross-platform sync. Built in Europe. Zero-knowledge by architecture."
  path="/features"
>

  <!-- ═══════════════════════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════════════════════ -->
  <section class="px-8 pt-[72px] pb-16 text-center relative" style="background: linear-gradient(180deg, var(--color-amber-bg) 0%, var(--color-paper) 85%);">
    <div class="section-label bb-fade-up">What Beebeeb does</div>
    <h1 class="text-[54px] leading-[1.05] font-bold tracking-[-0.03em] mt-3.5 max-w-[860px] mx-auto bb-fade-up bb-delay-1">
      Everything you need in cloud storage.<br />
      <span class="text-amber-deep">Nothing you don't.</span>
    </h1>
    <p class="text-base text-ink-2 mt-[22px] max-w-[600px] mx-auto leading-relaxed bb-fade-up bb-delay-2">
      Beebeeb is a zero-knowledge encrypted vault for the files that matter. No ads, no tracking, no data mining. Just your files — private, fast, and always under your control.
    </p>
    <div class="flex gap-3 justify-center mt-8 flex-wrap bb-fade-up bb-delay-3">
      <a href="https://app.beebeeb.io/signup" class="btn btn-amber">Get started free</a>
      <a href="/pricing" class="btn btn-ghost">See pricing</a>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       FEATURE GRID — Core features (1–4)
       ═══════════════════════════════════════════════════════════ -->
  <section class="px-8 py-20 bg-paper border-t border-line">
    <div class="max-w-[1100px] mx-auto">
      <div class="section-label text-center bb-fade-up">Core features</div>
      <h2 class="text-[40px] font-bold tracking-[-0.025em] text-center mb-14 leading-tight bb-fade-up bb-delay-1">
        Built for privacy. Built to last.
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-[18px]" data-stagger>

        <!-- 1. End-to-end encrypted -->
        <div class="p-7 border border-line rounded-lg bg-paper bb-fade-up bb-lift">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-[10px] bg-amber-bg text-amber-deep border border-[oklch(0.86_0.07_90)] flex items-center justify-center shrink-0">
              <svg class="w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <div>
              <h3 class="text-[18px] font-bold tracking-[-0.02em] mb-2 leading-tight">End-to-end encrypted</h3>
              <p class="text-[13.5px] text-ink-2 leading-relaxed">
                Your files are encrypted before they leave your device. We can't read them. Nobody can. Even under a court order, we have nothing useful to hand over.
              </p>
            </div>
          </div>
        </div>

        <!-- 2. Zero-knowledge architecture -->
        <div class="p-7 border border-line rounded-lg bg-paper bb-fade-up bb-lift">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-[10px] bg-amber-bg text-amber-deep border border-[oklch(0.86_0.07_90)] flex items-center justify-center shrink-0">
              <svg class="w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
            </div>
            <div>
              <h3 class="text-[18px] font-bold tracking-[-0.02em] mb-2 leading-tight">Zero-knowledge architecture</h3>
              <p class="text-[13.5px] text-ink-2 leading-relaxed">
                We don't know what you store. Not the file names. Not the file types. Not even the thumbnails. The encryption key lives on your device and nowhere else.
              </p>
            </div>
          </div>
        </div>

        <!-- 3. Works everywhere -->
        <div class="p-7 border border-line rounded-lg bg-paper bb-fade-up bb-lift">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-[10px] bg-amber-bg text-amber-deep border border-[oklch(0.86_0.07_90)] flex items-center justify-center shrink-0">
              <svg class="w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
            </div>
            <div>
              <h3 class="text-[18px] font-bold tracking-[-0.02em] mb-2 leading-tight">Works everywhere</h3>
              <p class="text-[13.5px] text-ink-2 leading-relaxed mb-3">
                Web, iOS, Android, desktop sync client, and CLI. Your files follow you across every device. One vault, all platforms.
              </p>
              <div class="flex gap-2 flex-wrap">
                {['Web', 'iOS', 'Android', 'Desktop', 'CLI'].map(p => (
                  <span class="inline-flex px-2.5 py-1 bg-paper-2 border border-line rounded-md font-mono text-[11px] text-ink-3">{p}</span>
                ))}
              </div>
            </div>
          </div>
        </div>

        <!-- 4. Photo backup -->
        <div class="p-7 border border-line rounded-lg bg-paper bb-fade-up bb-lift">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-[10px] bg-amber-bg text-amber-deep border border-[oklch(0.86_0.07_90)] flex items-center justify-center shrink-0">
              <svg class="w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
            </div>
            <div>
              <h3 class="text-[18px] font-bold tracking-[-0.02em] mb-2 leading-tight">Automatic photo backup</h3>
              <p class="text-[13.5px] text-ink-2 leading-relaxed">
                Your phone's photos, encrypted and backed up automatically in the background. Every memory, safe. No one at Beebeeb can ever see them.
              </p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       SHARING + PREVIEW (alternating background)
       ═══════════════════════════════════════════════════════════ -->
  <section class="px-8 py-20 bg-paper-2 border-t border-line">
    <div class="max-w-[1100px] mx-auto">
      <div class="section-label text-center bb-fade-up">Sharing and preview</div>
      <h2 class="text-[40px] font-bold tracking-[-0.025em] text-center mb-14 leading-tight bb-fade-up bb-delay-1">
        Share safely. Preview instantly.
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-[18px]" data-stagger>

        <!-- 5. Secure sharing -->
        <div class="p-7 border border-line rounded-lg bg-paper bb-fade-up bb-lift">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-[10px] bg-amber-bg text-amber-deep border border-[oklch(0.86_0.07_90)] flex items-center justify-center shrink-0">
              <svg class="w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
            </div>
            <div>
              <h3 class="text-[18px] font-bold tracking-[-0.02em] mb-2 leading-tight">Share securely</h3>
              <p class="text-[13.5px] text-ink-2 leading-relaxed">
                Share with a link. The decryption key lives in the URL fragment — our servers never see it. Set a passphrase, an expiry date, or a maximum number of opens.
              </p>
            </div>
          </div>
        </div>

        <!-- 6. File preview -->
        <div class="p-7 border border-line rounded-lg bg-paper bb-fade-up bb-lift">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-[10px] bg-amber-bg text-amber-deep border border-[oklch(0.86_0.07_90)] flex items-center justify-center shrink-0">
              <svg class="w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            </div>
            <div>
              <h3 class="text-[18px] font-bold tracking-[-0.02em] mb-2 leading-tight">File preview — all in your browser</h3>
              <p class="text-[13.5px] text-ink-2 leading-relaxed mb-3">
                Preview documents, images, videos, PDFs, Markdown, code, and Office files — decrypted and rendered entirely in your browser. The server only ever sees ciphertext.
              </p>
              <div class="flex gap-2 flex-wrap">
                {['PDF', 'DOCX', 'XLSX', 'Images', 'Video', 'Markdown', 'Code'].map(t => (
                  <span class="inline-flex px-2.5 py-1 bg-paper-2 border border-line rounded-md font-mono text-[11px] text-ink-3">{t}</span>
                ))}
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       POWER USER FEATURES (7–8)
       ═══════════════════════════════════════════════════════════ -->
  <section class="px-8 py-20 bg-paper border-t border-line">
    <div class="max-w-[1100px] mx-auto">
      <div class="section-label text-center bb-fade-up">Power user features</div>
      <h2 class="text-[40px] font-bold tracking-[-0.025em] text-center mb-14 leading-tight bb-fade-up bb-delay-1">
        For users who care about details.
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-[18px]" data-stagger>

        <!-- 7. Version history -->
        <div class="p-7 border border-line rounded-lg bg-paper bb-fade-up bb-lift">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-[10px] bg-amber-bg text-amber-deep border border-[oklch(0.86_0.07_90)] flex items-center justify-center shrink-0">
              <svg class="w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/><line x1="12" y1="7" x2="12" y2="12"/><line x1="12" y1="12" x2="16" y2="14"/></svg>
            </div>
            <div>
              <h3 class="text-[18px] font-bold tracking-[-0.02em] mb-2 leading-tight">Version history</h3>
              <p class="text-[13.5px] text-ink-2 leading-relaxed">
                Every file keeps its full history. Accidentally overwrote something? Roll back to any previous version. Each version is independently encrypted with its own key.
              </p>
            </div>
          </div>
        </div>

        <!-- 8. Import from anywhere -->
        <div class="p-7 border border-line rounded-lg bg-paper bb-fade-up bb-lift">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-[10px] bg-amber-bg text-amber-deep border border-[oklch(0.86_0.07_90)] flex items-center justify-center shrink-0">
              <svg class="w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="8 17 12 21 16 17"/><line x1="12" y1="12" x2="12" y2="21"/><path d="M20.88 18.09A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.29"/></svg>
            </div>
            <div>
              <h3 class="text-[18px] font-bold tracking-[-0.02em] mb-2 leading-tight">Import from anywhere</h3>
              <p class="text-[13.5px] text-ink-2 leading-relaxed mb-3">
                Move from Google Drive or Dropbox in minutes. Beebeeb handles the import — your files arrive already encrypted in your new vault.
              </p>
              <div class="flex gap-2 flex-wrap">
                {['Google Drive', 'Dropbox'].map(s => (
                  <span class="inline-flex px-2.5 py-1 bg-paper-2 border border-line rounded-md font-mono text-[11px] text-ink-3">{s}</span>
                ))}
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       EU + OPEN SOURCE (dark banner)
       ═══════════════════════════════════════════════════════════ -->
  <section class="px-8 py-20 bg-ink text-paper border-t border-line relative overflow-hidden">
    <div class="absolute inset-0 opacity-[0.06]" style="background-image: radial-gradient(circle at 50% 50%, oklch(0.82 0.17 84 / 0.5) 1.5px, transparent 1.8px); background-size: 24px 24px;"></div>
    <div class="relative max-w-[1100px] mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

        <!-- 9. Made in Europe -->
        <div class="bb-fade-up">
          <div class="w-10 h-10 rounded-[10px] bg-amber text-ink flex items-center justify-center mb-5">
            <svg class="w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          </div>
          <h3 class="text-[22px] font-bold tracking-[-0.02em] mb-3 leading-tight">Made in Europe</h3>
          <p class="text-[14px] text-paper/70 leading-relaxed">
            Stored in Falkenstein, Germany. Operated from Wijchen, Netherlands by Initlabs B.V. Your data stays in the EU — subject to EU law, not the CLOUD Act. We name the city and the provider.
          </p>
          <div class="mt-4 flex gap-2 flex-wrap">
            {['Falkenstein, DE', 'Hetzner', 'GDPR', 'NIS2'].map(b => (
              <span class="inline-flex px-2.5 py-1 bg-paper/10 border border-paper/20 rounded-md font-mono text-[11px] text-paper/60">{b}</span>
            ))}
          </div>
        </div>

        <!-- 10. Open source -->
        <div class="bb-fade-up bb-delay-1">
          <div class="w-10 h-10 rounded-[10px] bg-amber text-ink flex items-center justify-center mb-5">
            <svg class="w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
          </div>
          <h3 class="text-[22px] font-bold tracking-[-0.02em] mb-3 leading-tight">Open source</h3>
          <p class="text-[14px] text-paper/70 leading-relaxed">
            Our client code is public. Audit the encryption. Verify our zero-knowledge claims. Trust, but verify — because "trust us" is not a security model.
          </p>
          <div class="mt-4">
            <a href="https://github.com/beebeeb-io" target="_blank" rel="noopener noreferrer"
               class="inline-flex items-center gap-2 px-4 py-2 bg-paper/10 border border-paper/20 rounded-md text-[13px] text-paper/80 hover:bg-paper/20 transition-colors no-underline">
              View on GitHub
              <svg class="w-[13px] h-[13px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       COMPARISON TABLE
       ═══════════════════════════════════════════════════════════ -->
  <section class="px-8 py-20 bg-paper-2 border-t border-line">
    <div class="max-w-[860px] mx-auto">
      <div class="section-label text-center bb-fade-up">How we compare</div>
      <h2 class="text-[40px] font-bold tracking-[-0.025em] text-center mb-12 leading-tight bb-fade-up bb-delay-1">
        Not all cloud storage is equal.
      </h2>
      <div class="rounded-xl border border-line overflow-hidden bb-fade-up">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="bg-paper-2 border-b border-line">
              <th class="px-5 py-3.5 text-[11px] font-semibold uppercase tracking-wider text-ink-3 w-[40%]">Feature</th>
              <th class="px-4 py-3.5 text-[12px] font-bold text-amber-deep text-center">Beebeeb</th>
              <th class="px-4 py-3.5 text-[11px] font-semibold text-ink-3 text-center">Google Drive</th>
              <th class="px-4 py-3.5 text-[11px] font-semibold text-ink-3 text-center">Dropbox</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-line">
            {[
              ['End-to-end encryption',   true,  false, false],
              ['Zero-knowledge (filenames encrypted)', true, false, false],
              ['EU data residency',       true,  false, false],
              ['Open-source client',      true,  false, false],
              ['No ad tracking',          true,  false, false],
              ['File preview in browser', true,  true,  true ],
              ['Photo backup',            true,  true,  true ],
              ['Version history',         true,  true,  true ],
            ].map(([label, bb, gd, db]) => (
              <tr class="bg-paper hover:bg-paper-2 transition-colors">
                <td class="px-5 py-3 text-[13px] text-ink">{label as string}</td>
                <td class="px-4 py-3 text-center">
                  {bb
                    ? <span class="inline-block w-5 h-5 rounded-full bg-amber/20 text-amber-deep text-[12px] leading-5 text-center font-bold">✓</span>
                    : <span class="text-ink-4 text-[14px]">—</span>}
                </td>
                <td class="px-4 py-3 text-center">
                  {gd
                    ? <span class="inline-block w-5 h-5 rounded-full bg-paper-2 text-ink-3 text-[12px] leading-5 text-center">✓</span>
                    : <span class="text-ink-4 text-[14px]">—</span>}
                </td>
                <td class="px-4 py-3 text-center">
                  {db
                    ? <span class="inline-block w-5 h-5 rounded-full bg-paper-2 text-ink-3 text-[12px] leading-5 text-center">✓</span>
                    : <span class="text-ink-4 text-[14px]">—</span>}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       CTA
       ═══════════════════════════════════════════════════════════ -->
  <CtaSection
    title="Ready to take control of your files?"
    title_highlight="Start free today."
    description="5 GB free. No credit card. Your encryption keys, your files, your rules."
    cta_primary_label="Create your vault"
    cta_primary_href="https://app.beebeeb.io/signup"
    cta_secondary_label="See pricing"
    cta_secondary_href="/pricing"
    dark_bg={true}
  />

</Base>
