---
import Base from '../layouts/base.astro';
import CtaSection from '../components/blocks/CtaSection.astro';
---

<Base
  title="Features — Beebeeb"
  description="End-to-end encrypted cloud storage with photo backup, secure sharing, file preview, version history, and cross-platform sync. Built in Europe. Zero-knowledge by architecture."
  path="/features"
>

  <!-- Hero -->
  <section class="feat-hero" style="background: linear-gradient(180deg, var(--amber-soft) 0%, var(--paper) 85%);">
    <div class="section-label bb-fade-up">What Beebeeb does</div>
    <h1 class="feat-hero-title bb-fade-up bb-delay-1">
      Everything you need in cloud storage.<br />
      <span class="feat-hero-accent">Nothing you don't.</span>
    </h1>
    <p class="feat-hero-desc bb-fade-up bb-delay-2">
      Beebeeb is a zero-knowledge encrypted vault for the files that matter. No ads, no tracking, no data mining. Just your files — private, fast, and always under your control.
    </p>
    <div class="feat-hero-cta bb-fade-up bb-delay-3">
      <a href="https://app.beebeeb.io/signup" class="btn btn-amber">Get started free</a>
      <a href="/pricing" class="btn btn-ghost">See pricing</a>
    </div>
  </section>

  <!-- Core features (1-4) -->
  <section class="feat-section">
    <div class="feat-container">
      <div class="section-label feat-center bb-fade-up">Core features</div>
      <h2 class="feat-heading feat-center bb-fade-up bb-delay-1">
        Built for privacy. Built to last.
      </h2>

      <div class="feat-grid" data-stagger>
        <!-- 1. End-to-end encrypted -->
        <div class="feat-card bb-fade-up">
          <div class="feat-card-row">
            <div class="feat-card-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <div>
              <h3 class="feat-card-title">End-to-end encrypted</h3>
              <p class="feat-card-desc">
                Your files are encrypted before they leave your device. We can't read them. Nobody can. Even under a court order, we have nothing useful to hand over.
              </p>
            </div>
          </div>
        </div>

        <!-- 2. Zero-knowledge architecture -->
        <div class="feat-card bb-fade-up">
          <div class="feat-card-row">
            <div class="feat-card-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
            </div>
            <div>
              <h3 class="feat-card-title">Zero-knowledge architecture</h3>
              <p class="feat-card-desc">
                We don't know what you store. Not the file names. Not the file types. Not even the thumbnails. The encryption key lives on your device and nowhere else.
              </p>
            </div>
          </div>
        </div>

        <!-- 3. Works everywhere -->
        <div class="feat-card bb-fade-up">
          <div class="feat-card-row">
            <div class="feat-card-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
            </div>
            <div>
              <h3 class="feat-card-title">Works everywhere</h3>
              <p class="feat-card-desc feat-card-desc--mb">
                Web, iOS, Android, desktop sync client, and CLI. Your files follow you across every device. One vault, all platforms.
              </p>
              <div class="feat-chip-row">
                {['Web', 'iOS', 'Android', 'Desktop', 'CLI'].map(p => (
                  <span class="feat-chip">{p}</span>
                ))}
              </div>
            </div>
          </div>
        </div>

        <!-- 4. Photo backup -->
        <div class="feat-card bb-fade-up">
          <div class="feat-card-row">
            <div class="feat-card-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
            </div>
            <div>
              <h3 class="feat-card-title">Automatic photo backup</h3>
              <p class="feat-card-desc">
                Your phone's photos, encrypted and backed up automatically in the background. Every memory, safe. No one at Beebeeb can ever see them.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Sharing + Preview -->
  <section class="feat-section feat-section--alt">
    <div class="feat-container">
      <div class="section-label feat-center bb-fade-up">Sharing and preview</div>
      <h2 class="feat-heading feat-center bb-fade-up bb-delay-1">
        Share safely. Preview instantly.
      </h2>

      <div class="feat-grid" data-stagger>
        <!-- 5. Secure sharing -->
        <div class="feat-card bb-fade-up">
          <div class="feat-card-row">
            <div class="feat-card-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
            </div>
            <div>
              <h3 class="feat-card-title">Share securely</h3>
              <p class="feat-card-desc">
                Share with a link. The decryption key lives in the URL fragment — our servers never see it. Set a passphrase, an expiry date, or a maximum number of opens.
              </p>
            </div>
          </div>
        </div>

        <!-- 6. File preview -->
        <div class="feat-card bb-fade-up">
          <div class="feat-card-row">
            <div class="feat-card-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            </div>
            <div>
              <h3 class="feat-card-title">File preview — all in your browser</h3>
              <p class="feat-card-desc feat-card-desc--mb">
                Preview documents, images, videos, PDFs, Markdown, code, and Office files — decrypted and rendered entirely in your browser. The server only ever sees ciphertext.
              </p>
              <div class="feat-chip-row">
                {['PDF', 'DOCX', 'XLSX', 'Images', 'Video', 'Markdown', 'Code'].map(t => (
                  <span class="feat-chip">{t}</span>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Power user features (7-8) -->
  <section class="feat-section">
    <div class="feat-container">
      <div class="section-label feat-center bb-fade-up">Power user features</div>
      <h2 class="feat-heading feat-center bb-fade-up bb-delay-1">
        For users who care about details.
      </h2>

      <div class="feat-grid" data-stagger>
        <!-- 7. Version history -->
        <div class="feat-card bb-fade-up">
          <div class="feat-card-row">
            <div class="feat-card-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/><line x1="12" y1="7" x2="12" y2="12"/><line x1="12" y1="12" x2="16" y2="14"/></svg>
            </div>
            <div>
              <h3 class="feat-card-title">Version history</h3>
              <p class="feat-card-desc">
                Every file keeps its full history. Accidentally overwrote something? Roll back to any previous version. Each version is independently encrypted with its own key.
              </p>
            </div>
          </div>
        </div>

        <!-- 8. Import from anywhere -->
        <div class="feat-card bb-fade-up">
          <div class="feat-card-row">
            <div class="feat-card-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="8 17 12 21 16 17"/><line x1="12" y1="12" x2="12" y2="21"/><path d="M20.88 18.09A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.29"/></svg>
            </div>
            <div>
              <h3 class="feat-card-title">Import from anywhere</h3>
              <p class="feat-card-desc feat-card-desc--mb">
                Move from Google Drive or Dropbox in minutes. Beebeeb handles the import — your files arrive already encrypted in your new vault.
              </p>
              <div class="feat-chip-row">
                {['Google Drive', 'Dropbox'].map(s => (
                  <span class="feat-chip">{s}</span>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- EU + Open source (dark banner) -->
  <section class="feat-dark-section">
    <div class="feat-dark-dots"></div>
    <div class="feat-dark-inner">
      <div class="feat-dark-grid">
        <!-- 9. Made in Europe -->
        <div class="bb-fade-up">
          <div class="feat-dark-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          </div>
          <h3 class="feat-dark-title">Made in Europe</h3>
          <p class="feat-dark-desc">
            Stored in Falkenstein, Germany. Operated from Wijchen, Netherlands by Initlabs B.V. Your data stays in the EU — subject to EU law, not the CLOUD Act. We name the city.
          </p>
          <div class="feat-dark-chips">
            {['Falkenstein, DE', 'GDPR', 'NIS2', 'EU-only'].map(b => (
              <span class="feat-dark-chip">{b}</span>
            ))}
          </div>
        </div>

        <!-- 10. Open source -->
        <div class="bb-fade-up bb-delay-1">
          <div class="feat-dark-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
          </div>
          <h3 class="feat-dark-title">Open source</h3>
          <p class="feat-dark-desc">
            Our client code is public. Audit the encryption. Verify our zero-knowledge claims. Trust, but verify — because "trust us" is not a security model.
          </p>
          <div class="feat-dark-gh">
            <a href="https://github.com/beebeeb-io" target="_blank" rel="noopener noreferrer" class="feat-dark-gh-link">
              View on GitHub
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Comparison table -->
  <section class="feat-compare-section">
    <div class="feat-compare-container">
      <div class="section-label feat-center bb-fade-up">How we compare</div>
      <h2 class="feat-heading feat-center bb-fade-up bb-delay-1">
        Not all cloud storage is equal.
      </h2>
      <div class="feat-table-wrap bb-fade-up">
        <table class="feat-table">
          <thead>
            <tr>
              <th class="feat-table-th feat-table-th--feature">Feature</th>
              <th class="feat-table-th feat-table-th--bb">Beebeeb</th>
              <th class="feat-table-th feat-table-th--them">Google Drive</th>
              <th class="feat-table-th feat-table-th--them">Dropbox</th>
            </tr>
          </thead>
          <tbody>
            {[
              ['End-to-end encryption',   true,  false, false],
              ['Zero-knowledge (filenames encrypted)', true, false, false],
              ['EU data residency',       true,  false, false],
              ['Open-source client',      true,  false, false],
              ['No ad tracking',          true,  false, false],
              ['File preview in browser', true,  true,  true ],
              ['Photo backup',            true,  true,  true ],
              ['Version history',         true,  true,  true ],
            ].map(([label, bb, gd, db]) => (
              <tr class="feat-table-row">
                <td class="feat-table-td feat-table-td--label">{label as string}</td>
                <td class="feat-table-td feat-table-td--center">
                  {bb
                    ? <span class="feat-table-yes">&#10003;</span>
                    : <span class="feat-table-no">&mdash;</span>}
                </td>
                <td class="feat-table-td feat-table-td--center">
                  {gd
                    ? <span class="feat-table-neutral">&#10003;</span>
                    : <span class="feat-table-no">&mdash;</span>}
                </td>
                <td class="feat-table-td feat-table-td--center">
                  {db
                    ? <span class="feat-table-neutral">&#10003;</span>
                    : <span class="feat-table-no">&mdash;</span>}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CtaSection
    title="Ready to take control of your files?"
    title_highlight="Start free today."
    description="5 GB free. No credit card. Your encryption keys, your files, your rules."
    cta_primary_label="Create your vault"
    cta_primary_href="https://app.beebeeb.io/signup"
    cta_secondary_label="See pricing"
    cta_secondary_href="/pricing"
    dark_bg={true}
  />

</Base>

<style>
  /* ── Hero ────────────────────────────────────────────────── */
  .feat-hero {
    padding: 72px 32px 64px;
    text-align: center;
    position: relative;
  }

  .feat-hero-title {
    font-size: 54px;
    line-height: 1.05;
    font-weight: 700;
    letter-spacing: -0.03em;
    margin-top: 14px;
    max-width: 860px;
    margin-left: auto;
    margin-right: auto;
  }

  .feat-hero-accent {
    color: var(--amber-deep);
  }

  .feat-hero-desc {
    font-size: 15px;
    color: var(--ink-2);
    margin-top: 22px;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.65;
  }

  .feat-hero-cta {
    display: flex;
    gap: 12px;
    justify-content: center;
    margin-top: 32px;
    flex-wrap: wrap;
  }

  /* ── Sections ───────────────────────────────────────────── */
  .feat-section {
    padding: 80px 32px;
    background: var(--paper);
    border-top: 1px solid var(--line);
  }

  .feat-section--alt {
    background: var(--paper-2);
  }

  .feat-container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .feat-center {
    text-align: center;
  }

  .feat-heading {
    font-size: 40px;
    font-weight: 700;
    letter-spacing: -0.025em;
    margin-bottom: 56px;
    line-height: 1.1;
  }

  /* ── Feature grid ───────────────────────────────────────── */
  .feat-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 18px;
  }

  .feat-card {
    padding: 28px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--paper);
  }

  .feat-card-row {
    display: flex;
    align-items: flex-start;
    gap: 16px;
  }

  .feat-card-icon {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: var(--amber-soft);
    color: var(--amber-deep);
    border: 1px solid oklch(0.86 0.07 90);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .feat-card-title {
    font-size: 18px;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 8px;
    line-height: 1.2;
  }

  .feat-card-desc {
    font-size: 13.5px;
    color: var(--ink-2);
    line-height: 1.65;
  }

  .feat-card-desc--mb {
    margin-bottom: 12px;
  }

  .feat-chip-row {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .feat-chip {
    display: inline-flex;
    padding: 4px 10px;
    background: var(--paper-2);
    border: 1px solid var(--line);
    border-radius: 6px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-3);
  }

  /* ── Dark section ───────────────────────────────────────── */
  .feat-dark-section {
    padding: 80px 32px;
    background: var(--ink);
    color: var(--paper);
    border-top: 1px solid var(--line);
    position: relative;
    overflow: hidden;
  }

  .feat-dark-dots {
    position: absolute;
    inset: 0;
    opacity: 0.06;
    background-image: radial-gradient(circle at 50% 50%, oklch(0.82 0.17 84 / 0.5) 1.5px, transparent 1.8px);
    background-size: 24px 24px;
  }

  .feat-dark-inner {
    position: relative;
    max-width: 1100px;
    margin: 0 auto;
  }

  .feat-dark-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 32px;
  }

  .feat-dark-icon {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: var(--amber);
    color: var(--ink);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
  }

  .feat-dark-title {
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 12px;
    line-height: 1.2;
  }

  .feat-dark-desc {
    font-size: 14px;
    color: oklch(0.985 0.004 85 / 0.7);
    line-height: 1.65;
  }

  .feat-dark-chips {
    margin-top: 16px;
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .feat-dark-chip {
    display: inline-flex;
    padding: 4px 10px;
    background: oklch(0.985 0.004 85 / 0.1);
    border: 1px solid oklch(0.985 0.004 85 / 0.2);
    border-radius: 6px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: oklch(0.985 0.004 85 / 0.6);
  }

  .feat-dark-gh {
    margin-top: 16px;
  }

  .feat-dark-gh-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    background: oklch(0.985 0.004 85 / 0.1);
    border: 1px solid oklch(0.985 0.004 85 / 0.2);
    border-radius: 6px;
    font-size: 13px;
    color: oklch(0.985 0.004 85 / 0.8);
    text-decoration: none;
    transition: background 150ms var(--ease);
  }

  .feat-dark-gh-link:hover {
    background: oklch(0.985 0.004 85 / 0.2);
  }

  /* ── Comparison table ───────────────────────────────────── */
  .feat-compare-section {
    padding: 80px 32px;
    background: var(--paper-2);
    border-top: 1px solid var(--line);
  }

  .feat-compare-container {
    max-width: 860px;
    margin: 0 auto;
  }

  .feat-table-wrap {
    border-radius: 12px;
    border: 1px solid var(--line);
    overflow: hidden;
  }

  .feat-table {
    width: 100%;
    text-align: left;
    border-collapse: collapse;
  }

  .feat-table-th {
    padding: 14px 20px;
    border-bottom: 1px solid var(--line);
    background: var(--paper-2);
  }

  .feat-table-th--feature {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--ink-3);
    width: 40%;
  }

  .feat-table-th--bb {
    font-size: 12px;
    font-weight: 700;
    color: var(--amber-deep);
    text-align: center;
  }

  .feat-table-th--them {
    font-size: 11px;
    font-weight: 600;
    color: var(--ink-3);
    text-align: center;
  }

  .feat-table-row {
    background: var(--paper);
    transition: background 150ms var(--ease);
  }

  .feat-table-row:hover {
    background: var(--paper-2);
  }

  .feat-table-td {
    padding: 12px 20px;
    border-bottom: 1px solid var(--line);
  }

  .feat-table-td--label {
    font-size: 13px;
    color: var(--ink);
  }

  .feat-table-td--center {
    text-align: center;
  }

  .feat-table-yes {
    display: inline-block;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: oklch(0.82 0.17 84 / 0.2);
    color: var(--amber-deep);
    font-size: 12px;
    line-height: 20px;
    text-align: center;
    font-weight: 700;
  }

  .feat-table-neutral {
    display: inline-block;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: var(--paper-2);
    color: var(--ink-3);
    font-size: 12px;
    line-height: 20px;
    text-align: center;
  }

  .feat-table-no {
    color: var(--ink-4);
    font-size: 14px;
  }

  /* ── Responsive ─────────────────────────────────────────── */
  @media (max-width: 760px) {
    .feat-hero-title {
      font-size: 42px;
    }

    .feat-heading {
      font-size: 32px;
    }

    .feat-grid {
      grid-template-columns: 1fr;
    }

    .feat-dark-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 560px) {
    .feat-hero {
      padding: 48px 20px 48px;
    }

    .feat-hero-title {
      font-size: 34px;
