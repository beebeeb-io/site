---
interface Props {
  title?: string;
  body?: string;
  [key: string]: unknown;
}

const { title, body } = Astro.props;
---

<section class="px-8 py-[72px] bg-paper">
  <div class="max-w-[760px] mx-auto">
    {title && <h1 class="text-[36px] font-bold tracking-[-0.02em] mb-8 bb-fade-up">{title}</h1>}
    {body && (
      <div class="prose prose-sm text-ink-2 leading-relaxed bb-fade-up bb-delay-1
        [&_h2]:text-[22px] [&_h2]:font-bold [&_h2]:text-ink [&_h2]:mt-10 [&_h2]:mb-4
        [&_h3]:text-[17px] [&_h3]:font-semibold [&_h3]:text-ink [&_h3]:mt-8 [&_h3]:mb-3
        [&_p]:mb-4 [&_ul]:mb-4 [&_ul]:pl-5 [&_li]:mb-1.5
        [&_a]:text-amber-deep [&_a]:underline [&_a]:underline-offset-2
        [&_strong]:text-ink [&_strong]:font-semibold"
        set:html={body}
      />
    )}
  </div>
</section>
