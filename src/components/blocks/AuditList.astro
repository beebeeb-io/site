---
interface Props {
  title?: string;
  description?: string;
  audits?: { firm: string; date: string; scope: string; result: string }[];
  cta_buttons?: { label: string; href: string }[];
  [key: string]: unknown;
}

const { title, description, audits = [], cta_buttons = [] } = Astro.props;
---

<section class="px-8 py-[72px] bg-paper">
  <div class="max-w-[900px] mx-auto">
    {title && <h2 class="text-[32px] font-bold tracking-[-0.02em] text-center mb-3 bb-fade-up">{title}</h2>}
    {description && <p class="text-sm text-ink-2 text-center max-w-[600px] mx-auto mb-8 bb-fade-up bb-delay-1">{description}</p>}

    {audits.length > 0 && (
      <div class="border border-line rounded-xl overflow-hidden mb-8 bb-reveal-scale bb-delay-2">
        <div class="grid grid-cols-4 gap-3.5 px-5 py-3 bg-paper-2 border-b border-line text-[10.5px] font-semibold tracking-[0.04em] uppercase text-ink-3">
          <span>Firm</span><span>Date</span><span>Scope</span><span>Result</span>
        </div>
        {audits.map((a) => (
          <div class="grid grid-cols-4 gap-3.5 px-5 py-3.5 border-b border-line last:border-b-0 text-[13px] text-ink-2">
            <span class="font-medium text-ink">{a.firm}</span>
            <span class="font-mono text-[11px]">{a.date}</span>
            <span>{a.scope}</span>
            <span>{a.result}</span>
          </div>
        ))}
      </div>
    )}

    {cta_buttons.length > 0 && (
      <div class="flex gap-2.5 justify-center bb-fade-up bb-delay-3">
        {cta_buttons.map((btn, i) => (
          <a href={btn.href} class:list={['btn btn-md', i === 0 ? 'btn-amber' : 'btn-outline']}>
            {btn.label}
          </a>
        ))}
      </div>
    )}
  </div>
</section>
