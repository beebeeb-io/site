---
interface Props {
  title?: string;
  description?: string;
  audits?: { firm: string; date: string; scope: string; result: string }[];
  cta_buttons?: { label: string; href: string }[];
  [key: string]: unknown;
}

const { title, description, audits = [], cta_buttons = [] } = Astro.props;
---

<section class="audit-list">
  <div class="audit-list-inner">
    {title && <h2 class="audit-list-title bb-fade-up">{title}</h2>}
    {description && <p class="audit-list-desc bb-fade-up bb-delay-1">{description}</p>}

    {audits.length > 0 && (
      <div class="audit-list-table bb-fade-up bb-delay-2">
        <div class="audit-list-header">
          <span>Firm</span><span>Date</span><span>Scope</span><span>Result</span>
        </div>
        {audits.map((a) => (
          <div class="audit-list-row">
            <span class="audit-list-firm">{a.firm}</span>
            <span class="audit-list-date">{a.date}</span>
            <span>{a.scope}</span>
            <span>{a.result}</span>
          </div>
        ))}
      </div>
    )}

    {cta_buttons.length > 0 && (
      <div class="audit-list-actions bb-fade-up bb-delay-3">
        {cta_buttons.map((btn, i) => (
          <a href={btn.href} class:list={['bb-cta', i === 0 ? 'amber' : 'ghost']}>
            {btn.label}
          </a>
        ))}
      </div>
    )}
  </div>
</section>

<style>
  .audit-list {
    padding: 72px 32px;
    background: var(--paper);
  }

  .audit-list-inner {
    max-width: 900px;
    margin: 0 auto;
  }

  .audit-list-title {
    font-size: 32px;
    font-weight: 700;
    letter-spacing: -0.02em;
    text-align: center;
    margin: 0 0 12px;
  }

  .audit-list-desc {
    font-size: 14px;
    color: var(--ink-2);
    text-align: center;
    max-width: 600px;
    margin: 0 auto 32px;
  }

  .audit-list-table {
    border: 1px solid var(--line);
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 32px;
  }

  .audit-list-header {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 14px;
    padding: 12px 20px;
    background: var(--paper-2);
    border-bottom: 1px solid var(--line);
    font-size: 10.5px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--ink-3);
  }

  .audit-list-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 14px;
    padding: 14px 20px;
    border-bottom: 1px solid var(--line);
    font-size: 13px;
    color: var(--ink-2);
  }

  .audit-list-row:last-child {
    border-bottom: none;
  }

  .audit-list-firm {
    font-weight: 500;
    color: var(--ink);
  }

  .audit-list-date {
    font-family: var(--font-mono);
    font-size: 11px;
  }

  .audit-list-actions {
    display: flex;
    gap: 10px;
    justify-content: center;
  }

  @media (max-width: 640px) {
    .audit-list-header,
    .audit-list-row {
      grid-template-columns: 1fr 1fr;
      gap: 8px;
    }
  }

  @media (max-width: 560px) {
    .audit-list {
      padding: 48px 20px;
    }
  }
</style>
