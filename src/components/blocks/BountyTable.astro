---
interface Props {
  title?: string;
  description?: string;
  tiers?: { severity: string; reward: string; criteria: string }[];
  rules?: string;
  [key: string]: unknown;
}

const { title, description, tiers = [], rules } = Astro.props;
---

<section class="bounty-table">
  <div class="bounty-table-inner">
    {title && <h2 class="bounty-table-title bb-fade-up">{title}</h2>}
    {description && <p class="bounty-table-desc bb-fade-up bb-delay-1">{description}</p>}

    {tiers.length > 0 && (
      <div class="bounty-table-grid bb-fade-up bb-delay-2">
        <div class="bounty-table-header">
          <span>Severity</span><span>Reward</span><span>Criteria</span>
        </div>
        {tiers.map((t) => (
          <div class="bounty-table-row">
            <span class="bounty-table-severity">{t.severity}</span>
            <span class="bounty-table-reward">{t.reward}</span>
            <span>{t.criteria}</span>
          </div>
        ))}
      </div>
    )}

    {rules && (
      <div class="bounty-table-rules bb-fade-up" set:html={rules} />
    )}
  </div>
</section>

<style>
  .bounty-table {
    padding: 72px 32px;
    background: var(--paper);
  }

  .bounty-table-inner {
    max-width: 900px;
    margin: 0 auto;
  }

  .bounty-table-title {
    font-size: 32px;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0 0 12px;
  }

  .bounty-table-desc {
    font-size: 14px;
    color: var(--ink-2);
    max-width: 600px;
    margin: 0 0 32px;
  }

  .bounty-table-grid {
    border: 1px solid var(--line);
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 40px;
  }

  .bounty-table-header {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
    padding: 12px 20px;
    background: var(--paper-2);
    border-bottom: 1px solid var(--line);
    font-size: 10.5px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--ink-3);
  }

  .bounty-table-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
    padding: 14px 20px;
    border-bottom: 1px solid var(--line);
    font-size: 13px;
    color: var(--ink-2);
  }

  .bounty-table-row:last-child {
    border-bottom: none;
  }

  .bounty-table-severity {
    font-weight: 500;
    color: var(--ink);
  }

  .bounty-table-reward {
    font-family: var(--font-mono);
    font-weight: 600;
    color: var(--amber-deep);
  }

  .bounty-table-rules {
    color: var(--ink-2);
    font-size: 14px;
    line-height: 1.7;
  }

  .bounty-table-rules :global(p) {
    margin: 0 0 12px;
  }

  .bounty-table-rules :global(ul) {
    margin: 0 0 16px;
    padding-left: 20px;
  }

  .bounty-table-rules :global(li) {
    margin-bottom: 6px;
  }

  @media (max-width: 640px) {
    .bounty-table-header,
    .bounty-table-row {
      grid-template-columns: 1fr;
      gap: 4px;
    }
  }

  @media (max-width: 560px) {
    .bounty-table {
      padding: 48px 20px;
    }
  }
</style>
