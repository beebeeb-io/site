---
interface Props {
  title?: string;
  description?: string;
  categories?: { icon?: string; title: string; description?: string; link_count?: number }[];
  [key: string]: unknown;
}

const { title, description, categories = [] } = Astro.props;
---

<section class="docs-grid">
  <div class="docs-grid-inner">
    {title && <h2 class="docs-grid-title bb-fade-up">{title}</h2>}
    {description && <p class="docs-grid-desc bb-fade-up bb-delay-1">{description}</p>}
    <div class="docs-grid-cards" data-stagger>
      {categories.map((cat) => (
        <div class="docs-grid-card bb-fade-up">
          <h3 class="docs-grid-card-title">{cat.title}</h3>
          {cat.description && <p class="docs-grid-card-desc">{cat.description}</p>}
          {cat.link_count && <span class="docs-grid-card-count">{cat.link_count} articles</span>}
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .docs-grid {
    padding: 72px 32px;
    background: var(--paper);
  }

  .docs-grid-inner {
    max-width: 1000px;
    margin: 0 auto;
  }

  .docs-grid-title {
    font-size: 32px;
    font-weight: 700;
    letter-spacing: -0.02em;
    text-align: center;
    margin: 0 0 12px;
  }

  .docs-grid-desc {
    font-size: 14px;
    color: var(--ink-2);
    text-align: center;
    max-width: 500px;
    margin: 0 auto 40px;
  }

  .docs-grid-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .docs-grid-card {
    padding: 24px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--paper);
    cursor: pointer;
    transition: border-color 150ms var(--ease), transform 150ms var(--ease);
  }

  .docs-grid-card:hover {
    border-color: var(--line-2);
    transform: translateY(-2px);
  }

  .docs-grid-card-title {
    font-size: 16px;
    font-weight: 600;
    margin: 0 0 8px;
  }

  .docs-grid-card-desc {
    font-size: 12.5px;
    color: var(--ink-2);
    line-height: 1.7;
    margin: 0 0 12px;
  }

  .docs-grid-card-count {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--ink-3);
  }

  @media (max-width: 760px) {
    .docs-grid-cards {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 560px) {
    .docs-grid {
      padding: 48px 20px;
    }

    .docs-grid-cards {
      grid-template-columns: 1fr;
    }
  }
</style>
