---
interface Props {
  body?: string;
  [key: string]: unknown;
}

const { body } = Astro.props;
---

{body && (
  <section class="rich-text">
    <div class="rich-text-inner bb-fade-up" set:html={body} />
  </section>
)}

<style>
  .rich-text {
    padding: 48px 32px;
    background: var(--paper);
  }

  .rich-text-inner {
    max-width: 760px;
    margin: 0 auto;
    color: var(--ink-2);
    line-height: 1.75;
    font-size: 15px;
  }

  .rich-text-inner :global(h2) {
    color: var(--ink);
    font-size: 22px;
    font-weight: 650;
    letter-spacing: -0.018em;
    margin: 36px 0 12px;
  }

  .rich-text-inner :global(h3) {
    color: var(--ink);
    font-size: 17px;
    font-weight: 650;
    margin: 28px 0 8px;
  }

  .rich-text-inner :global(p) {
    margin: 0 0 14px;
  }

  .rich-text-inner :global(ul),
  .rich-text-inner :global(ol) {
    margin: 0 0 16px;
    padding-left: 22px;
  }

  .rich-text-inner :global(li) {
    margin-bottom: 6px;
  }

  .rich-text-inner :global(a) {
    color: var(--amber-deep);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .rich-text-inner :global(strong) {
    color: var(--ink);
    font-weight: 650;
  }

  .rich-text-inner :global(code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
    padding: 2px 6px;
    background: var(--paper-2);
    border-radius: 4px;
  }

  .rich-text-inner :global(blockquote) {
    margin: 20px 0;
    padding: 12px 20px;
    border-left: 3px solid var(--amber);
    color: var(--ink-2);
    background: var(--paper-2);
    border-radius: 0 6px 6px 0;
  }

  @media (max-width: 560px) {
    .rich-text {
      padding: 32px 20px;
    }
  }
</style>
