---
interface Props {
  title?: string;
  subtitle?: string;
  primitives?: { label: string; value: string; description?: string }[];
  [key: string]: unknown;
}

const { title, subtitle, primitives = [] } = Astro.props;
---

<section class="px-8 py-[72px] bg-paper">
  <div class="max-w-[1000px] mx-auto">
    {title && <h2 class="text-[32px] font-bold tracking-[-0.02em] text-center mb-3 bb-fade-up">{title}</h2>}
    {subtitle && <p class="text-sm text-ink-2 text-center max-w-[600px] mx-auto mb-10 bb-fade-up bb-delay-1">{subtitle}</p>}
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4" data-stagger>
      {primitives.map((p) => (
        <div class="p-5 border border-line rounded-lg bg-paper bb-fade-up">
          <div class="font-mono text-[10px] text-ink-3 uppercase tracking-[0.06em] mb-1">{p.label}</div>
          <div class="text-lg font-bold tracking-tight mb-1">{p.value}</div>
          {p.description && <div class="text-[12px] text-ink-2 leading-relaxed">{p.description}</div>}
        </div>
      ))}
    </div>
  </div>
</section>
