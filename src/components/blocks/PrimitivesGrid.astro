---
interface Props {
  title?: string;
  subtitle?: string;
  primitives?: { label: string; value: string; description?: string }[];
  [key: string]: unknown;
}

const { title, subtitle, primitives = [] } = Astro.props;
---

<section class="primitives-grid">
  <div class="primitives-grid-inner">
    {title && <h2 class="primitives-grid-title bb-fade-up">{title}</h2>}
    {subtitle && <p class="primitives-grid-subtitle bb-fade-up bb-delay-1">{subtitle}</p>}
    <div class="primitives-grid-cards" data-stagger>
      {primitives.map((p) => (
        <div class="primitives-card bb-fade-up">
          <div class="primitives-card-label">{p.label}</div>
          <div class="primitives-card-value">{p.value}</div>
          {p.description && <div class="primitives-card-desc">{p.description}</div>}
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .primitives-grid {
    padding: 72px 32px;
    background: var(--paper);
  }

  .primitives-grid-inner {
    max-width: 1000px;
    margin: 0 auto;
  }

  .primitives-grid-title {
    font-size: 32px;
    font-weight: 700;
    letter-spacing: -0.02em;
    text-align: center;
    margin: 0 0 12px;
  }

  .primitives-grid-subtitle {
    font-size: 14px;
    color: var(--ink-2);
    text-align: center;
    max-width: 600px;
    margin: 0 auto 40px;
  }

  .primitives-grid-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .primitives-card {
    padding: 20px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--paper);
  }

  .primitives-card-label {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--ink-3);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 4px;
  }

  .primitives-card-value {
    font-size: 18px;
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-bottom: 4px;
  }

  .primitives-card-desc {
    font-size: 12px;
    color: var(--ink-2);
    line-height: 1.7;
  }

  @media (max-width: 760px) {
    .primitives-grid-cards {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 560px) {
    .primitives-grid {
      padding: 48px 20px;
    }
  }
</style>
