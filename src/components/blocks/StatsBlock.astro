---
interface StatItem {
  value: string;
  label: string;
}

interface Props {
  stats?: StatItem[];
  [key: string]: unknown;
}

const { stats = [] } = Astro.props;

const gridClass = stats.length <= 1
  ? 'stats-block-cols-1'
  : stats.length === 2
    ? 'stats-block-cols-2'
    : stats.length === 3
      ? 'stats-block-cols-3'
      : 'stats-block-cols-4';
---

{stats.length > 0 && (
  <section class="stats-block">
    <div class:list={['stats-block-grid', gridClass]}>
      {stats.map((stat, i) => (
        <div class:list={[
          'stats-block-card bb-fade-up',
          i === 1 ? 'bb-delay-1' : i === 2 ? 'bb-delay-2' : i === 3 ? 'bb-delay-3' : '',
        ]}>
          <div class="stats-block-value">
            {stat.value}
          </div>
          <div class="stats-block-label">
            {stat.label}
          </div>
        </div>
      ))}
    </div>
  </section>
)}

<style>
  .stats-block {
    padding: 72px 32px;
    background: var(--paper);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }

  .stats-block-grid {
    display: grid;
    gap: 24px;
    margin: 0 auto;
  }

  .stats-block-cols-1 {
    grid-template-columns: 1fr;
    max-width: 320px;
  }

  .stats-block-cols-2 {
    grid-template-columns: repeat(2, 1fr);
    max-width: 640px;
  }

  .stats-block-cols-3 {
    grid-template-columns: repeat(3, 1fr);
    max-width: 960px;
  }

  .stats-block-cols-4 {
    grid-template-columns: repeat(4, 1fr);
    max-width: 1100px;
  }

  .stats-block-card {
    text-align: center;
    padding: 28px;
    border: 1px solid var(--line);
    border-radius: 12px;
    background: var(--paper);
  }

  .stats-block-value {
    font-size: 40px;
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--ink);
    line-height: 1;
    margin-bottom: 8px;
  }

  .stats-block-label {
    font-size: 13px;
    color: var(--ink-3);
    line-height: 1.5;
  }

  @media (max-width: 760px) {
    .stats-block-cols-3,
    .stats-block-cols-4 {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 560px) {
    .stats-block {
      padding: 48px 20px;
    }

    .stats-block-cols-2,
    .stats-block-cols-3,
    .stats-block-cols-4 {
      grid-template-columns: 1fr;
    }
  }
</style>
