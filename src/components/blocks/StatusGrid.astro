---
interface Props {
  services?: { name: string; status: string }[];
  incidents?: { date: string; title: string; resolved: boolean }[];
  [key: string]: unknown;
}

const { services = [], incidents = [] } = Astro.props;
---

<section class="status-grid">
  <div class="status-grid-inner">
    {services.length > 0 && (
      <div class="status-grid-services" data-stagger>
        {services.map((s) => (
          <div class="status-grid-service bb-fade-up">
            <span class:list={[
              'status-grid-dot',
              s.status === 'operational' ? 'status-grid-dot--green' : s.status === 'degraded' ? 'status-grid-dot--amber' : 'status-grid-dot--red',
            ]}></span>
            <span class="status-grid-service-name">{s.name}</span>
            <span class="status-grid-service-status">{s.status}</span>
          </div>
        ))}
      </div>
    )}

    {incidents.length > 0 && (
      <div class="status-grid-incidents">
        <h3 class="status-grid-incidents-title bb-fade-up">Recent incidents</h3>
        <div class="status-grid-incidents-list">
          {incidents.map((inc) => (
            <div class="status-grid-incident bb-fade-up">
              <span class:list={['status-grid-dot-sm', inc.resolved ? 'status-grid-dot--green' : 'status-grid-dot--amber']}></span>
              <span class="status-grid-incident-title">{inc.title}</span>
              <time class="status-grid-incident-date">{inc.date}</time>
            </div>
          ))}
        </div>
      </div>
    )}
  </div>
</section>

<style>
  .status-grid {
    padding: 72px 32px;
    background: var(--paper);
  }

  .status-grid-inner {
    max-width: 900px;
    margin: 0 auto;
  }

  .status-grid-services {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    margin-bottom: 48px;
  }

  .status-grid-service {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px;
    border: 1px solid var(--line);
    border-radius: 8px;
  }

  .status-grid-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .status-grid-dot-sm {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .status-grid-dot--green {
    background: var(--green);
  }

  .status-grid-dot--amber {
    background: var(--amber);
  }

  .status-grid-dot--red {
    background: var(--red);
  }

  .status-grid-service-name {
    font-size: 13px;
    font-weight: 500;
  }

  .status-grid-service-status {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--ink-3);
    text-transform: capitalize;
  }

  .status-grid-incidents-title {
    font-size: 18px;
    font-weight: 600;
    margin: 0 0 16px;
  }

  .status-grid-incidents-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .status-grid-incident {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px;
    border: 1px solid var(--line);
    border-radius: 8px;
  }

  .status-grid-incident-title {
    font-size: 13px;
  }

  .status-grid-incident-date {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--ink-3);
  }

  @media (max-width: 760px) {
    .status-grid-services {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 560px) {
    .status-grid {
      padding: 48px 20px;
    }
  }
</style>
