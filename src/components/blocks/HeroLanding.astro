---
interface Props {
  title?: string;
  title_highlight?: string;
  subtitle?: string;
  announcement?: string;
  cta_primary_label?: string;
  cta_primary_href?: string;
  cta_secondary_label?: string;
  cta_secondary_href?: string;
  trust_badges?: string[];
  [key: string]: unknown;
}

const {
  title,
  title_highlight,
  subtitle,
  announcement,
  cta_primary_label,
  cta_primary_href,
  cta_secondary_label,
  cta_secondary_href,
  trust_badges,
} = Astro.props;
---

<section class="hero-landing">
  <div class="hero-landing-dots"></div>
  <div class="hero-landing-glow"></div>

  <div class="hero-landing-inner">
    {announcement && (
      <div class="hero-landing-announcement bb-fade-up">
        <div class="hero-landing-announcement-pill">
          <span class="hero-landing-announcement-badge">New</span>
          <span class="hero-landing-announcement-text">{announcement}</span>
        </div>
      </div>
    )}

    <h1 class="hero-landing-title bb-fade-up bb-delay-1">
      {title && <Fragment set:html={title} />}
      {title_highlight && (
        <Fragment>
          <br />
          <span class="hero-landing-highlight">{title_highlight}</span>
        </Fragment>
      )}
    </h1>

    {subtitle && (
      <p class="hero-landing-subtitle bb-fade-up bb-delay-2">
        {subtitle}
      </p>
    )}

    <div class="hero-landing-actions bb-fade-up bb-delay-3">
      {cta_primary_label && cta_primary_href && (
        <a href={cta_primary_href} class="bb-cta amber">
          {cta_primary_label}
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </a>
      )}
      {cta_secondary_label && cta_secondary_href && (
        <a href={cta_secondary_href} class="bb-cta ghost">
          {cta_secondary_label}
        </a>
      )}
    </div>

    {trust_badges && trust_badges.length > 0 && (
      <div class="hero-landing-badges bb-fade-up bb-delay-3">
        {trust_badges.map((badge: string) => (
          <span class="hero-landing-badge">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            {badge}
          </span>
        ))}
      </div>
    )}
  </div>
</section>

<style>
  .hero-landing {
    position: relative;
    overflow: hidden;
    padding: 72px 32px 48px;
    text-align: center;
  }

  .hero-landing-dots {
    position: absolute;
    inset: 0;
    opacity: 0.35;
    background-image: radial-gradient(circle at 2px 2px, oklch(0.85 0.04 85 / 0.5) 1px, transparent 1px);
    background-size: 24px 24px;
  }

  .hero-landing-glow {
    position: absolute;
    top: 40px;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 300px;
    border-radius: 50%;
    filter: blur(40px);
    background: radial-gradient(circle, oklch(0.92 0.1 85 / 0.45), transparent 70%);
    pointer-events: none;
  }

  .hero-landing-inner {
    position: relative;
    max-width: 880px;
    margin: 0 auto;
  }

  .hero-landing-announcement {
    display: flex;
    justify-content: center;
    margin-bottom: 24px;
  }

  .hero-landing-announcement-pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 5px 12px 5px 5px;
    background: var(--paper);
    border: 1px solid var(--line-2);
    border-radius: 999px;
    box-shadow: var(--shadow-1);
  }

  .hero-landing-announcement-badge {
    padding: 2px 8px;
    background: var(--ink);
    color: var(--amber);
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-weight: 600;
  }

  .hero-landing-announcement-text {
    font-size: 12px;
    color: var(--ink-2);
  }

  .hero-landing-title {
    font-size: 64px;
    line-height: 1.02;
    letter-spacing: -0.035em;
    font-weight: 700;
    margin: 0 0 20px;
  }

  .hero-landing-highlight {
    color: var(--amber-deep);
  }

  .hero-landing-subtitle {
    font-size: 17px;
    color: var(--ink-2);
    max-width: 620px;
    margin: 0 auto 28px;
    line-height: 1.7;
  }

  .hero-landing-actions {
    display: flex;
    gap: 10px;
    justify-content: center;
    margin-bottom: 18px;
  }

  .hero-landing-badges {
    display: flex;
    gap: 14px;
    justify-content: center;
    font-size: 12px;
    color: var(--ink-3);
  }

  .hero-landing-badge {
    display: flex;
    align-items: center;
    gap: 5px;
    color: var(--ink-3);
  }

  .hero-landing-badge svg {
    color: oklch(0.55 0.12 155);
  }

  @media (max-width: 760px) {
    .hero-landing-title {
      font-size: clamp(36px, 7vw, 64px);
    }
  }

  @media (max-width: 560px) {
    .hero-landing {
      padding: 48px 20px 32px;
    }

    .hero-landing-actions {
      flex-direction: column;
      align-items: center;
    }

    .hero-landing-badges {
      flex-wrap: wrap;
    }
  }
</style>
