---
interface Props {
  title?: string;
  title_highlight?: string;
  subtitle?: string;
  announcement?: string;
  cta_primary_label?: string;
  cta_primary_href?: string;
  cta_secondary_label?: string;
  cta_secondary_href?: string;
  trust_badges?: string[];
  [key: string]: unknown;
}

const {
  title,
  title_highlight,
  subtitle,
  announcement,
  cta_primary_label,
  cta_primary_href,
  cta_secondary_label,
  cta_secondary_href,
  trust_badges,
} = Astro.props;
---

<section class="relative overflow-hidden px-8 pt-[72px] pb-12 text-center">
  <div class="absolute inset-0 opacity-35" style="background-image: radial-gradient(circle at 2px 2px, oklch(0.85 0.04 85 / 0.5) 1px, transparent 1px); background-size: 24px 24px;"></div>
  <div class="absolute top-10 left-1/2 -translate-x-1/2 w-[600px] h-[300px] rounded-full blur-[40px]" style="background: radial-gradient(circle, oklch(0.92 0.1 85 / 0.45), transparent 70%);"></div>

  <div class="relative max-w-[880px] mx-auto">
    {announcement && (
      <div class="flex justify-center mb-6 bb-fade-up">
        <div class="inline-flex items-center gap-2 py-[5px] pl-[5px] pr-3 bg-paper border border-line-2 rounded-full shadow-1">
          <span class="px-2 py-0.5 bg-ink text-amber rounded-full font-mono text-[10px] tracking-[0.06em] uppercase font-semibold">New</span>
          <span class="text-xs text-ink-2">{announcement}</span>
        </div>
      </div>
    )}

    <h1 class="text-[64px] leading-[1.02] tracking-[-0.035em] font-bold mb-5 bb-fade-up bb-delay-1">
      {title && <Fragment set:html={title} />}
      {title_highlight && (
        <Fragment>
          <br />
          <span class="text-amber-deep">{title_highlight}</span>
        </Fragment>
      )}
    </h1>

    {subtitle && (
      <p class="text-[17px] text-ink-2 max-w-[620px] mx-auto mb-7 leading-relaxed bb-fade-up bb-delay-2">
        {subtitle}
      </p>
    )}

    <div class="flex gap-2.5 justify-center mb-[18px] bb-fade-up bb-delay-3">
      {cta_primary_label && cta_primary_href && (
        <a href={cta_primary_href} class="btn btn-amber btn-lg">
          {cta_primary_label}
          <svg class="w-[13px] h-[13px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </a>
      )}
      {cta_secondary_label && cta_secondary_href && (
        <a href={cta_secondary_href} class="btn btn-outline btn-lg">
          {cta_secondary_label}
        </a>
      )}
    </div>

    {trust_badges && trust_badges.length > 0 && (
      <div class="flex gap-3.5 justify-center text-xs text-ink-3 bb-fade-up bb-delay-4">
        {trust_badges.map((badge: string) => (
          <span class="flex items-center gap-[5px]">
            <svg class="w-[11px] h-[11px] text-[oklch(0.55_0.12_155)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            {badge}
          </span>
        ))}
      </div>
    )}
  </div>
</section>
