---
interface Props {
  label?: string;
  quote?: string;
  author_name?: string;
  author_title?: string;
  author_initials?: string;
  [key: string]: unknown;
}

const { label, quote, author_name, author_title, author_initials } = Astro.props;
---

<section class="founder-quote">
  <div class="founder-quote-inner">
    {label && <div class="section-label founder-quote-label bb-fade-up">{label}</div>}
    {quote && (
      <blockquote class="founder-quote-text bb-fade-up bb-delay-1">
        "{quote}"
      </blockquote>
    )}
    <div class="founder-quote-attribution bb-fade-up bb-delay-2">
      <div class="founder-quote-author">
        {author_initials && (
          <div class="founder-quote-avatar">{author_initials}</div>
        )}
        <div class="founder-quote-author-info">
          {author_name && <div class="founder-quote-name">{author_name}</div>}
          {author_title && <div class="founder-quote-role">{author_title}</div>}
        </div>
      </div>
      <div class="founder-quote-divider"></div>
      <span class="founder-quote-brand">beebeeb.io</span>
    </div>
  </div>
</section>

<style>
  .founder-quote {
    padding: 72px 32px;
    background: var(--paper);
  }

  .founder-quote-inner {
    max-width: 780px;
    margin: 0 auto;
    text-align: center;
  }

  .founder-quote-label {
    text-align: center;
  }

  .founder-quote-text {
    font-size: 22px;
    line-height: 1.7;
    color: var(--ink-2);
    letter-spacing: -0.015em;
    font-style: italic;
    margin: 0 0 28px;
  }

  .founder-quote-attribution {
    display: flex;
    gap: 16px;
    justify-content: center;
    align-items: center;
  }

  .founder-quote-author {
    display: flex;
    gap: 10px;
    align-items: center;
  }

  .founder-quote-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--amber);
    font-weight: 700;
    font-size: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .founder-quote-author-info {
    text-align: left;
  }

  .founder-quote-name {
    font-size: 13px;
    font-weight: 600;
  }

  .founder-quote-role {
    font-size: 11px;
    color: var(--ink-3);
  }

  .founder-quote-divider {
    width: 1px;
    height: 24px;
    background: var(--line-2);
  }

  .founder-quote-brand {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-3);
  }

  @media (max-width: 560px) {
    .founder-quote {
      padding: 48px 20px;
    }

    .founder-quote-text {
      font-size: 18px;
    }
  }
</style>
