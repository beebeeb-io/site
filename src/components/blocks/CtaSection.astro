---
interface Props {
  title?: string;
  title_highlight?: string;
  description?: string;
  cta_primary_label?: string;
  cta_primary_href?: string;
  cta_secondary_label?: string;
  cta_secondary_href?: string;
  dark_bg?: boolean;
  [key: string]: unknown;
}

const {
  title, title_highlight, description,
  cta_primary_label, cta_primary_href,
  cta_secondary_label, cta_secondary_href,
  dark_bg = false,
} = Astro.props;
---

<section class:list={[
  'relative px-8 py-[72px] overflow-hidden',
  dark_bg ? 'bg-ink text-paper' : 'bg-paper',
]}>
  {dark_bg && (
    <div class="absolute inset-0 opacity-[0.08]" style="background-image: radial-gradient(circle at 50% 50%, oklch(0.82 0.17 84 / 0.5) 1.5px, transparent 1.8px); background-size: 24px 24px;"></div>
  )}

  <div class="relative max-w-[780px] mx-auto text-center">
    <h2 class="text-[44px] leading-[1.05] tracking-[-0.03em] font-bold mb-4 bb-fade-up">
      {title && <Fragment set:html={title} />}
      {title_highlight && (
        <Fragment>
          <br />
          <span class:list={[dark_bg ? 'text-amber' : 'text-amber-deep']}>{title_highlight}</span>
        </Fragment>
      )}
    </h2>
    {description && (
      <p class:list={[
        'text-[15px] max-w-[520px] mx-auto mb-7 leading-relaxed bb-fade-up bb-delay-1',
        dark_bg ? 'text-[oklch(0.78_0.01_80)]' : 'text-ink-2',
      ]}>
        {description}
      </p>
    )}
    <div class="flex gap-2.5 justify-center bb-fade-up bb-delay-2">
      {cta_primary_label && cta_primary_href && (
        <a href={cta_primary_href} class="btn btn-amber btn-lg">
          {cta_primary_label}
          <svg class="w-[13px] h-[13px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </a>
      )}
      {cta_secondary_label && cta_secondary_href && (
        <a href={cta_secondary_href} class:list={[
          'btn btn-lg',
          dark_bg ? 'btn-outline border-[oklch(0.35_0.01_70)] text-paper hover:border-[oklch(0.5_0.01_70)]' : 'btn-outline',
        ]}>
          {cta_secondary_label}
        </a>
      )}
    </div>
  </div>
</section>
