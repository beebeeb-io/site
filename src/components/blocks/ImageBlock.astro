---
import { strapiImage } from '../../lib/strapi';

interface Props {
  image?: { url?: string; alternativeText?: string } | null;
  caption?: string;
  mode?: 'contained' | 'full-width';
  [key: string]: unknown;
}

const { image, caption, mode = 'contained' } = Astro.props;

const src = image?.url ? strapiImage(image.url) : '';
const alt = image?.alternativeText || '';
---

{src && (
  <section class:list={[
    'image-block',
    mode === 'full-width' ? 'image-block--full' : 'image-block--contained',
  ]}>
    <div class:list={[
      'image-block-inner',
      mode === 'full-width' ? 'image-block-inner--full' : 'image-block-inner--contained',
    ]}>
      <figure class="image-block-figure">
        <img
          src={src}
          alt={alt}
          class:list={[
            'image-block-img',
            mode === 'full-width' ? 'image-block-img--full' : '',
          ]}
          loading="lazy"
          decoding="async"
        />
        {caption && (
          <figcaption class:list={[
            'image-block-caption',
            mode === 'full-width' ? 'image-block-caption--full' : '',
          ]}>
            {caption}
          </figcaption>
        )}
      </figure>
    </div>
  </section>
)}

<style>
  .image-block {
    background: var(--paper);
  }

  .image-block--contained {
    padding: 0 32px;
  }

  .image-block--full {
    padding: 0;
  }

  .image-block-inner {
    padding: 40px 0;
    margin: 0 auto;
  }

  .image-block-inner--contained {
    max-width: 1200px;
  }

  .image-block-inner--full {
    max-width: 100%;
  }

  .image-block-figure {
    margin: 0;
  }

  .image-block-img {
    width: 100%;
    border-radius: 8px;
  }

  .image-block-img--full {
    border-radius: 0;
  }

  .image-block-caption {
    font-size: 12px;
    color: var(--ink-3);
    margin-top: 12px;
    text-align: center;
  }

  .image-block-caption--full {
    padding: 0 32px;
  }

  @media (max-width: 560px) {
    .image-block--contained {
      padding: 0 20px;
    }
  }
</style>
