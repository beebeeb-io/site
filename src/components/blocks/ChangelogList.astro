---
import { fetchChangelogEntries } from '../../lib/strapi';

interface Props {
  title?: string;
  [key: string]: unknown;
}

const { title } = Astro.props;

let entries: any[] = [];
try {
  entries = await fetchChangelogEntries();
} catch {
  entries = [];
}
---

<section class="px-8 py-[72px] bg-paper">
  <div class="max-w-[760px] mx-auto">
    {title && <h2 class="text-[32px] font-bold tracking-[-0.02em] mb-10 bb-fade-up">{title}</h2>}
    <div class="space-y-8">
      {entries.map((entry: any) => (
        <article class="border-b border-line pb-8 bb-fade-up">
          <div class="flex items-center gap-3 mb-3">
            <time class="font-mono text-[11px] text-ink-3">{entry.date}</time>
            {entry.tags?.map((tag: string) => (
              <span class="px-2 py-0.5 bg-amber-bg border border-[oklch(0.86_0.07_90)] text-amber-deep rounded font-mono text-[10px] font-medium">{tag}</span>
            ))}
          </div>
          <h3 class="text-lg font-semibold mb-2">{entry.title}</h3>
          {entry.body && <div class="text-[13.5px] text-ink-2 leading-relaxed" set:html={entry.body} />}
        </article>
      ))}
      {entries.length === 0 && (
        <p class="text-ink-3 text-center">No changelog entries yet.</p>
      )}
    </div>
  </div>
</section>
