---
interface PillarItem {
  number?: string;
  icon?: string;
  title: string;
  description?: string;
  stat?: string;
}

interface Props {
  label?: string;
  title?: string;
  pillars?: PillarItem[];
  [key: string]: unknown;
}

const { label, title, pillars = [] } = Astro.props;

const iconMap: Record<string, string> = {
  shield: '<svg class="w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>',
  cloud: '<svg class="w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"/></svg>',
  users: '<svg class="w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>',
  key: '<svg class="w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="m21 2-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0 3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg>',
};
---

<section class="px-8 py-20 bg-paper">
  <div class="max-w-[1100px] mx-auto">
    {label && <div class="section-label text-center bb-fade-up">{label}</div>}
    {title && <h2 class="text-[40px] font-bold tracking-[-0.025em] text-center mb-14 leading-tight bb-fade-up bb-delay-1">{title}</h2>}
    <div class="grid grid-cols-1 md:grid-cols-2 gap-[18px]" data-stagger>
      {pillars.map((pillar) => (
        <div class="p-7 border border-line rounded-lg bg-paper relative overflow-hidden bb-fade-up bb-lift">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-[10px] bg-amber-bg text-amber-deep border border-[oklch(0.86_0.07_90)] flex items-center justify-center shrink-0">
              <Fragment set:html={iconMap[pillar.icon || 'shield'] || iconMap.shield} />
            </div>
            <div class="flex-1">
              {pillar.number && <div class="font-mono text-[10.5px] text-ink-4 tracking-[0.08em] mb-1">{pillar.number}</div>}
              <h3 class="text-xl font-bold tracking-[-0.02em] mb-2 leading-tight">{pillar.title}</h3>
              {pillar.description && <p class="text-[13.5px] text-ink-2 leading-relaxed mb-3.5">{pillar.description}</p>}
              {pillar.stat && <span class="inline-flex px-2.5 py-1 bg-paper-2 border border-line rounded-md font-mono text-[11px] text-ink-3">{pillar.stat}</span>}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
