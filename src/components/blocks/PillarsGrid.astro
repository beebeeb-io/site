---
interface PillarItem {
  number?: string;
  icon?: string;
  title: string;
  description?: string;
  stat?: string;
}

interface Props {
  label?: string;
  title?: string;
  pillars?: PillarItem[];
  [key: string]: unknown;
}

const { label, title, pillars = [] } = Astro.props;

const iconMap: Record<string, string> = {
  shield: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>',
  cloud: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"/></svg>',
  users: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>',
  key: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="m21 2-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0 3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg>',
};
---

<section class="pillars-grid">
  <div class="pillars-grid-inner">
    {label && <div class="section-label pillars-grid-label bb-fade-up">{label}</div>}
    {title && <h2 class="pillars-grid-title bb-fade-up bb-delay-1">{title}</h2>}
    <div class="pillars-grid-cards" data-stagger>
      {pillars.map((pillar) => (
        <div class="pillars-card bb-fade-up">
          <div class="pillars-card-header">
            <div class="pillars-card-icon">
              <Fragment set:html={iconMap[pillar.icon || 'shield'] || iconMap.shield} />
            </div>
            <div class="pillars-card-body">
              {pillar.number && <div class="pillars-card-number">{pillar.number}</div>}
              <h3 class="pillars-card-title">{pillar.title}</h3>
              {pillar.description && <p class="pillars-card-desc">{pillar.description}</p>}
              {pillar.stat && <span class="pillars-card-stat">{pillar.stat}</span>}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .pillars-grid {
    padding: 80px 32px;
    background: var(--paper);
  }

  .pillars-grid-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .pillars-grid-label {
    text-align: center;
  }

  .pillars-grid-title {
    font-size: 40px;
    font-weight: 700;
    letter-spacing: -0.025em;
    text-align: center;
    margin: 0 0 56px;
    line-height: 1.1;
  }

  .pillars-grid-cards {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 18px;
  }

  .pillars-card {
    padding: 28px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--paper);
    position: relative;
    overflow: hidden;
    transition: border-color 150ms var(--ease), transform 150ms var(--ease);
  }

  .pillars-card:hover {
    border-color: var(--line-2);
    transform: translateY(-2px);
  }

  .pillars-card-header {
    display: flex;
    align-items: flex-start;
    gap: 16px;
  }

  .pillars-card-icon {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: var(--amber-soft);
    color: var(--amber-deep);
    border: 1px solid oklch(0.86 0.07 90);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .pillars-card-body {
    flex: 1;
  }

  .pillars-card-number {
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--ink-4);
    letter-spacing: 0.08em;
    margin-bottom: 4px;
  }

  .pillars-card-title {
    font-size: 20px;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0 0 8px;
    line-height: 1.2;
  }

  .pillars-card-desc {
    font-size: 13.5px;
    color: var(--ink-2);
    line-height: 1.7;
    margin: 0 0 14px;
  }

  .pillars-card-stat {
    display: inline-flex;
    padding: 4px 10px;
    background: var(--paper-2);
    border: 1px solid var(--line);
    border-radius: 6px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-3);
  }

  @media (max-width: 760px) {
    .pillars-grid-cards {
      grid-template-columns: 1fr;
    }

    .pillars-grid-title {
      font-size: clamp(28px, 4vw, 40px);
    }
  }

  @media (max-width: 560px) {
    .pillars-grid {
      padding: 48px 20px;
    }
  }
</style>
