---
interface Props {
  quote?: string;
  author_name?: string;
  author_role?: string;
  author_company?: string;
  [key: string]: unknown;
}

const { quote, author_name, author_role, author_company } = Astro.props;
---

{quote && (
  <section class="testimonial-block">
    <div class="testimonial-block-inner">
      <svg class="testimonial-block-quote-icon bb-fade-up" width="40" height="40" viewBox="0 0 24 24" fill="currentColor">
        <path d="M4.583 17.321C3.553 16.227 3 15 3 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 0 1-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179zm10 0C13.553 16.227 13 15 13 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 0 1-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179z"/>
      </svg>

      <blockquote class="testimonial-block-text bb-fade-up bb-delay-1">
        &ldquo;{quote}&rdquo;
      </blockquote>

      <div class="testimonial-block-author bb-fade-up bb-delay-2">
        {author_name && (
          <div class="testimonial-block-name">{author_name}</div>
        )}
        {(author_role || author_company) && (
          <div class="testimonial-block-role">
            {author_role}{author_role && author_company && <span> &middot; </span>}{author_company}
          </div>
        )}
      </div>
    </div>
  </section>
)}

<style>
  .testimonial-block {
    padding: 72px 32px;
    background: var(--paper);
  }

  .testimonial-block-inner {
    max-width: 780px;
    margin: 0 auto;
    text-align: center;
  }

  .testimonial-block-quote-icon {
    margin: 0 auto 24px;
    color: oklch(0.78 0.14 78 / 0.3);
  }

  .testimonial-block-text {
    font-size: 22px;
    line-height: 1.7;
    color: var(--ink-2);
    letter-spacing: -0.015em;
    font-style: italic;
    margin: 0 0 32px;
  }

  .testimonial-block-name {
    font-size: 14px;
    font-weight: 600;
    color: var(--ink);
  }

  .testimonial-block-role {
    font-size: 12px;
    color: var(--ink-3);
    margin-top: 4px;
  }

  @media (max-width: 560px) {
    .testimonial-block {
      padding: 48px 20px;
    }

    .testimonial-block-text {
      font-size: 18px;
    }
  }
</style>
