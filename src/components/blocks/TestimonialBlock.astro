---
interface Props {
  quote?: string;
  author_name?: string;
  author_role?: string;
  author_company?: string;
  [key: string]: unknown;
}

const { quote, author_name, author_role, author_company } = Astro.props;
---

{quote && (
  <section class="px-8 py-[72px] bg-paper">
    <div class="max-w-[780px] mx-auto text-center">
      <!-- Quote icon -->
      <svg class="w-10 h-10 mx-auto mb-6 text-amber-deep/30 bb-fade-up" viewBox="0 0 24 24" fill="currentColor">
        <path d="M4.583 17.321C3.553 16.227 3 15 3 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 0 1-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179zm10 0C13.553 16.227 13 15 13 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 0 1-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179z"/>
      </svg>

      <!-- Quote text -->
      <blockquote class="text-[22px] leading-relaxed text-ink-2 tracking-[-0.015em] italic mb-8 bb-fade-up bb-delay-1">
        &ldquo;{quote}&rdquo;
      </blockquote>

      <!-- Author attribution -->
      <div class="bb-fade-up bb-delay-2">
        {author_name && (
          <div class="text-[14px] font-semibold text-ink">{author_name}</div>
        )}
        {(author_role || author_company) && (
          <div class="text-[12px] text-ink-3 mt-1">
            {author_role}{author_role && author_company && <span> &middot; </span>}{author_company}
          </div>
        )}
      </div>
    </div>
  </section>
)}
