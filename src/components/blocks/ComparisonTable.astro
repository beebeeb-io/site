---
interface Props {
  label?: string;
  title?: string;
  columns?: { name: string; highlight?: boolean }[];
  rows?: [string, ...string[]][];
  footnote?: string;
  [key: string]: unknown;
}

const { label, title, columns = [], rows = [], footnote } = Astro.props;
---

<section class="comparison-table">
  <div class="comparison-table-inner">
    {label && <div class="section-label comparison-table-label bb-fade-up">{label}</div>}
    {title && <h2 class="comparison-table-title bb-fade-up bb-delay-1">{title}</h2>}

    <div class="comparison-table-wrap bb-fade-up bb-delay-2">
      <div class="comparison-table-header" style={`grid-template-columns: 2fr repeat(${columns.length}, 1fr)`}>
        <span></span>
        {columns.map((col) => (
          <div class="comparison-table-col-header">
            {col.highlight ? (
              <Fragment>
                <span class="comparison-table-brand">beebeeb<span class="comparison-table-brand-dot">.io</span></span>
                <br /><span class="comparison-table-col-name-bold">{col.name}</span>
              </Fragment>
            ) : (
              <span class="comparison-table-col-name">{col.name}</span>
            )}
          </div>
        ))}
      </div>

      {rows.map((row, i) => (
        <div class:list={['comparison-table-row', i < rows.length - 1 && 'comparison-table-row-bordered']} style={`grid-template-columns: 2fr repeat(${columns.length}, 1fr)`}>
          <span class="comparison-table-feature">{row[0]}</span>
          {row.slice(1).map((val: string) => (
            <div class="comparison-table-cell">
              {val === 'y' ? (
                <span class="comparison-table-check">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                </span>
              ) : val === 'n' ? (
                <span class="comparison-table-dash">&mdash;</span>
              ) : (
                <span class="comparison-table-value">{val}</span>
              )}
            </div>
          ))}
        </div>
      ))}
    </div>

    {footnote && (
      <p class="comparison-table-footnote">{footnote}</p>
    )}
  </div>
</section>

<style>
  .comparison-table {
    padding: 72px 32px;
    background: var(--paper-2);
    border-top: 1px solid var(--line);
  }

  .comparison-table-inner {
    max-width: 1000px;
    margin: 0 auto;
  }

  .comparison-table-label {
    text-align: center;
  }

  .comparison-table-title {
    font-size: 40px;
    font-weight: 700;
    letter-spacing: -0.025em;
    text-align: center;
    margin: 0 0 36px;
    line-height: 1.1;
  }

  .comparison-table-wrap {
    border: 1px solid var(--line);
    border-radius: 12px;
    background: var(--paper);
    overflow: hidden;
  }

  .comparison-table-header {
    display: grid;
    gap: 14px;
    padding: 14px 22px;
    background: var(--paper);
    border-bottom: 1px solid var(--line);
  }

  .comparison-table-col-header {
    text-align: center;
  }

  .comparison-table-brand {
    font-size: 15px;
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  .comparison-table-brand-dot {
    color: var(--amber);
  }

  .comparison-table-col-name-bold {
    font-size: 12px;
    font-weight: 700;
  }

  .comparison-table-col-name {
    font-size: 12px;
    font-weight: 500;
    color: var(--ink-3);
  }

  .comparison-table-row {
    display: grid;
    gap: 14px;
    padding: 13px 22px;
    align-items: center;
  }

  .comparison-table-row-bordered {
    border-bottom: 1px solid var(--line);
  }

  .comparison-table-feature {
    font-size: 13px;
    color: var(--ink-2);
  }

  .comparison-table-cell {
    text-align: center;
  }

  .comparison-table-check {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: oklch(0.94 0.06 155);
    color: oklch(0.35 0.12 155);
  }

  .comparison-table-dash {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-4);
  }

  .comparison-table-value {
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--ink-3);
    background: var(--paper-2);
    padding: 2px 6px;
    border-radius: 4px;
  }

  .comparison-table-footnote {
    font-size: 11px;
    color: var(--ink-4);
    text-align: center;
    margin: 14px 0 0;
    font-style: italic;
  }

  @media (max-width: 760px) {
    .comparison-table-title {
      font-size: clamp(28px, 4vw, 40px);
    }
  }

  @media (max-width: 560px) {
    .comparison-table {
      padding: 48px 20px;
    }

    .comparison-table-wrap {
      overflow-x: auto;
    }

    .comparison-table-header,
    .comparison-table-row {
      min-width: 600px;
    }
  }
</style>
