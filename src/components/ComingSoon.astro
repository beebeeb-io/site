---
interface Props {
  title?: string;
  subtitle?: string;
  cta_label?: string;
  cta_href?: string;
}

const {
  title = 'Something is brewing.',
  subtitle = 'Beebeeb is end-to-end encrypted cloud storage. Made in Europe, for people who want their files private by default.',
  cta_label = 'Get notified at launch',
  cta_href = 'mailto:hello@beebeeb.io?subject=Notify me when Beebeeb launches',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Beebeeb — Coming soon</title>
    <meta name="description" content={subtitle} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="theme-color" content="#faf9f7" />
    <style>
      @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap');

      * { box-sizing: border-box; }

      body {
        margin: 0;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        background: oklch(0.985 0.004 85);
        color: oklch(0.18 0.01 70);
        font-family: 'Inter', system-ui, sans-serif;
        -webkit-font-smoothing: antialiased;
        padding: 32px;
        text-align: center;
        position: relative;
        overflow: hidden;
      }

      .bg-pattern {
        position: absolute;
        inset: 0;
        opacity: 0.3;
        background-image: radial-gradient(circle at 2px 2px, oklch(0.85 0.04 85 / 0.5) 1px, transparent 1px);
        background-size: 24px 24px;
        pointer-events: none;
      }

      .glow {
        position: absolute;
        top: -100px;
        left: 50%;
        transform: translateX(-50%);
        width: 600px;
        height: 400px;
        border-radius: 50%;
        background: radial-gradient(circle, oklch(0.92 0.1 85 / 0.4), transparent 70%);
        filter: blur(40px);
        pointer-events: none;
      }

      .content {
        position: relative;
        z-index: 1;
        max-width: 560px;
      }

      .logo {
        font-size: 20px;
        font-weight: 700;
        letter-spacing: -0.02em;
        margin-bottom: 48px;
      }

      .logo span {
        color: oklch(0.82 0.17 84);
      }

      h1 {
        font-size: clamp(32px, 6vw, 52px);
        font-weight: 800;
        line-height: 1.05;
        letter-spacing: -0.03em;
        margin: 0 0 20px;
      }

      .subtitle {
        font-size: 16px;
        line-height: 1.7;
        color: oklch(0.38 0.01 72);
        margin: 0 0 40px;
      }

      .cta {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 14px 28px;
        background: oklch(0.82 0.17 84);
        color: oklch(0.18 0.01 70);
        font-family: inherit;
        font-size: 15px;
        font-weight: 600;
        border: none;
        border-radius: 8px;
        text-decoration: none;
        cursor: pointer;
        transition: all 0.2s;
      }

      .cta:hover {
        background: oklch(0.66 0.15 72);
        transform: translateY(-1px);
        box-shadow: 0 4px 16px oklch(0.82 0.17 84 / 0.25);
      }

      .badge {
        position: absolute;
        bottom: 32px;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        align-items: center;
        gap: 16px;
        font-family: 'JetBrains Mono', monospace;
        font-size: 11px;
        color: oklch(0.52 0.01 78);
        white-space: nowrap;
      }

      .badge-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: oklch(0.72 0.16 155);
      }

      @media (max-width: 600px) {
        .badge { flex-direction: column; gap: 8px; }
      }
    </style>
  </head>
  <body>
    <div class="bg-pattern"></div>
    <div class="glow"></div>

    <div class="content">
      <div class="logo">beebeeb<span>.io</span></div>
      <h1>{title}</h1>
      <p class="subtitle">{subtitle}</p>
      <a href={cta_href} class="cta">
        {cta_label}
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
      </a>
    </div>

    <div class="badge">
      <span><span class="badge-dot" style="display:inline-block;vertical-align:middle;margin-right:4px;"></span> EU sovereign</span>
      <span>Hetzner, Germany</span>
      <span>Initlabs B.V. &middot; Wijchen, NL</span>
    </div>
  </body>
</html>
