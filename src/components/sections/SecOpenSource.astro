---
const sample = `<span class="rust-kw">use</span> <span class="rust-path">aes_gcm::aead</span>::<span class="rust-type">Aead</span>;
<span class="rust-kw">use</span> <span class="rust-path">aes_gcm</span>::{<span class="rust-type">Aes256Gcm</span>, <span class="rust-type">KeyInit</span>, <span class="rust-type">Nonce</span>};
<span class="rust-kw">use</span> <span class="rust-path">rand</span>::<span class="rust-type">RngCore</span>;

<span class="rust-comment">/// Encrypt an arbitrary plaintext chunk with AES-256-GCM.</span>
<span class="rust-comment">/// A fresh random 12-byte nonce is generated for every call.</span>
<span class="rust-kw">pub fn</span> <span class="rust-fn">encrypt_chunk</span>(<span class="rust-var">key</span>: &amp;<span class="rust-type">FileKey</span>, <span class="rust-var">plaintext</span>: &amp;[<span class="rust-type">u8</span>])
    -&gt; <span class="rust-type">Result</span>&lt;<span class="rust-type">EncryptedBlob</span>, <span class="rust-type">CoreError</span>&gt; {
    <span class="rust-kw">let</span> <span class="rust-var">cipher</span> = <span class="rust-type">Aes256Gcm</span>::<span class="rust-fn">new_from_slice</span>(key.<span class="rust-fn">as_bytes</span>())?;

    <span class="rust-kw">let mut</span> <span class="rust-var">nonce_bytes</span> = [<span class="rust-num">0u8</span>; <span class="rust-const">NONCE_LEN</span>];
    <span class="rust-path">rand::rngs</span>::<span class="rust-type">OsRng</span>.<span class="rust-fn">fill_bytes</span>(&amp;<span class="rust-kw">mut</span> nonce_bytes);

    <span class="rust-kw">let</span> <span class="rust-var">ciphertext</span> = cipher
        .<span class="rust-fn">encrypt</span>(<span class="rust-type">Nonce</span>::<span class="rust-fn">from_slice</span>(&amp;nonce_bytes), plaintext)?;

    <span class="rust-fn">Ok</span>(<span class="rust-type">EncryptedBlob</span> {
        <span class="rust-var">cipher_suite</span>: <span class="rust-type">CipherSuite</span>::<span class="rust-type">V1Aes256Gcm</span>,
        <span class="rust-var">nonce</span>: nonce_bytes.<span class="rust-fn">to_vec</span>(),
        ciphertext,
    })
}`;
---

<section style="padding: 96px 32px; background: var(--paper-2); border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); position: relative; overflow: hidden;">
  <div style="position: absolute; inset: 0; opacity: 0.06; background-image: repeating-linear-gradient(0deg, transparent, transparent 22px, oklch(0.18 0.01 70) 22px, oklch(0.18 0.01 70) 23px); mask-image: radial-gradient(ellipse at center, black 30%, transparent 70%);" aria-hidden="true"></div>

  <div class="bb-container" style="padding: 0; position: relative; display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: center;">
    <div>
      <div class="bb-eyebrow" style="margin-bottom: 20px;">Don’t take our word</div>
      <h2 class="bb-display-l" style="margin: 0 0 24px;">Read the code.<br />Build it yourself.</h2>
      <p style="font-size: 17px; line-height: 1.65; color: var(--ink-2); margin: 0 0 28px; max-width: 480px; text-wrap: pretty;">
        Every client is open source — the web app, the CLI, and everything
        we’re building next. If we said one thing and shipped another, the
        code would show it. You don’t have to trust us. You can check.
      </p>
      <a href="https://github.com/beebeeb-io" target="_blank" rel="noopener noreferrer" class="bb-cta ghost" style="background: var(--paper);">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .5C5.7.5.7 5.6.7 11.9c0 5 3.3 9.3 7.8 10.8.6.1.8-.2.8-.6v-2c-3.2.7-3.8-1.5-3.8-1.5-.5-1.3-1.3-1.6-1.3-1.6-1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.7-1.6-2.5-.3-5.2-1.3-5.2-5.7 0-1.3.4-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.2 1.2.9-.3 1.9-.4 2.9-.4s2 .1 2.9.4c2.2-1.5 3.2-1.2 3.2-1.2.6 1.6.2 2.8.1 3.1.7.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.2 5.7.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6 4.5-1.5 7.8-5.8 7.8-10.8C23.3 5.6 18.3.5 12 .5z"/></svg>
        github.com/beebeeb-io
      </a>
    </div>

    <div class="rust-code-card">
      <div style="padding: 10px 14px; border-bottom: 1px solid oklch(0.3 0.012 70); display: flex; align-items: center; gap: 8px; font-size: 10.5px; color: oklch(0.7 0.01 80); letter-spacing: 0.04em;">
        <span style="width: 8px; height: 8px; border-radius: 999px; background: oklch(0.6 0.01 70);"></span>
        beebeeb-core/src/encrypt.rs
        <span style="flex: 1;"></span>
        <a href="https://github.com/beebeeb-io/core/blob/main/beebeeb-core/src/encrypt.rs" target="_blank" rel="noopener noreferrer" style="color: oklch(0.55 0.01 80); text-decoration: none;">core@main</a>
      </div>
      <pre><code set:html={sample} /></pre>
    </div>
  </div>
</section>

<style>
  .rust-code-card {
    overflow: hidden;
    border: 1px solid oklch(0.32 0.012 70);
    border-radius: 10px;
    background: var(--ink);
    color: oklch(0.93 0.008 85);
    box-shadow: 0 30px 60px -25px rgba(24, 20, 10, 0.4);
    font-family: var(--font-mono);
    font-size: 11.5px;
  }

  .rust-code-card pre {
    margin: 0;
    padding: 16px 18px;
    overflow-x: auto;
    color: inherit;
    line-height: 1.65;
    tab-size: 4;
  }

  .rust-code-card code {
    display: block;
    min-width: 620px;
    white-space: pre;
  }

  .rust-comment {
    color: oklch(0.66 0.018 86);
    font-style: italic;
  }

  .rust-kw {
    color: oklch(0.79 0.14 82);
  }

  .rust-type,
  .rust-const {
    color: oklch(0.86 0.075 205);
  }

  .rust-fn {
    color: oklch(0.83 0.1 142);
  }

  .rust-var,
  .rust-path {
    color: oklch(0.94 0.018 84);
  }

  .rust-num {
    color: oklch(0.84 0.12 38);
  }

  @media (max-width: 840px) {
    .bb-container {
      grid-template-columns: 1fr !important;
    }
  }
</style>
