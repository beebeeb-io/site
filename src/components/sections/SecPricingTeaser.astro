---
import type { PhaseConfig } from '../../lib/phase';
import WaitlistModalTrigger from '../WaitlistModalTrigger.astro';

const { cfg } = Astro.props as { cfg: PhaseConfig };

const basicMonthly = 10.99;
const basicAnnual = +(basicMonthly * 10 / 12).toFixed(2);
const proBaseMonthly = 54.95;
const proBaseAnnual = +(proBaseMonthly * 10 / 12).toFixed(2);
const bizBaseMonthly = 109.90;
const bizBaseAnnual = +(bizBaseMonthly * 10 / 12).toFixed(2);
---

<section class="pricing-teaser" id="pricing">
  <div class="bb-container">
    <div class="pricing-heading">
      <div class="bb-eyebrow">Plans</div>
      <h2 class="bb-display-l">Simple pricing. No surprises.</h2>
      <p>
        Start free with 5 GB. Upgrade when you need more. Every plan includes
        EU-only storage, zero-knowledge encryption, and full feature access on every plan.
      </p>

      <div class="bb-segment" role="tablist">
        <button id="teaser-btn-monthly" type="button" class="on" aria-pressed="true">Monthly</button>
        <button id="teaser-btn-annual" type="button" aria-pressed="false">
          Annual <span class="save">SAVE 2 MONTHS</span>
        </button>
      </div>
    </div>

    <div class="plan-grid">
      <div class="bb-plan">
        <div>
          <div class="t-label" style="margin-bottom: 10px;">Free</div>
          <div style="font-size: 40px; font-weight: 600; letter-spacing: -0.025em; display: flex; align-items: baseline; gap: 4px;">
            &euro;0<span style="font-size: 14px; color: var(--ink-3); font-weight: 400;">/mo</span>
          </div>
          <div style="font-size: 12px; color: var(--ink-3); margin-top: 4px; height: 16px;">Always &euro;0</div>
        </div>
        <div style="font-size: 13.5px; line-height: 1.55; color: var(--ink-2); min-height: 38px;">
          Try Beebeeb with no commitment.
        </div>
        <div style="padding: 14px; background: var(--paper-2); border: 1px solid var(--line); border-radius: 8px;">
          <div class="t-label" style="margin-bottom: 6px;">What you get</div>
          <div style="font-family: var(--font-mono); font-size: 12.5px; color: var(--ink); display: flex; flex-direction: column; gap: 3px;">
            <span>5 GB storage</span>
            <span>1 user</span>
          </div>
        </div>
        {cfg.isLive ? (
          <a href="https://app.beebeeb.io/signup?plan=free" class="bb-cta plan-cta free"
             target="_blank" rel="noopener noreferrer">
            {cfg.freeCTA}
          </a>
        ) : (
          <WaitlistModalTrigger source="pricing" plan="free" planLabel="Free" variant="free" buttonClass="plan-card" />
        )}
      </div>

      <div class:list={['bb-plan', cfg.isLive ? 'popular' : '']}>
        {cfg.isLive && <div class="bb-plan-badge popular">Most popular</div>}
        <div>
          <div class="t-label" style="margin-bottom: 10px;">Basic</div>
          <div style="font-size: 40px; font-weight: 600; letter-spacing: -0.025em; display: flex; align-items: baseline; gap: 4px;">
            <span id="teaser-basic-price">&euro;{basicMonthly.toFixed(2).replace('.', ',')}</span>
            <span style="font-size: 14px; color: var(--ink-3); font-weight: 400;">/mo</span>
          </div>
          <div id="teaser-basic-note" style="font-size: 12px; color: var(--ink-3); margin-top: 4px; height: 16px;">billed monthly</div>
        </div>
        <div style="font-size: 13.5px; line-height: 1.55; color: var(--ink-2); min-height: 38px;">
          For people who want real privacy for their personal files.
        </div>
        <div style="padding: 14px; background: var(--paper-2); border: 1px solid var(--line); border-radius: 8px;">
          <div class="t-label" style="margin-bottom: 6px;">What you get</div>
          <div style="font-family: var(--font-mono); font-size: 12.5px; color: var(--ink); display: flex; flex-direction: column; gap: 3px;">
            <span>1 TB storage</span>
            <span>1 user</span>
          </div>
        </div>
        {cfg.isLive ? (
          <a href="https://app.beebeeb.io/signup?plan=basic" class="bb-cta plan-cta basic"
             target="_blank" rel="noopener noreferrer">
            {cfg.basicCTA}
          </a>
        ) : (
          <WaitlistModalTrigger source="pricing" plan="basic" planLabel="Basic" variant="basic" buttonClass="plan-card" />
        )}
      </div>

      <div class="bb-plan">
        <div>
          <div class="t-label" style="margin-bottom: 10px;">Pro</div>
          <div style="font-size: 40px; font-weight: 600; letter-spacing: -0.025em; display: flex; align-items: baseline; gap: 4px; min-height: 48px;" aria-live="polite">
            <span id="teaser-pro-price">&euro;{proBaseMonthly.toFixed(2).replace('.', ',')}</span>
            <span id="teaser-pro-unit" style="font-size: 14px; color: var(--ink-3); font-weight: 400;">/mo</span>
          </div>
          <div id="teaser-pro-note" style="font-size: 12px; color: var(--ink-3); margin-top: 4px; height: 16px;">billed monthly</div>
        </div>
        <div style="font-size: 13.5px; line-height: 1.55; color: var(--ink-2); min-height: 38px;">
          For power users with serious storage needs.
        </div>
        <div style="padding: 14px; background: var(--paper-2); border: 1px solid var(--line); border-radius: 8px;">
          <div style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 4px;">
            <span class="t-label">Storage</span>
            <span id="teaser-pro-tb-label" style="font-family: var(--font-mono); font-size: 14px; font-weight: 600; color: var(--ink);">5 TB</span>
          </div>
          <input type="range" class="bb-slider" id="teaser-pro-slider"
                 min="5" max="100" step="1" value="5"
                 aria-label="Storage in TB" aria-valuemin="5" aria-valuemax="100"
                 aria-valuenow="5" aria-valuetext="5 TB" />
          <div style="display: flex; justify-content: space-between; font-family: var(--font-mono); font-size: 10px; color: var(--ink-4); margin-top: 2px;">
            <span>5 TB</span><span>99 TB</span><span>100+</span>
          </div>
          <div style="font-size: 11.5px; color: var(--ink-3); margin-top: 8px; font-family: var(--font-mono);">
            1 user &middot; &euro;10,99 / extra TB
          </div>
        </div>
        {cfg.isLive ? (
          <a id="teaser-pro-cta"
             href="https://app.beebeeb.io/signup?plan=pro"
             target="_blank" rel="noopener noreferrer"
             class="bb-cta plan-cta pro">
            {cfg.proCTA}
          </a>
        ) : (
          <WaitlistModalTrigger source="pricing" plan="pro" planLabel="Pro" variant="pro" buttonClass="plan-card" storageInputId="teaser-pro-slider" />
        )}
      </div>

      <div class:list={['bb-plan', !cfg.bizLive ? 'coming' : '']}>
        {cfg.bizBadge && <div class="bb-plan-badge coming">{cfg.bizBadge}</div>}
        <div>
          <div class="t-label" style="margin-bottom: 10px;">Business</div>
          <div style={`font-size: 40px; font-weight: 600; letter-spacing: -0.025em; display: flex; align-items: baseline; gap: 4px; min-height: 48px; color: ${cfg.bizLive ? 'var(--ink)' : 'var(--ink-3)'};`} aria-live="polite">
            <span id="teaser-biz-price">&euro;{bizBaseMonthly.toFixed(2).replace('.', ',')}</span>
            <span id="teaser-biz-unit" style="font-size: 14px; color: var(--ink-3); font-weight: 400;">/mo</span>
          </div>
          <div id="teaser-biz-note" style="font-size: 12px; color: var(--ink-3); margin-top: 4px; height: 16px;">billed monthly</div>
        </div>
        <div style="font-size: 13.5px; line-height: 1.55; color: var(--ink-2); min-height: 38px;">
          For teams. Shared workspaces, admin console, SLA.
        </div>
        <div style={`padding: 14px; background: var(--paper-2); border: 1px solid var(--line); border-radius: 8px; opacity: ${cfg.bizLive ? '1' : '0.85'};`}>
          <div style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 4px;">
            <span class="t-label">Storage</span>
            <span id="teaser-biz-tb-label" style="font-family: var(--font-mono); font-size: 13px; font-weight: 600; color: var(--ink);">10 TB</span>
          </div>
          <input type="range" class="bb-slider" id="teaser-biz-tb-slider"
                 min="10" max="100" step="1" value="10"
                 aria-label="Business storage in TB" />
          <div style="height: 10px;"></div>
          <div style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 4px;">
            <span class="t-label">Users</span>
            <span id="teaser-biz-user-label" style="font-family: var(--font-mono); font-size: 13px; font-weight: 600; color: var(--ink);">3</span>
          </div>
          <input type="range" class="bb-slider" id="teaser-biz-user-slider"
                 min="3" max="50" step="1" value="3"
                 aria-label="Business team size" />
          <div style="font-size: 11.5px; color: var(--ink-3); margin-top: 8px; font-family: var(--font-mono);">
            &euro;10,99/extra TB &middot; &euro;4,99/extra user
          </div>
        </div>
        {cfg.bizLive ? (
          <a id="teaser-biz-cta" href="https://app.beebeeb.io/signup?plan=business" class="bb-cta plan-cta business"
             target="_blank" rel="noopener noreferrer">
            {cfg.bizCTA}
          </a>
        ) : (
          <WaitlistModalTrigger
            source="pricing"
            plan="business"
            planLabel="Business"
            variant="business-muted"
            buttonClass="plan-card"
            storageInputId="teaser-biz-tb-slider"
            usersInputId="teaser-biz-user-slider"
          />
        )}
      </div>
    </div>

    <div class="pricing-link">
      <a href="/pricing" class="bb-link">See full feature comparison →</a>
    </div>
  </div>
</section>

<script define:vars={{
  basicMonthly,
  basicAnnual,
  proBaseMonthly,
  proBaseAnnual,
  bizBaseMonthly,
  bizBaseAnnual,
  isLive: cfg.isLive,
  bizLive: cfg.bizLive,
  proCTA: cfg.proCTA,
  bizCTA: cfg.bizCTA,
}}>
  let billing = 'monthly';

  function fmt(n) {
    return '€' + n.toFixed(2).replace('.', ',');
  }

  const btnMonthly = document.getElementById('teaser-btn-monthly');
  const btnAnnual = document.getElementById('teaser-btn-annual');
  if (btnMonthly && btnAnnual) {
    btnMonthly.addEventListener('click', () => { billing = 'monthly'; updateAll(); setToggle('monthly'); });
    btnAnnual.addEventListener('click', () => { billing = 'annual'; updateAll(); setToggle('annual'); });
  }

  function setToggle(active) {
    btnMonthly?.classList.toggle('on', active === 'monthly');
    btnAnnual?.classList.toggle('on', active === 'annual');
    btnMonthly?.setAttribute('aria-pressed', String(active === 'monthly'));
    btnAnnual?.setAttribute('aria-pressed', String(active === 'annual'));
  }

  function updateBasic() {
    const price = billing === 'annual' ? basicAnnual : basicMonthly;
    const note = billing === 'annual'
      ? 'billed €' + (basicAnnual * 12).toFixed(2).replace('.', ',') + '/year'
      : 'billed monthly';
    const el = document.getElementById('teaser-basic-price');
    const nl = document.getElementById('teaser-basic-note');
    if (el) el.textContent = fmt(price);
    if (nl) nl.textContent = note;
  }

  const proSlider = document.getElementById('teaser-pro-slider');
  function updatePro() {
    const tb = parseInt(proSlider?.value ?? '5', 10);
    const isQuote = tb >= 100;
    const priceEl = document.getElementById('teaser-pro-price');
    const unitEl = document.getElementById('teaser-pro-unit');
    const noteEl = document.getElementById('teaser-pro-note');
    const ctaEl = document.getElementById('teaser-pro-cta');
    const tbLabel = document.getElementById('teaser-pro-tb-label');
    if (tbLabel) tbLabel.textContent = isQuote ? '100+ TB' : tb + ' TB';
    if (proSlider) {
      proSlider.setAttribute('aria-valuenow', String(tb));
      proSlider.setAttribute('aria-valuetext', isQuote ? 'over 99 TB — get a quote' : tb + ' TB');
    }
    if (isQuote) {
      if (priceEl) priceEl.textContent = 'Get a quote';
      if (unitEl) unitEl.textContent = '';
      if (noteEl) noteEl.textContent = 'Beyond 99 TB';
      if (ctaEl) { ctaEl.textContent = 'Get a quote →'; ctaEl.href = 'mailto:sales@beebeeb.io'; ctaEl.className = 'bb-cta plan-cta free'; }
    } else {
      const monthly = proBaseMonthly + Math.max(0, tb - 5) * 10.99;
      const annual = proBaseAnnual + Math.max(0, tb - 5) * 10.99;
      const price = billing === 'annual' ? annual : monthly;
      const hasExtras = tb > 5;
      if (priceEl) priceEl.textContent = fmt(price);
      if (unitEl) unitEl.textContent = '/mo';
      if (noteEl) noteEl.textContent = billing === 'annual'
        ? (hasExtras ? 'Base annual · add-ons monthly' : 'billed €' + (proBaseAnnual * 12).toFixed(2).replace('.', ',') + '/year')
        : 'billed monthly';
      if (ctaEl && isLive) { ctaEl.textContent = proCTA; ctaEl.href = 'https://app.beebeeb.io/signup?plan=pro'; ctaEl.className = 'bb-cta plan-cta pro'; }
    }
  }
  if (proSlider) proSlider.addEventListener('input', updatePro);

  const bizTbSlider = document.getElementById('teaser-biz-tb-slider');
  const bizUserSlider = document.getElementById('teaser-biz-user-slider');
  function updateBiz() {
    const tb = parseInt(bizTbSlider?.value ?? '10', 10);
    const users = parseInt(bizUserSlider?.value ?? '3', 10);
    const isQuote = tb >= 100 || users >= 50;
    const priceEl = document.getElementById('teaser-biz-price');
    const unitEl = document.getElementById('teaser-biz-unit');
    const noteEl = document.getElementById('teaser-biz-note');
    const ctaEl = document.getElementById('teaser-biz-cta');
    const tbLabel = document.getElementById('teaser-biz-tb-label');
    const userLabel = document.getElementById('teaser-biz-user-label');
    if (tbLabel) tbLabel.textContent = tb >= 100 ? '100+ TB' : tb + ' TB';
    if (userLabel) userLabel.textContent = users >= 50 ? '50+' : String(users);
    if (isQuote) {
      if (priceEl) priceEl.textContent = 'Get a quote';
      if (unitEl) unitEl.textContent = '';
      if (noteEl) noteEl.textContent = 'Beyond 99 TB or 49 users';
      if (ctaEl && bizLive) { ctaEl.textContent = 'Get a quote →'; ctaEl.href = 'mailto:sales@beebeeb.io'; ctaEl.className = 'bb-cta plan-cta business-muted'; }
    } else {
      const monthly = bizBaseMonthly + Math.max(0, tb - 10) * 10.99 + Math.max(0, users - 3) * 4.99;
      const annual = bizBaseAnnual + Math.max(0, tb - 10) * 10.99 + Math.max(0, users - 3) * 4.99;
      const hasExtras = tb > 10 || users > 3;
      const price = billing === 'annual' ? annual : monthly;
      if (priceEl) priceEl.textContent = fmt(price);
      if (unitEl) unitEl.textContent = '/mo';
      if (noteEl) noteEl.textContent = billing === 'annual'
        ? (hasExtras ? 'Base annual · add-ons monthly' : 'billed €' + (bizBaseAnnual * 12).toFixed(2).replace('.', ',') + '/year')
        : 'billed monthly';
      if (ctaEl && bizLive) { ctaEl.textContent = bizCTA; ctaEl.href = 'https://app.beebeeb.io/signup?plan=business'; ctaEl.className = 'bb-cta plan-cta business'; }
    }
  }
  if (bizTbSlider) bizTbSlider.addEventListener('input', updateBiz);
  if (bizUserSlider) bizUserSlider.addEventListener('input', updateBiz);

  function updateAll() {
    updateBasic();
    updatePro();
    if (bizLive) updateBiz();
  }
</script>

<style>
  .pricing-teaser {
    padding: 110px 32px;
    background: var(--paper);
  }

  .pricing-teaser > .bb-container {
    padding: 0;
  }

  .pricing-heading {
    margin-bottom: 36px;
    text-align: center;
  }

  .pricing-heading .bb-eyebrow {
    display: inline-flex;
    justify-content: center;
    margin: 0 auto 18px;
  }

  h2 {
    margin: 0 0 14px;
    font-size: clamp(32px, 3.4vw, 46px);
  }

  .pricing-heading p {
    max-width: 580px;
    margin: 0 auto;
    color: var(--ink-2);
    font-size: 16px;
    line-height: 1.6;
  }

  .bb-segment {
    display: inline-flex;
    margin-top: 24px;
  }

  .plan-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
  }

  .pricing-link {
    margin-top: 32px;
    text-align: center;
  }

  .plan-cta {
    width: 100%;
    justify-content: center;
    padding: 12px 14px;
    margin-top: auto;
  }

  .plan-cta.free {
    border-color: var(--line-2);
    background: transparent;
    color: var(--ink);
    box-shadow: none;
  }

  .plan-cta.free:hover {
    border-color: var(--ink-3);
    background: var(--paper-2);
  }

  .plan-cta.basic {
    border-color: var(--amber-deep);
    background: var(--amber);
    color: var(--ink);
  }

  .plan-cta.pro {
    border-color: var(--ink);
    background: var(--ink);
    color: var(--paper);
  }

  .plan-cta.business,
  .plan-cta.business-muted {
    border-color: oklch(0.34 0.012 75);
    background: oklch(0.30 0.010 75);
    color: var(--paper);
    box-shadow: none;
  }

  .plan-cta.business:hover,
  .plan-cta.business-muted:hover {
    background: oklch(0.34 0.012 75);
  }

  @media (max-width: 980px) {
    .plan-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 620px) {
    .plan-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
