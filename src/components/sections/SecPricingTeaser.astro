---
import type { PhaseConfig } from '../../lib/phase';

const { cfg } = Astro.props as { cfg: PhaseConfig };
const waitlist = cfg.phase === 1;
const plans = [
  { name: 'Free',     price: '€0',       note: '',      storage: '5 GB',           desc: 'Try Beebeeb with no commitment.',                         popular: false, badge: null,         cta: cfg.freeCTA,  href: cfg.isLive ? 'https://app.beebeeb.io/signup?plan=free'     : '#waitlist' },
  { name: 'Basic',    price: '€10,99',   note: '/mo',   storage: '1 TB',           desc: 'For people who want real privacy for their personal files.', popular: cfg.isLive, badge: null, cta: cfg.basicCTA, href: cfg.isLive ? 'https://app.beebeeb.io/signup?plan=basic'    : '#waitlist' },
  { name: 'Pro',      price: '€54,95',   note: '/mo',   storage: '5 TB base',      desc: 'For power users with serious storage needs.',              popular: false, badge: null,         cta: cfg.proCTA,   href: cfg.isLive ? 'https://app.beebeeb.io/signup?plan=pro'      : '#waitlist' },
  { name: 'Business', price: '€109,90',  note: '/mo',   storage: '10 TB + 3 users', desc: 'For teams. Shared workspaces, admin console, SLA.',       popular: false, badge: cfg.bizBadge, cta: cfg.bizCTA,   href: cfg.bizLive ? 'https://app.beebeeb.io/signup?plan=business' : '#waitlist' },
];
---

<section class="bb-section-band pricing-section">
  <div class="bb-container">
    <div class="pricing-heading">
      <div class="bb-eyebrow">Plans</div>
      <h2 class="bb-display-l">Simple pricing. No surprises.</h2>
      <p>
        Start free with 5 GB. Upgrade when you need more. Every plan includes EU-only
        storage and zero-knowledge encryption.
      </p>
    </div>

    <div class="plan-grid">
      {plans.map((plan) => (
        <article class:list={['bb-plan', plan.popular && 'popular', plan.badge && !plan.popular && 'coming']}>
          {plan.popular && <div class="bb-plan-badge popular">Most popular</div>}
          {plan.badge && !plan.popular && <div class="bb-plan-badge coming">{plan.badge}</div>}
          <div class="t-label">{plan.name}</div>
          <div class="price">{plan.price}<span>{plan.note}</span></div>
          <p>{plan.desc}</p>
          <div class="storage">{plan.storage}</div>
          <a href={plan.href} class:list={['bb-cta', plan.popular ? 'amber' : 'ghost']}
             target={plan.href.startsWith('http') ? '_blank' : undefined}
             rel={plan.href.startsWith('http') ? 'noopener noreferrer' : undefined}>
            {plan.cta}
          </a>
        </article>
      ))}
    </div>

    <div class="pricing-link">
      <a href="/pricing" class="bb-link">See full feature comparison -&gt;</a>
    </div>
  </div>
</section>

<style>
  .pricing-heading {
    margin-bottom: 36px;
    text-align: center;
  }

  .pricing-heading .bb-eyebrow {
    justify-content: center;
  }

  h2 {
    margin: 18px 0 14px;
    font-size: clamp(32px, 3.4vw, 46px);
  }

  .pricing-heading p {
    max-width: 600px;
    margin: 0 auto;
    color: var(--color-ink-2);
    font-size: 16px;
    line-height: 1.6;
  }

  .plan-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
  }

  .price {
    display: flex;
    align-items: baseline;
    gap: 4px;
    color: var(--color-ink);
    font-size: 30px;
    font-weight: 800;
    letter-spacing: -0.035em;
  }

  .price span {
    color: var(--color-ink-3);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0;
  }

  .bb-plan p {
    min-height: 62px;
    margin: 0;
    color: var(--color-ink-2);
    font-size: 13px;
    line-height: 1.55;
  }

  .storage {
    padding: 8px 10px;
    border: 1px solid var(--color-line);
    border-radius: 6px;
    background: var(--color-paper-2);
    color: var(--color-ink-2);
    font-family: var(--font-mono);
    font-size: 11px;
    text-align: center;
  }

  .bb-plan .bb-cta {
    margin-top: auto;
  }

  .pricing-link {
    margin-top: 32px;
    text-align: center;
  }

  .bb-link {
    border-bottom: 1px solid var(--color-line-2);
    color: var(--color-ink);
    font-size: 13.5px;
    text-decoration: none;
  }

  @media (max-width: 980px) {
    .plan-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 620px) {
    .plan-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
