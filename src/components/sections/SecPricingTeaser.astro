---
import type { PhaseConfig } from '../../lib/phase';

const { cfg } = Astro.props as { cfg: PhaseConfig };
const waitlist = cfg.phase === 1;
const plans = [
  ['Free', '0 euro', '5 GB', 'Private encrypted storage to get started.'],
  ['Basic', '3 euro', '100 GB', 'Room for everyday files and encrypted sharing.'],
  ['Pro', '8 euro', '1 TB', 'More storage for people who live in the cloud.'],
  ['Business', '15 euro', '2 TB / user', 'Team storage with the same zero-knowledge model.'],
];
---

<section class="bb-section-band pricing-section">
  <div class="bb-container">
    <div class="pricing-heading">
      <div class="bb-eyebrow">Plans</div>
      <h2 class="bb-display-l">Simple pricing. No surprises.</h2>
      <p>
        Start free with 5 GB. Upgrade when you need more. Every plan includes EU-only
        storage and zero-knowledge encryption.
      </p>
    </div>

    <div class="plan-grid">
      {plans.map(([name, price, storage, desc], index) => (
        <article class:list={['bb-plan', index === 2 && 'popular']}>
          {index === 2 && <div class="bb-plan-badge">Popular</div>}
          <div class="t-label">{name}</div>
          <div class="price">{price}<span>{price === '0 euro' ? '' : ' / month'}</span></div>
          <p>{desc}</p>
          <div class="storage">{storage}</div>
          <a href={waitlist ? '#waitlist' : cfg.primaryHref} class:list={['bb-cta', index === 2 ? 'amber' : 'ghost']}>
            {waitlist ? 'Join the waitlist' : 'Sign up'}
          </a>
        </article>
      ))}
    </div>

    <div class="pricing-link">
      <a href="/pricing" class="bb-link">See full feature comparison -&gt;</a>
    </div>
  </div>
</section>

<style>
  .pricing-heading {
    margin-bottom: 36px;
    text-align: center;
  }

  .pricing-heading .bb-eyebrow {
    justify-content: center;
  }

  h2 {
    margin: 18px 0 14px;
    font-size: clamp(32px, 3.4vw, 46px);
  }

  .pricing-heading p {
    max-width: 600px;
    margin: 0 auto;
    color: var(--color-ink-2);
    font-size: 16px;
    line-height: 1.6;
  }

  .plan-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
  }

  .price {
    display: flex;
    align-items: baseline;
    gap: 4px;
    color: var(--color-ink);
    font-size: 30px;
    font-weight: 800;
    letter-spacing: -0.035em;
  }

  .price span {
    color: var(--color-ink-3);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0;
  }

  .bb-plan p {
    min-height: 62px;
    margin: 0;
    color: var(--color-ink-2);
    font-size: 13px;
    line-height: 1.55;
  }

  .storage {
    padding: 8px 10px;
    border: 1px solid var(--color-line);
    border-radius: 6px;
    background: var(--color-paper-2);
    color: var(--color-ink-2);
    font-family: var(--font-mono);
    font-size: 11px;
    text-align: center;
  }

  .bb-plan .bb-cta {
    margin-top: auto;
  }

  .pricing-link {
    margin-top: 32px;
    text-align: center;
  }

  .bb-link {
    border-bottom: 1px solid var(--color-line-2);
    color: var(--color-ink);
    font-size: 13.5px;
    text-decoration: none;
  }

  @media (max-width: 980px) {
    .plan-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 620px) {
    .plan-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
