---
const steps = [
  {
    n: '01',
    title: 'Sign up',
    body: 'Pick a password. We generate your master key on your device, encrypted by that password, plus a 12-word recovery phrase only you ever see.',
    visual: 'recovery',
  },
  {
    n: '02',
    title: 'Upload',
    body: 'Drag, drop, done. Files are encrypted on your device before bytes leave you. We see opaque blobs; only you see your stuff.',
    visual: 'files',
  },
  {
    n: '03',
    title: 'Share',
    body: 'Share a link. The decryption key travels in the URL fragment — the part our server never sees. Revoke any link, any time.',
    visual: 'share',
  },
];

const words = ['gather', 'kiwi', 'actor', 'bronze', '••••••', '•••••', '••••••', '••••', '••••••', '••••', '•••••', '••••'];
const files = [
  ['tax-2025.pdf', '4f9e2a01b7c8a93f'],
  ['passport-scan.jpg', 'e22b1c0a749d83bf'],
  ['family-photos/', 'a09c4f7e2bd1880a'],
];
---

<section style="padding: 110px 32px; background: var(--paper);">
  <div class="bb-container" style="padding: 0;">
    <div style="text-align: center; margin-bottom: 40px;">
      <div class="bb-eyebrow" style="margin: 0 auto 18px; justify-content: center; display: inline-flex;">How it works</div>
      <h2 class="bb-display-l" style="margin: 0 0 28px; font-size: clamp(32px, 3.4vw, 46px);">Three steps. No clever tricks.</h2>
      <div class="bb-segment" role="tablist" style="margin: 0 auto;">
        <button type="button" class="on">For everyone</button>
        <button type="button">For engineers</button>
      </div>
    </div>

    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 0; border: 1px solid var(--line); border-radius: 12px; overflow: hidden; background: var(--paper);">
      {steps.map((step, index) => (
        <article style={`padding: 36px 32px; border-right: ${index < steps.length - 1 ? '1px solid var(--line)' : 'none'}; display: flex; flex-direction: column; gap: 14px; min-height: 280px;`}>
          <div class="bb-step-num">{step.n} / 03</div>
          <h3 style="font-size: 24px; font-weight: 600; letter-spacing: -0.022em; color: var(--ink); margin: 0;">{step.title}</h3>
          <p style="font-size: 14px; line-height: 1.65; color: var(--ink-2); text-wrap: pretty; min-height: 110px; margin: 0;">{step.body}</p>
          <div style="flex: 1;"></div>

          {step.visual === 'recovery' && (
            <div class="step-visual recovery">
              <div class="t-label">Recovery phrase · 12 words</div>
              <div class="word-grid">
                {words.map((word, i) => (
                  <div>
                    <span>{String(i + 1).padStart(2, '0')}</span>
                    <span>{word}</span>
                  </div>
                ))}
              </div>
              <div class="visual-note">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><rect x="5" y="11" width="14" height="10" rx="2"></rect><path d="M8 11V7a4 4 0 0 1 8 0v4"></path></svg>
                Only ever shown to you
              </div>
            </div>
          )}

          {step.visual === 'files' && (
            <div class="step-visual files">
              <div class="file-head">
                <span>Your file →</span>
                <span>What we store</span>
              </div>
              {files.map(([name, hash], i) => (
                <div class="file-row" style={`border-bottom: ${i < files.length - 1 ? '1px solid var(--line)' : 'none'};`}>
                  <span>{name}</span>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--amber-deep)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"></path></svg>
                  <span>{hash}.enc</span>
                </div>
              ))}
            </div>
          )}

          {step.visual === 'share' && (
            <div class="step-visual share">
              <div class="t-label">Share link</div>
              <div class="share-link">
                <span>app.beebeeb.io/s/</span><span>k7Qx</span><span>#a3f7c2e9b1d8</span>
              </div>
              <div class="share-meta">
                <span>
                  <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><circle cx="12" cy="12" r="9"></circle><path d="M12 7v5l3 2"></path></svg>
                  Expires in 7 days
                </span>
                <span>Revoke</span>
              </div>
              <div class="fragment-note"><span>#</span> = key. Server never sees this.</div>
            </div>
          )}
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .step-visual {
    margin-top: 8px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--paper-2);
    overflow: hidden;
  }

  .recovery {
    padding: 14px;
  }

  .recovery .t-label,
  .share .t-label {
    margin-bottom: 10px;
    color: var(--ink-3);
    font-size: 9.5px;
  }

  .word-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 6px 8px;
  }

  .word-grid div {
    display: flex;
    align-items: baseline;
    gap: 5px;
    color: var(--ink);
    font-family: var(--font-mono);
    font-size: 10.5px;
  }

  .word-grid div:nth-child(n+5) {
    color: var(--ink-3);
  }

  .word-grid span:first-child {
    min-width: 12px;
    color: var(--ink-3);
    font-size: 8.5px;
  }

  .visual-note {
    display: flex;
    align-items: center;
    gap: 5px;
    margin-top: 10px;
    padding-top: 8px;
    border-top: 1px dashed var(--line-2);
    color: var(--amber-deep);
    font-size: 10.5px;
  }

  .file-head {
    display: flex;
    justify-content: space-between;
    padding: 8px 12px;
    border-bottom: 1px solid var(--line);
    color: var(--ink-3);
    font-family: var(--font-mono);
    font-size: 9.5px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .file-row {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 8px;
    padding: 9px 12px;
    font-size: 11px;
  }

  .file-row span:first-child {
    color: var(--ink);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .file-row span:last-child {
    color: var(--amber-deep);
    font-family: var(--font-mono);
    font-size: 10px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .share {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 12px 14px;
  }

  .share-link {
    display: flex;
    align-items: center;
    gap: 6px;
    overflow: hidden;
    padding: 8px 10px;
    border: 1px solid var(--line-2);
    border-radius: 5px;
    background: var(--paper);
    font-family: var(--font-mono);
    font-size: 10px;
  }

  .share-link span:first-child {
    color: var(--ink-3);
  }

  .share-link span:nth-child(2) {
    color: var(--ink);
  }

  .share-link span:last-child {
    color: var(--amber-deep);
  }

  .share-meta {
    display: flex;
    justify-content: space-between;
    color: var(--ink-2);
    font-size: 10.5px;
  }

  .share-meta span {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .share-meta span:last-child,
  .fragment-note span {
    color: var(--amber-deep);
    font-weight: 500;
  }

  .fragment-note {
    color: var(--ink-3);
    font-family: var(--font-mono);
    font-size: 9.5px;
    letter-spacing: 0.02em;
  }

  @media (max-width: 900px) {
    .bb-container > div:last-child {
      grid-template-columns: 1fr !important;
    }

    article {
      border-right: 0 !important;
      border-bottom: 1px solid var(--line);
    }
  }
</style>
