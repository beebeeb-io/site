---
const links = [
  {
    label: 'System status',
    description: 'Current uptime, incidents, and service health.',
    href: '/status',
    icon: 'activity',
  },
  {
    label: 'Security',
    description: 'How encryption works, threat model, and audits.',
    href: '/security',
    icon: 'shield',
  },
  {
    label: 'Documentation',
    description: 'Guides, API reference, and getting started.',
    href: '/docs',
    icon: 'book',
  },
  {
    label: 'Bug bounty',
    description: 'Report a vulnerability and earn a reward.',
    href: '/bug-bounty',
    icon: 'bug',
  },
];
---

<section class="quick-links-section">
  <div class="bb-container" style="padding: 0;">
    <div class="quick-links-grid">
      {links.map((link, i) => (
        <a href={link.href} class:list={['quick-link-card', 'bb-fade-up', `bb-delay-${i + 1}`]}>
          <div class="quick-link-icon">
            {link.icon === 'activity' && (
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
            )}
            {link.icon === 'shield' && (
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            )}
            {link.icon === 'book' && (
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
            )}
            {link.icon === 'bug' && (
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="8" y="6" width="8" height="14" rx="4"/><path d="M19 12h2"/><path d="M3 12h2"/><path d="M19 8h2"/><path d="M3 8h2"/><path d="M19 16h2"/><path d="M3 16h2"/><path d="M9 2l1.5 2"/><path d="M15 2l-1.5 2"/></svg>
            )}
          </div>
          <div class="quick-link-label">{link.label}</div>
          <p class="quick-link-desc">{link.description}</p>
          <span class="quick-link-arrow" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .quick-links-section {
    padding: 0 32px 72px;
    background: var(--paper);
  }

  .quick-links-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .quick-link-card {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 24px 22px;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 12px;
    text-decoration: none;
    color: inherit;
    position: relative;
    transition: border-color 150ms var(--ease), box-shadow 150ms var(--ease), transform 150ms var(--ease);
  }

  .quick-link-card:hover {
    border-color: var(--ink-3);
    box-shadow: var(--shadow-2);
    transform: translateY(-2px);
  }

  .quick-link-icon {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background: var(--amber-soft);
    border: 1px solid oklch(0.86 0.07 90);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--amber-deep);
    flex-shrink: 0;
  }

  .quick-link-label {
    font-size: 15px;
    font-weight: 600;
    letter-spacing: -0.018em;
    color: var(--ink);
  }

  .quick-link-desc {
    margin: 0;
    font-size: 13px;
    line-height: 1.55;
    color: var(--ink-2);
    flex: 1;
  }

  .quick-link-arrow {
    color: var(--ink-4);
    transition: color 150ms var(--ease), transform 150ms var(--ease);
    display: inline-flex;
    margin-top: 4px;
  }

  .quick-link-card:hover .quick-link-arrow {
    color: var(--amber-deep);
    transform: translateX(3px);
  }

  @media (max-width: 900px) {
    .quick-links-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 560px) {
    .quick-links-section {
      padding: 0 20px 48px;
    }

    .quick-links-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
