---
import type { PhaseConfig } from '../../lib/phase';

const { cfg } = Astro.props as { cfg: PhaseConfig };

const platforms = [
  ['web', 'Web app', cfg.webLive],
  ['cli', 'CLI', cfg.cliLive],
  ['macos', 'macOS', cfg.desktopLive],
  ['windows', 'Windows', cfg.desktopLive],
  ['linux', 'Linux', cfg.desktopLive],
  ['ios', 'iOS', cfg.iosLive],
  ['android', 'Android', cfg.androidLive],
  ['rclone', 'rclone', cfg.rcloneLive],
] as const;

const live = platforms.filter((item) => item[2]);
const soon = platforms.filter((item) => !item[2]);
---

<section id="product" style="padding: 110px 32px; background: var(--paper-2); border-top: 1px solid var(--line); border-bottom: 1px solid var(--line);">
  <div class="bb-container" style="padding: 0;">
    <div style="margin-bottom: 56px; max-width: 720px;">
      <div class="bb-eyebrow" style="margin-bottom: 18px;">The product</div>
      <h2 class="bb-display-l" style="margin: 0 0 18px;">Cloud storage. End-to-end encrypted.</h2>
      <p style="font-size: 17px; line-height: 1.6; color: var(--ink-2); margin: 0; text-wrap: pretty;">
        Your files, encrypted on your device, stored on EU infrastructure.
        Start on the web or the command line. More platforms are on the way.
      </p>
    </div>

    {live.length > 0 && (
      <div style="margin-bottom: 36px;">
        <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 16px;">
          <span class="t-label" style="color: var(--ink); font-weight: 600;">{cfg.availLabel}</span>
          <span style={`width: 6px; height: 6px; border-radius: 999px; background: ${cfg.isLive ? 'var(--green)' : 'var(--amber)'};`}></span>
        </div>
        <div style="display: flex; gap: 10px; flex-wrap: wrap;">
          {live.map(([key, label]) => (
            <div class="bb-platform">
              <span class="platform-glyph" aria-hidden="true">{key === 'web' ? '◎' : key === 'cli' ? '⌘' : '◦'}</span>
              <span>{label}</span>
            </div>
          ))}
        </div>
      </div>
    )}

    {soon.length > 0 && (
      <div>
        <div class="t-label" style="margin-bottom: 16px; color: var(--ink-3);">Coming soon</div>
        <div style="display: flex; gap: 10px; flex-wrap: wrap;">
          {soon.map(([key, label]) => (
            <div class="bb-platform coming">
              <span class="platform-glyph" aria-hidden="true">{key === 'rclone' ? '✳' : '◦'}</span>
              <span>{label}</span>
            </div>
          ))}
        </div>
      </div>
    )}

    {cfg.cliLive && (
      <div style="margin-top: 48px; padding: 24px; border-radius: 12px; background: var(--ink); color: var(--paper); display: grid; grid-template-columns: 1fr auto; gap: 24px; align-items: center; border: 1px solid var(--ink);">
        <div>
          <div class="t-label" style="color: var(--amber); margin-bottom: 8px;">Install the CLI</div>
          <div style="font-size: 15px; color: oklch(0.85 0.01 80); line-height: 1.5; margin-bottom: 14px; max-width: 480px;">
            One line. Verifies its own signature. Works on macOS, Linux, and WSL.
          </div>
          <div style="display: flex; align-items: center; gap: 10px; background: oklch(0.16 0.012 70); border: 1px solid oklch(0.3 0.012 70); border-radius: 6px; padding: 12px 14px; max-width: 540px;">
            <span style="color: var(--amber); font-family: var(--font-mono); font-size: 13px;">$</span>
            <code style="flex: 1; font-family: var(--font-mono); font-size: 13px; color: oklch(0.95 0.005 80); overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
              curl -fsSL https://get.beebeeb.io | sh
            </code>
            <button type="button" data-copy-cli style="background: transparent; border: 1px solid oklch(0.4 0.012 70); color: oklch(0.85 0.01 80); border-radius: 5px; padding: 5px 10px; font-size: 11px; font-family: var(--font-mono); cursor: pointer; letter-spacing: 0.06em; text-transform: uppercase;">copy</button>
          </div>
        </div>
        <div style="display: flex; flex-direction: column; gap: 8px; align-items: flex-end;">
          <a href="https://github.com/beebeeb-io/cli" target="_blank" rel="noopener noreferrer" class="bb-cta" style="background: transparent; border-color: oklch(0.4 0.012 70); color: var(--paper);">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .5C5.7.5.7 5.6.7 11.9c0 5 3.3 9.3 7.8 10.8.6.1.8-.2.8-.6v-2c-3.2.7-3.8-1.5-3.8-1.5-.5-1.3-1.3-1.6-1.3-1.6-1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.7-1.6-2.5-.3-5.2-1.3-5.2-5.7 0-1.3.4-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.2 1.2.9-.3 1.9-.4 2.9-.4s2 .1 2.9.4c2.2-1.5 3.2-1.2 3.2-1.2.6 1.6.2 2.8.1 3.1.7.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.2 5.7.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6 4.5-1.5 7.8-5.8 7.8-10.8C23.3 5.6 18.3.5 12 .5z"/></svg>
            View source
          </a>
        </div>
      </div>
    )}
  </div>
</section>

<script>
  document.querySelectorAll('[data-copy-cli]').forEach((button) => {
    if (button.dataset.bound === 'true') return;
    button.dataset.bound = 'true';
    button.addEventListener('click', async () => {
      await navigator.clipboard?.writeText('curl -fsSL https://get.beebeeb.io | sh');
      const previous = button.textContent;
      button.textContent = 'copied';
      button.style.color = 'var(--amber)';
      window.setTimeout(() => {
        button.textContent = previous;
        button.style.color = 'oklch(0.85 0.01 80)';
      }, 1600);
    });
  });
</script>

<style>
  .platform-glyph {
    color: var(--ink-2);
    font-size: 14px;
    line-height: 1;
  }

  .bb-platform.coming .platform-glyph {
    color: var(--ink-4);
  }

  @media (max-width: 760px) {
    div[style*='grid-template-columns: 1fr auto'] {
      grid-template-columns: 1fr !important;
    }
  }
</style>
