---
import type { PhaseConfig } from '../../lib/phase';
import WaitlistModalTrigger from '../WaitlistModalTrigger.astro';

const { cfg } = Astro.props as { cfg: PhaseConfig };
const waitlist = cfg.phase === 1;
const primaryExternal = /^https?:\/\//.test(cfg.primaryHref);
---

<section class="bb-ink-panel final-cta">
  <div class="bb-container final-inner">
    <h2 class="bb-display-l">Your files deserve better.</h2>
    <p>{cfg.ctaCaption}</p>
    <div class="final-actions">
      {waitlist ? (
        <a href="#waitlist" class="bb-cta amber" data-waitlist-trigger data-waitlist-source="final-cta">
          Join the waitlist
        </a>
      ) : (
        <a
          href={cfg.primaryHref}
          class="bb-cta amber"
          target={primaryExternal ? '_blank' : undefined}
          rel={primaryExternal ? 'noopener noreferrer' : undefined}
        >
          Get started free
        </a>
      )}
      <a href="/security" class="bb-cta security-note">Read the security note</a>
    </div>
    {waitlist && <WaitlistModalTrigger source="final-cta" renderButton={false} />}
  </div>
</section>

<style>
  .final-cta {
    padding: 110px 32px;
  }

  .final-inner {
    max-width: 760px;
    margin: 0 auto;
    text-align: center;
  }

  h2 {
    margin: 0 0 22px;
    color: var(--paper);
    font-size: clamp(36px, 4.4vw, 64px);
  }

  p {
    margin: 0 0 36px;
    color: oklch(0.78 0.01 80);
    font-size: 17px;
    line-height: 1.55;
    text-wrap: pretty;
  }

  .final-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
  }

  .security-note {
    border-color: oklch(0.4 0.012 70);
    background: transparent;
    color: var(--paper);
  }
</style>
