---
import type { PhaseConfig } from '../../lib/phase';
import WaitlistForm from '../WaitlistForm.astro';

const { cfg } = Astro.props as { cfg: PhaseConfig };
const waitlist = cfg.phase === 1;
---

<section class="bb-ink-panel final-cta">
  <div class="bb-container final-inner">
    <h2 class="bb-display-l">Your files<br />deserve <span>better.</span></h2>
    <p>
      {waitlist
        ? 'Join the waitlist. One email when we go live. Then silence.'
        : '5 GB free. No credit card. Encrypted from day one.'}
    </p>
    <div class="final-actions">
      {waitlist ? (
        <WaitlistForm source="footer-cta" />
      ) : (
        <a href={cfg.primaryHref} class="bb-cta amber">
          Get started free
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
      )}
      <a href="/security" class="bb-cta security-note">Read the security note</a>
    </div>
  </div>
</section>

<style>
  .final-cta {
    padding: 110px 32px;
  }

  .final-inner {
    max-width: 760px;
    margin: 0 auto;
    text-align: center;
  }

  h2 {
    margin: 0 0 22px;
    color: var(--paper);
    font-size: clamp(36px, 4.4vw, 64px);
  }

  h2 span {
    color: var(--amber);
  }

  p {
    margin: 0 0 36px;
    color: oklch(0.78 0.01 80);
    font-size: 17px;
    line-height: 1.55;
    text-wrap: pretty;
  }

  .final-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
  }

  .security-note {
    border-color: oklch(0.4 0.012 70);
    background: transparent;
    color: var(--paper);
  }
</style>
