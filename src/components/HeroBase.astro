---
import type { PhaseConfig } from '../lib/phase';
import EncDemo from './EncDemo.astro';
import WaitlistForm from './WaitlistForm.astro';

interface Props {
  cfg: PhaseConfig;
}

const { cfg } = Astro.props as Props;
const phaseOne = cfg.phase === 1;
const primaryCTA = phaseOne ? 'Join the waitlist' : 'Get started free';
const primaryHref = phaseOne ? '#waitlist' : cfg.primaryHref;
const caption = cfg.ctaCaption;
const trust = [
  ['Zero-knowledge', 'we cannot read your files'],
  ['EU-only', 'EU law, no US Cloud Act'],
  ['Open source', 'every client is auditable'],
  ['Encrypted on device', 'before bytes leave you'],
];
---

<section class="hero-launch">
  <div class="hero-wash" aria-hidden="true"></div>
  <div class="bb-honeycomb-soft hero-pattern" aria-hidden="true"></div>

  <div class="bb-container hero-grid">
    <div class="hero-copy">
      <div class="bb-eyebrow">Why we exist</div>
      <h1 class="bb-display-xl">Your files<br />belong to you.</h1>
      <p>
        Privacy isn't a feature you find in a settings menu. It's the starting position.
        Everything we build follows from that.
      </p>
      <div class="hero-actions">
        <a href={primaryHref} class="bb-cta amber">
          {primaryCTA}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
        <a href="#how" class="bb-cta ghost">How it works</a>
      </div>
      <div class="hero-caption">{caption}</div>
      {cfg.phase >= 3 && <div class="hero-native-note">Native desktop and mobile clients are available in this phase.</div>}
    </div>

    <div class="hero-demo">
      <div class="live-label">
        <span></span>
        Live demonstration
      </div>
      <EncDemo height={400} />
      <div class="crypto-row">
        {['AES-256-GCM', 'Key on device', 'Password never sent'].map((chip) => (
          <div class="bb-crypto"><span class="dot"></span>{chip}</div>
        ))}
      </div>
    </div>
  </div>

  <div class="hero-trust">
    {trust.map(([label, value], index) => (
      <div class:list={['bb-trust-item', index === trust.length - 1 && 'last']}>
        <span class="label">{label}</span>
        <span class="value">{value}</span>
      </div>
    ))}
  </div>

  {phaseOne && (
    <div class="hero-waitlist">
      <WaitlistForm source="hero" />
    </div>
  )}
</section>

<style>
  .hero-launch {
    position: relative;
    overflow: hidden;
    background: var(--paper);
  }

  .hero-wash {
    position: absolute;
    top: -200px;
    right: -300px;
    width: 800px;
    height: 700px;
    border-radius: 999px;
    background: radial-gradient(circle, oklch(0.94 0.06 88 / 0.4), transparent 65%);
    filter: blur(80px);
    pointer-events: none;
  }

  .hero-pattern {
    position: absolute;
    inset: 0;
    opacity: 0.5;
    mask-image: radial-gradient(circle at 75% 30%, black 5%, transparent 60%);
    pointer-events: none;
  }

  .hero-grid {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1.15fr;
    gap: 72px;
    align-items: center;
    padding: 88px 32px 80px;
  }

  .hero-copy .bb-eyebrow {
    margin-bottom: 24px;
  }

  .hero-copy .bb-display-xl {
    margin: 0 0 22px;
    color: var(--ink);
    font-family: var(--font-sans);
    font-size: clamp(40px, 5.6vw, 78px);
    font-weight: 600;
    letter-spacing: -0.038em;
    line-height: 0.98;
  }

  .hero-copy p {
    max-width: 520px;
    margin: 0 0 32px;
    color: var(--ink-2);
    font-size: 18px;
    line-height: 1.6;
    text-wrap: pretty;
  }

  .hero-actions {
    display: flex;
    gap: 12px;
    align-items: center;
    margin-bottom: 14px;
  }

  .hero-actions .bb-cta {
    gap: 10px;
    min-height: unset;
    padding: 14px 22px;
    border-radius: 8px;
    font-size: 14.5px;
    font-weight: 500;
    letter-spacing: -0.005em;
  }

  .hero-actions .bb-cta.amber {
    border-color: var(--amber-deep);
    background: var(--amber);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.4) inset,
      0 4px 12px -4px oklch(0.66 0.15 72 / 0.4);
  }

  .hero-actions .bb-cta.ghost {
    border-color: var(--line-2);
    background: transparent;
    box-shadow: none;
  }

  .hero-caption,
  .hero-native-note {
    color: var(--ink-3);
    font-size: 12.5px;
  }

  .hero-native-note {
    margin-top: 8px;
    color: var(--amber-deep);
    font-weight: 600;
  }

  .hero-demo {
    position: relative;
  }

  .live-label {
    position: absolute;
    top: -28px;
    left: 0;
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--ink-3);
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .live-label span {
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: var(--amber-deep);
    box-shadow: 0 0 8px var(--amber);
  }

  .crypto-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 16px;
  }

  .hero-waitlist {
    position: relative;
    padding: 0 32px 54px;
  }

  .hero-trust {
    position: relative;
    display: flex;
    flex-wrap: wrap;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    background: var(--paper);
  }

  .hero-trust .bb-trust-item {
    flex: 1 1 0;
    min-width: 200px;
  }

  .hero-trust .bb-trust-item.last {
    border-right: none;
  }

  .hero-trust .label {
    color: var(--ink-3);
  }

  .value {
    color: var(--ink-2);
    font-size: 13.5px;
    font-weight: 500;
  }

  @media (max-width: 900px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 56px;
      padding-top: 72px;
      padding-bottom: 64px;
    }
  }

  @media (max-width: 640px) {
    .hero-trust .bb-trust-item {
      border-right: 0 !important;
      border-bottom: 1px solid var(--line);
    }
  }
</style>
