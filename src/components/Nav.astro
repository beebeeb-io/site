---
import Button from './Button.astro';
import RegionBadge from './RegionBadge.astro';

interface Props {
  active?: string;
}

const { active } = Astro.props;

const links = [
  { label: 'Product', href: '/' },
  { label: 'For teams', href: '/' },
  { label: 'Security', href: '/security' },
  { label: 'Pricing', href: '/pricing' },
  { label: 'Open source', href: '/' },
];
---

<nav class="flex items-center gap-6 px-8 py-4 border-b border-line bg-paper">
  <a href="/" class="text-[15px] font-bold tracking-tight text-ink no-underline">
    beebeeb<span class="text-amber">.io</span>
  </a>
  <div class="flex gap-5 ml-5">
    {links.map((link) => (
      <a
        href={link.href}
        class:list={[
          'text-[13px] no-underline transition-colors duration-150',
          link.label === active ? 'text-ink font-semibold' : 'text-ink-2 hover:text-ink',
        ]}
      >
        {link.label}
      </a>
    ))}
  </div>
  <div class="ml-auto flex items-center gap-2">
    <RegionBadge />
    <Button variant="ghost" size="sm">Sign in</Button>
    <Button variant="amber" size="sm">Start free</Button>
  </div>
</nav>
