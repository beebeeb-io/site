---
interface Props {
  variant?: 'default' | 'amber' | 'ghost' | 'primary' | 'danger';
  size?: 'sm' | 'md' | 'lg';
  href?: string;
  class?: string;
}

const { variant = 'default', size = 'md', href, class: className } = Astro.props;

const baseClasses = 'inline-flex items-center gap-2 font-medium cursor-pointer transition-colors duration-150 border';

const variantClasses: Record<string, string> = {
  default: 'bg-paper border-line-2 text-ink hover:bg-paper-2',
  amber: 'bg-amber text-ink border-amber hover:brightness-105',
  ghost: 'bg-transparent border-transparent text-ink-2 hover:text-ink hover:bg-paper-2',
  primary: 'bg-ink text-paper border-ink hover:brightness-125',
  danger: 'bg-red text-paper border-red hover:brightness-110',
};

const sizeClasses: Record<string, string> = {
  sm: 'text-xs px-3 py-1.5 rounded-md',
  md: 'text-sm px-4 py-2 rounded-lg',
  lg: 'text-sm px-5 py-3 rounded-lg',
};

const classes = [baseClasses, variantClasses[variant], sizeClasses[size], className].filter(Boolean).join(' ');

const Tag = href ? 'a' : 'button';
---

{href ? (
  <a href={href} class={classes}>
    <slot />
  </a>
) : (
  <button class={classes}>
    <slot />
  </button>
)}
