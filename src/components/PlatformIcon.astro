---
interface Props {
  name: 'web' | 'cli' | 'macos' | 'windows' | 'linux' | 'ios' | 'android' | 'rclone';
}

const { name } = Astro.props as Props;
---

{name === 'web' && (
  <svg viewBox="0 0 24 24" aria-hidden="true">
    <circle cx="12" cy="12" r="9" fill="none" stroke="currentColor" stroke-width="1.8" />
    <path d="M3 12h18M12 3c2.2 2.4 3.2 5.4 3.2 9s-1 6.6-3.2 9c-2.2-2.4-3.2-5.4-3.2-9s1-6.6 3.2-9z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
  </svg>
)}

{name === 'cli' && (
  <svg viewBox="0 0 24 24" aria-hidden="true">
    <rect x="3.5" y="5.5" width="17" height="13" rx="2" fill="none" stroke="currentColor" stroke-width="1.8" />
    <path d="m7 10 3 2-3 2M12 15h5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
  </svg>
)}

{name === 'macos' && (
  <svg viewBox="0 0 24 24" aria-hidden="true">
    <path fill="currentColor" d="M16.7 12.5c0-2 1.6-3 1.7-3.1-1-1.4-2.4-1.6-2.9-1.7-1.2-.1-2.4.7-3 0.7-.6 0-1.6-.7-2.6-.7-1.3 0-2.6.8-3.3 2-1.4 2.4-.4 5.9 1 7.8.7.9 1.4 1.9 2.4 1.9s1.4-.6 2.6-.6c1.2 0 1.5.6 2.6.6s1.8-.9 2.4-1.8c.8-1.1 1.1-2.2 1.1-2.3-.1-.1-2-.8-2-2.8ZM14.7 6.4c.6-.7.9-1.6.8-2.5-.8 0-1.7.5-2.3 1.2-.5.6-.9 1.5-.8 2.4.9.1 1.8-.4 2.3-1.1Z" />
  </svg>
)}

{name === 'windows' && (
  <svg viewBox="0 0 24 24" aria-hidden="true">
    <path fill="currentColor" d="M4 5.5 11 4.6v6.7H4V5.5Zm8.5-1.1L20 3.3v8h-7.5V4.4ZM4 12.8h7v6.6l-7-.9v-5.7Zm8.5 0H20v7.9l-7.5-1.1v-6.8Z" />
  </svg>
)}

{name === 'linux' && (
  <svg viewBox="0 0 24 24" aria-hidden="true">
    <path fill="currentColor" d="M12.1 3.2c2.2 0 3.6 1.7 3.6 4.2 0 1.1.4 2.2 1.2 3.3.9 1.2 1.5 2.6 1.5 4 0 3.7-2.6 6.1-6.4 6.1s-6.4-2.4-6.4-6.1c0-1.4.5-2.8 1.5-4 .8-1 1.2-2.2 1.2-3.3 0-2.5 1.5-4.2 3.8-4.2Zm-2.2 10.7c-.7.6-1.1 1.4-1.1 2.3 0 1.8 1.3 3 3.2 3s3.2-1.2 3.2-3c0-.9-.4-1.7-1.1-2.3-.6.6-1.3.9-2.1.9-.8 0-1.5-.3-2.1-.9Zm.9-6.3a.9.9 0 1 0 0 1.8.9.9 0 0 0 0-1.8Zm2.6 0a.9.9 0 1 0 0 1.8.9.9 0 0 0 0-1.8Z" />
  </svg>
)}

{name === 'ios' && (
  <svg viewBox="0 0 24 24" aria-hidden="true">
    <rect x="7" y="2.75" width="10" height="18.5" rx="2.2" fill="none" stroke="currentColor" stroke-width="1.8" />
    <path d="M10.2 5.6h3.6M11.3 18h1.4" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
  </svg>
)}

{name === 'android' && (
  <svg viewBox="0 0 24 24" aria-hidden="true">
    <path d="M7.5 9.2h9v8.4a2 2 0 0 1-2 2h-5a2 2 0 0 1-2-2V9.2ZM7.7 6.2 6.3 4.8M16.3 6.2l1.4-1.4" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
    <path d="M7.5 9.2c0-2.2 1.8-4 4.5-4s4.5 1.8 4.5 4" fill="none" stroke="currentColor" stroke-width="1.8" />
    <circle cx="10" cy="7.7" r=".55" fill="currentColor" />
    <circle cx="14" cy="7.7" r=".55" fill="currentColor" />
  </svg>
)}

{name === 'rclone' && (
  <svg viewBox="0 0 24 24" aria-hidden="true">
    <path d="M12 3v18M3 12h18M5.6 5.6l12.8 12.8M18.4 5.6 5.6 18.4" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
  </svg>
)}
