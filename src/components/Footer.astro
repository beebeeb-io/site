---
import type { PhaseConfig } from '../lib/phase';
import { phaseConfig } from '../lib/phase';

interface Props {
  cfg?: PhaseConfig;
}

const { cfg: providedCfg } = Astro.props;
const cfg = providedCfg ?? phaseConfig();

const releasesHref = 'https://github.com/beebeeb-io/releases';
const appLinks = [
  { label: 'CLI', href: releasesHref, live: cfg.cliLive, external: true },
  { label: 'macOS', href: releasesHref, live: cfg.desktopLive, external: true },
  { label: 'Windows', href: releasesHref, live: cfg.desktopLive, external: true },
  { label: 'Linux', href: releasesHref, live: cfg.desktopLive, external: true },
  { label: 'iOS', href: releasesHref, live: cfg.iosLive, external: true },
  { label: 'Android', href: releasesHref, live: cfg.androidLive, external: true },
  { label: 'rclone backend', href: releasesHref, live: cfg.rcloneLive, external: true },
];

const columns = [
  { title: 'Get the apps', items: appLinks },
  {
    title: 'Security',
    items: [
      { label: 'How it works', href: '/#how' },
      { label: 'GitHub', href: 'https://github.com/beebeeb-io', external: true },
    ],
  },
  {
    title: 'Plans',
    items: [
      { label: 'Pricing', href: '/pricing' },
      { label: 'Compare plans', href: '/pricing' },
    ],
  },
  {
    title: 'Company',
    items: [
      { label: 'Support', href: '/support' },
      { label: 'Contact', href: 'mailto:hello@beebeeb.io' },
      { label: 'Legal', href: '/legal' },
      { label: 'Privacy', href: '/privacy' },
      { label: 'Terms', href: '/terms' },
      { label: 'Cookies', href: '/cookies' },
    ],
  },
];
---

<footer class="bb-launch-footer">
  <div class="bb-footer-container">
    <div class="bb-footer-grid">
      <div>
        <a href="/" class="bb-footer-logo" aria-label="Beebeeb.io home">
          <img src="/assets/beebeeb-logo.png" alt="beebeeb.io" />
        </a>
        <p class="bb-footer-tagline">
          End-to-end encrypted cloud storage.<br />
          Built in Europe, under EU law.
        </p>
        <div class="bb-footer-contact t-mono">hello@beebeeb.io</div>
      </div>

      {columns.map((column) => (
        <div>
          <div class="t-label">{column.title}</div>
          <div class="bb-footer-links">
            {column.items.map((item) => (
              <a
                href={item.href}
                target={item.external ? '_blank' : undefined}
                rel={item.external ? 'noopener noreferrer' : undefined}
              >
                {item.label}{item.live === false ? ' (coming soon)' : ''}
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>

    <div class="bb-footer-bottom">
      <span>&copy; 2026 Beebeeb.io</span>
      <span class="bb-footer-dot">&middot;</span>
      <span class="t-mono">Stored in Europe</span>
      <span class="bb-footer-dot">&middot;</span>
      <span class="t-mono">Operated under EU law</span>
      <span class="bb-footer-spacer"></span>
      <a href="https://github.com/beebeeb-io" target="_blank" rel="noopener noreferrer">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .5C5.7.5.7 5.6.7 11.9c0 5 3.3 9.3 7.8 10.8.6.1.8-.2.8-.6v-2c-3.2.7-3.8-1.5-3.8-1.5-.5-1.3-1.3-1.6-1.3-1.6-1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.7-1.6-2.5-.3-5.2-1.3-5.2-5.7 0-1.3.4-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.2 1.2.9-.3 1.9-.4 2.9-.4s2 .1 2.9.4c2.2-1.5 3.2-1.2 3.2-1.2.6 1.6.2 2.8.1 3.1.7.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.2 5.7.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6 4.5-1.5 7.8-5.8 7.8-10.8C23.3 5.6 18.3.5 12 .5z"/></svg>
        github.com/beebeeb-io
      </a>
    </div>
  </div>
</footer>

<style>
  .bb-launch-footer {
    padding: 56px 32px 28px;
    border-top: 1px solid var(--line, var(--color-line));
    background: var(--paper-2, var(--color-paper-2));
  }

  .bb-footer-container {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
  }

  .bb-footer-grid {
    display: grid;
    grid-template-columns: 1.6fr repeat(4, 1fr);
    gap: 32px;
    margin-bottom: 40px;
  }

  .bb-footer-logo {
    display: inline-flex;
    align-items: center;
  }

  .bb-footer-logo img {
    width: auto;
    height: 15px;
  }

  .bb-footer-tagline {
    max-width: 280px;
    margin: 14px 0 0;
    color: var(--ink-3, var(--color-ink-3));
    font-size: 12.5px;
    line-height: 1.7;
  }

  .bb-footer-contact {
    margin-top: 16px;
    color: var(--ink-4, var(--color-ink-4));
    font-size: 10.5px;
  }

  .t-mono {
    font-family: var(--font-mono);
  }

  .t-label {
    margin-bottom: 12px;
    color: var(--ink-3, var(--color-ink-3));
    font-family: var(--font-mono);
    font-size: 10.5px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .bb-footer-links {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .bb-footer-links a,
  .bb-footer-muted {
    color: var(--ink-2, var(--color-ink-2));
    font-size: 13px;
    line-height: 1.5;
  }

  .bb-footer-links a {
    text-decoration: none;
    transition: color 150ms ease;
  }

  .bb-footer-links a:hover {
    color: var(--ink, var(--color-ink));
  }

  .bb-footer-muted {
    color: var(--ink-4, var(--color-ink-4));
    cursor: default;
  }

  .bb-footer-bottom {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 12px;
    padding-top: 24px;
    border-top: 1px solid var(--line, var(--color-line));
    color: var(--ink-3, var(--color-ink-3));
    font-size: 11.5px;
  }

  .bb-footer-bottom a {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--ink-3, var(--color-ink-3));
    text-decoration: none;
  }

  .bb-footer-bottom a:hover {
    color: var(--ink, var(--color-ink));
  }

  .bb-footer-spacer {
    flex: 1;
    min-width: 12px;
  }

  @media (max-width: 900px) {
    .bb-footer-grid {
      grid-template-columns: 1.4fr 1fr 1fr;
    }
  }

  @media (max-width: 640px) {
    .bb-launch-footer {
      padding-inline: 20px;
    }

    .bb-footer-grid {
      grid-template-columns: 1fr;
    }

    .bb-footer-dot,
    .bb-footer-spacer {
      display: none;
    }
  }
</style>
