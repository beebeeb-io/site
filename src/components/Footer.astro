---
const columns = [
  { title: 'Product', items: [
    { label: 'Drive', href: '#' },
    { label: 'Photos', href: '#' },
    { label: 'Sharing', href: '#' },
    { label: 'Team vaults', href: '#' },
    { label: 'Desktop apps', href: '#' },
  ]},
  { title: 'Security', items: [
    { label: 'How it works', href: '/security' },
    { label: 'Audits', href: '#' },
    { label: 'Warrant canary', href: '#' },
    { label: 'Bug bounty', href: '/bug-bounty' },
    { label: 'Whitepaper', href: '#' },
  ]},
  { title: 'Company', items: [
    { label: 'About', href: '/about' },
    { label: 'Careers', href: '/careers' },
    { label: 'GitHub', href: 'https://github.com/beebeeb-io' },
    { label: 'Contact', href: '#' },
  ]},
  { title: 'Legal', items: [
    { label: 'Terms', href: '/terms' },
    { label: 'Privacy', href: '/privacy' },
    { label: 'DPA', href: '#' },
    { label: 'Sub-processors', href: '#' },
    { label: 'Imprint', href: '/imprint' },
  ]},
];
---

<footer class="bg-ink text-paper" style="padding: 48px 32px 32px;">
  <div class="max-w-[1100px] mx-auto">
    <div class="grid grid-cols-[2fr_1fr_1fr_1fr_1fr] gap-10 mb-10" style="grid-template-columns: 2fr 1fr 1fr 1fr 1fr;">
      <div>
        <a href="/" class="text-[15px] font-bold tracking-tight text-paper no-underline">
          beebeeb<span class="text-amber">.io</span>
        </a>
        <div class="text-xs mt-3 leading-relaxed max-w-[260px]" style="color: oklch(0.75 0.01 80);">
          End-to-end encrypted cloud, made in Europe. Zero-knowledge by architecture, not by promise.
        </div>
        <div class="mt-4 inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[11px]" style="background: oklch(0.3 0.01 90); border: 1px solid oklch(0.35 0.01 90);">
          <span class="w-1.5 h-1.5 rounded-full" style="background: oklch(0.7 0.14 155);"></span>
          <span style="color: oklch(0.75 0.01 80);">Frankfurt &middot; Amsterdam &middot; Paris</span>
        </div>
      </div>
      {columns.map((col) => (
        <div>
          <div class="text-[11px] font-semibold tracking-[0.04em] uppercase mb-3" style="color: oklch(0.6 0.01 80);">
            {col.title}
          </div>
          <div class="flex flex-col gap-[7px]">
            {col.items.map((item) => (
              item.href === '#'
                ? <span class="text-[12.5px] cursor-default" style="color: oklch(0.55 0.01 80);">{item.label}</span>
                : <a href={item.href} class="text-[12.5px] no-underline transition-opacity duration-150 hover:opacity-100" style="color: oklch(0.75 0.01 80);">{item.label}</a>
            ))}
          </div>
        </div>
      ))}
    </div>
    <div class="pt-6 flex items-center gap-4 text-[11.5px] flex-wrap" style="border-top: 1px solid oklch(0.3 0.01 90); color: oklch(0.6 0.01 80);">
      <span>&copy; 2026 Initlabs B.V. &middot; KvK 95157565 &middot; Wijchen, Netherlands</span>
      <span>&middot;</span>
      <a href="/status" class="inline-flex items-center gap-1.5 no-underline transition-opacity hover:opacity-80" style="color: oklch(0.6 0.01 80);">
        <span class="w-1.5 h-1.5 rounded-full" style="background: oklch(0.7 0.14 155);"></span>
        All systems operational
      </a>
      <span class="ml-auto" style="color: oklch(0.55 0.01 80);">Designed and built in the EU.</span>
    </div>
  </div>
</footer>
