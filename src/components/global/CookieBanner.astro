<!-- Cookie consent banner + settings modal -->

<div id="bb-cookie-banner" class="bb-cookie-banner" role="region" aria-label="Cookie consent" hidden>
  <div class="bb-cookie-banner-inner">
    <p class="bb-cookie-banner-text">
      We use cookieless analytics to improve Beebeeb. No tracking, no ads.
    </p>
    <div class="bb-cookie-banner-actions">
      <button id="bb-cookie-accept" class="bb-cookie-btn bb-cookie-btn--primary" type="button">Accept</button>
      <button id="bb-cookie-decline" class="bb-cookie-btn bb-cookie-btn--secondary" type="button">Decline</button>
      <button id="bb-cookie-manage" class="bb-cookie-btn bb-cookie-btn--text" type="button">Manage</button>
    </div>
  </div>
</div>

<dialog id="bb-cookie-dialog" class="bb-cookie-dialog" aria-label="Cookie settings">
  <div class="bb-cookie-dialog-inner">
    <div class="bb-cookie-dialog-header">
      <h2 class="bb-cookie-dialog-title">Cookie settings</h2>
      <button id="bb-cookie-dialog-close" class="bb-cookie-dialog-close" type="button" aria-label="Close">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
          <line x1="4" y1="4" x2="12" y2="12" /><line x1="12" y1="4" x2="4" y2="12" />
        </svg>
      </button>
    </div>

    <div class="bb-cookie-category">
      <div class="bb-cookie-category-header">
        <div>
          <span class="bb-cookie-category-name">Essential</span>
          <span class="bb-cookie-category-badge">Always on</span>
        </div>
        <label class="bb-cookie-toggle bb-cookie-toggle--disabled">
          <input type="checkbox" checked disabled />
          <span class="bb-cookie-toggle-track"></span>
        </label>
      </div>
      <p class="bb-cookie-category-desc">
        Session, security, and language preferences. Required for the service to function.
      </p>
    </div>

    <div class="bb-cookie-category">
      <div class="bb-cookie-category-header">
        <div>
          <span class="bb-cookie-category-name">Analytics</span>
        </div>
        <label class="bb-cookie-toggle">
          <input type="checkbox" id="bb-cookie-analytics-toggle" />
          <span class="bb-cookie-toggle-track"></span>
        </label>
      </div>
      <p class="bb-cookie-category-desc">
        Cookieless analytics via Matomo. Helps us understand how people use Beebeeb. No personal data is collected.
      </p>
    </div>

    <div class="bb-cookie-dialog-footer">
      <button id="bb-cookie-save" class="bb-cookie-btn bb-cookie-btn--primary" type="button">Save preferences</button>
    </div>
  </div>
</dialog>

<script is:inline>
(function () {
  var COOKIE_NAME = 'bb_consent';
  var MAX_AGE = 31536000; // 12 months

  function getConsent() {
    try {
      var match = document.cookie.split('; ').find(function (c) { return c.startsWith(COOKIE_NAME + '='); });
      if (!match) return null;
      return JSON.parse(decodeURIComponent(match.split('=')[1]));
    } catch (e) {
      return null;
    }
  }

  function setConsent(analytics) {
    var value = JSON.stringify({ analytics: analytics });
    document.cookie = COOKIE_NAME + '=' + encodeURIComponent(value) + '; max-age=' + MAX_AGE + '; path=/; SameSite=Lax';
    document.dispatchEvent(new CustomEvent('bb:consent-changed', { detail: { analytics: analytics } }));
  }

  function hideBanner() {
    var banner = document.getElementById('bb-cookie-banner');
    if (banner) {
      banner.classList.add('bb-cookie-banner--hiding');
      setTimeout(function () { banner.hidden = true; }, 300);
    }
  }

  function showBanner() {
    var banner = document.getElementById('bb-cookie-banner');
    if (banner) {
      banner.hidden = false;
      // Force reflow so the animation plays
      banner.offsetHeight;
      banner.classList.add('bb-cookie-banner--visible');
    }
  }

  function openDialog() {
    var dialog = document.getElementById('bb-cookie-dialog');
    var toggle = document.getElementById('bb-cookie-analytics-toggle');
    if (!dialog) return;
    var consent = getConsent();
    if (toggle) toggle.checked = consent ? consent.analytics : false;
    dialog.showModal();
  }

  function closeDialog() {
    var dialog = document.getElementById('bb-cookie-dialog');
    if (dialog) dialog.close();
  }

  function init() {
    var consent = getConsent();

    // Show banner if no consent recorded
    if (!consent) {
      showBanner();
    }

    // Banner buttons
    var acceptBtn = document.getElementById('bb-cookie-accept');
    var declineBtn = document.getElementById('bb-cookie-decline');
    var manageBtn = document.getElementById('bb-cookie-manage');

    if (acceptBtn) acceptBtn.addEventListener('click', function () { setConsent(true); hideBanner(); });
    if (declineBtn) declineBtn.addEventListener('click', function () { setConsent(false); hideBanner(); });
    if (manageBtn) manageBtn.addEventListener('click', function () { hideBanner(); openDialog(); });

    // Dialog buttons
    var closeBtn = document.getElementById('bb-cookie-dialog-close');
    var saveBtn = document.getElementById('bb-cookie-save');

    if (closeBtn) closeBtn.addEventListener('click', closeDialog);
    if (saveBtn) saveBtn.addEventListener('click', function () {
      var toggle = document.getElementById('bb-cookie-analytics-toggle');
      setConsent(toggle ? toggle.checked : false);
      closeDialog();
    });

    // Footer "Cookie settings" link
    document.querySelectorAll('[data-cookie-settings]').forEach(function (el) {
      el.addEventListener('click', function (e) {
        e.preventDefault();
        openDialog();
      });
    });

    // Close dialog on backdrop click
    var dialog = document.getElementById('bb-cookie-dialog');
    if (dialog) {
      dialog.addEventListener('click', function (e) {
        if (e.target === dialog) closeDialog();
      });
    }
  }

  // Run on initial load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }

  // Re-init after Astro view transitions
  document.addEventListener('astro:after-swap', init);
})();
</script>

<style>
