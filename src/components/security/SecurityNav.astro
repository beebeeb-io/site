---
interface Props {
  showCanary?: boolean;
}

const { showCanary = false } = Astro.props;

const sections = [
  { id: 'journey', label: 'Journey' },
  { id: 'stack', label: 'Stack' },
  { id: 'keys', label: 'Keys' },
  { id: 'sharing', label: 'Sharing' },
  { id: 'threat-model', label: 'Threat model' },
  { id: 'infrastructure', label: 'Infrastructure' },
  { id: 'legal', label: 'Legal' },
  ...(showCanary ? [{ id: 'canary', label: 'Canary' }] : []),
  { id: 'open-source', label: 'Open source' },
  { id: 'disclosure', label: 'Disclosure' },
  { id: 'changelog', label: 'Changelog' },
];
---

<div class="security-section-nav" role="navigation" aria-label="Security page sections">
  <div class="bb-container nav-scroll">
    <span>Jump to</span>
    {sections.map((section) => (
      <a href={`#${section.id}`} data-section-link={section.id}>
        {section.label}
      </a>
    ))}
  </div>
</div>

<script>
  const nav = document.querySelector('.security-section-nav');
  const links = Array.from(document.querySelectorAll('[data-section-link]'));
  const sections = Array.from(document.querySelectorAll('[data-security-section]'));

  function setActive(id) {
    links.forEach((link) => {
      link.toggleAttribute('aria-current', link.getAttribute('data-section-link') === id);
    });
  }

  if (nav && links.length && sections.length) {
    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((entry) => entry.isIntersecting)
          .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
        if (visible && visible.target.id) {
          setActive(visible.target.id);
        }
      },
      {
        rootMargin: '-35% 0px -55% 0px',
        threshold: [0.1, 0.25, 0.5, 0.75],
      },
    );

    sections.forEach((section) => observer.observe(section));
    setActive(sections[0].id);
  }
</script>

<style>
  .security-section-nav {
    position: sticky;
    top: 49px;
    z-index: 40;
    border-bottom: 1px solid var(--line);
    background: oklch(0.985 0.004 85 / 0.92);
    backdrop-filter: blur(8px);
  }

  .nav-scroll {
    display: flex;
    align-items: center;
    gap: 4px;
    overflow-x: auto;
    padding: 12px 32px;
    scrollbar-width: none;
  }

  .nav-scroll::-webkit-scrollbar {
    display: none;
  }

  span {
    flex: 0 0 auto;
    margin-right: 10px;
    color: var(--ink-4);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  a {
    flex: 0 0 auto;
    padding: 6px 12px;
    border-radius: 6px;
    color: var(--ink-2);
    font-size: 12.5px;
    font-weight: 500;
    text-decoration: none;
    transition:
      background 150ms ease,
      color 150ms ease;
  }

  a:hover,
  a[aria-current='true'] {
    background: var(--paper);
    color: var(--ink);
  }

  @media (max-width: 840px) {
    .security-section-nav {
      top: 50px;
    }

    .nav-scroll {
      padding-inline: 20px;
    }

    span {
      display: none;
    }
  }
</style>
