---
const points = [
  {
    n: '01',
    t: 'We cannot read your files.',
    d: 'Files are encrypted on your device with keys we never see. What lands on our servers is opaque ciphertext.',
  },
  {
    n: '02',
    t: 'We cannot recover your password.',
    d: 'If you lose your password and your recovery phrase, your data is gone. By design — the alternative is a backdoor. Which we don’t offer.',
  },
  {
    n: '03',
    t: 'We comply with EU law.',
    d: 'When legally compelled, we hand over what we have. What we have is ciphertext. Nothing decryptable.',
  },
];
---

<section class="security-hero">
  <div class="bb-container">
    <div class="bb-eyebrow">Security</div>
    <h1 class="bb-display-xl">
      Three things you<br />
      should know about us.
    </h1>

    <div class="hero-points">
      {points.map((p, i) => (
        <article class="hero-point" data-edge={i < 2 ? 'right' : undefined}>
          <div class="bb-step-num">{p.n} / 03</div>
          <h2>{p.t}</h2>
          <p>{p.d}</p>
        </article>
      ))}
    </div>

    <p class="hero-reviewed">
      This page describes what Beebeeb does, how, and where we draw the line.
      It does not describe what we hope to do. Last reviewed: <span>06 May 2026</span>.
    </p>
  </div>
</section>

<style>
  .security-hero {
    padding: 120px 32px 96px;
    border-bottom: 1px solid var(--line);
    background: var(--paper);
    color: var(--ink);
  }

  .security-hero .bb-container {
    padding: 0;
  }

  .security-hero .bb-eyebrow {
    margin-bottom: 22px;
  }

  .security-hero h1 {
    max-width: 1100px;
    margin: 0 0 48px;
    font-size: clamp(40px, 5vw, 72px);
  }

  .hero-points {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: 12px;
    background: var(--paper);
  }

  .hero-point {
    display: flex;
    min-height: 240px;
    flex-direction: column;
    gap: 14px;
    padding: 32px 28px;
  }

  .hero-point[data-edge='right'] {
    border-right: 1px solid var(--line);
  }

  .hero-point h2 {
    margin: 0;
    color: var(--ink);
    font-size: 22px;
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .hero-point p {
    margin: 0;
    color: var(--ink-2);
    font-size: 14px;
    line-height: 1.65;
    text-wrap: pretty;
  }

  .hero-reviewed {
    margin: 36px 0 14px;
    color: var(--ink-3);
    font-family: var(--font-mono);
    font-size: 14px;
    letter-spacing: 0.02em;
  }

  .hero-reviewed span {
    color: var(--ink-2);
  }

  @media (max-width: 860px) {
    .security-hero {
      padding: 96px 24px 76px;
    }

    .hero-points {
      grid-template-columns: 1fr;
    }

    .hero-point {
      min-height: 0;
      border-right: 0;
      border-bottom: 1px solid var(--line);
    }

    .hero-point:last-child {
      border-bottom: 0;
    }
  }

  @media (max-width: 640px) {
    .security-hero {
      padding: 78px 20px 64px;
    }
  }
</style>
