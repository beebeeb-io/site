---
const primitives = ['AES-256-GCM', 'HKDF-SHA256', 'OPAQUE PAKE', 'X25519', 'Argon2id', 'BIP39'];

const points = [
  {
    n: '01',
    t: 'We cannot read your files.',
    d: 'Files are encrypted on your device with keys we never see. What lands on our servers is opaque ciphertext.',
  },
  {
    n: '02',
    t: 'We cannot recover your password.',
    d: 'If you lose your password and your recovery phrase, your data is gone. By design — the alternative is a backdoor. Which we don’t offer.',
  },
  {
    n: '03',
    t: 'We comply with EU law.',
    d: 'When legally compelled, we hand over what we have. What we have is ciphertext. Nothing decryptable.',
  },
];
---

<section id="overview" class="security-hero" data-security-section>
  <div class="security-container">
    <div class="bb-eyebrow">Security</div>
    <h1 class="bb-display-xl">
      Three things you<br />
      should know about us.
    </h1>

    <div class="hero-chips" aria-label="Cryptographic primitives">
      {primitives.map((primitive) => <span class="crypto-chip">{primitive}</span>)}
    </div>

    <div class="hero-points">
      {points.map((p, i) => (
        <article class="hero-point">
          <div class="bb-step-num">{p.n} / 03</div>
          <h2>{p.t}</h2>
          <p>{p.d}</p>
        </article>
      ))}
    </div>

    <p class="hero-reviewed">
      This page describes what Beebeeb does, how, and where we draw the line.
      It does not describe what we hope to do. Last reviewed: <span>06 May 2026</span>.
    </p>
  </div>
</section>

<style>
  .security-hero {
    padding: 120px 32px 96px;
    border-bottom: 1px solid oklch(0.34 0.014 70);
    background:
      radial-gradient(ellipse at 20% 0%, oklch(0.30 0.02 70) 0%, transparent 48%),
      radial-gradient(ellipse at 85% 35%, oklch(0.25 0.018 62) 0%, transparent 48%),
      var(--ink);
    color: var(--paper);
  }

  .security-hero .bb-eyebrow {
    margin-bottom: 22px;
    color: oklch(0.78 0.01 80);
  }

  .security-hero h1 {
    max-width: 1100px;
    margin: 0 0 28px;
  }

  .hero-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 48px;
  }

  .hero-chips .crypto-chip {
    border-color: oklch(0.42 0.014 70);
    background: oklch(0.24 0.012 70);
    color: oklch(0.90 0.006 80);
  }

  .hero-points {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    overflow: hidden;
    border: 1px solid oklch(0.38 0.012 70);
    border-radius: 12px;
    background: oklch(0.22 0.012 70);
  }

  .hero-point {
    display: flex;
    min-height: 240px;
    flex-direction: column;
    gap: 14px;
    padding: 32px 28px;
    border-right: 1px solid oklch(0.38 0.012 70);
  }

  .hero-point:last-child {
    border-right: 0;
  }

  .hero-point h2 {
    margin: 0;
    color: var(--paper);
    font-size: 22px;
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .hero-point p {
    margin: 0;
    color: oklch(0.76 0.008 80);
    font-size: 14px;
    line-height: 1.65;
    text-wrap: pretty;
  }

  .hero-reviewed {
    margin: 36px 0 0;
    color: oklch(0.66 0.008 80);
    font-family: var(--font-mono);
    font-size: 14px;
    letter-spacing: 0.02em;
  }

  .hero-reviewed span {
    color: oklch(0.82 0.008 80);
  }

  @media (max-width: 860px) {
    .security-hero {
      padding: 96px 24px 76px;
    }

    .hero-points {
      grid-template-columns: 1fr;
    }

    .hero-point {
      min-height: 0;
      border-right: 0;
      border-bottom: 1px solid oklch(0.38 0.012 70);
    }

    .hero-point:last-child {
      border-bottom: 0;
    }
  }

  @media (max-width: 640px) {
    .security-hero {
      padding: 78px 20px 64px;
    }
  }
</style>
