---
const repos = [
  ['core', 'Cryptographic core, shared types, sync engine', 'Rust', 'github.com/beebeeb-io/core'],
  ['web', 'Web client — encrypted file management in your browser', 'TypeScript', 'github.com/beebeeb-io/web'],
  ['cli', 'bb — your vault from the terminal', 'Rust', 'github.com/beebeeb-io/cli'],
  ['desktop', 'Desktop sync for macOS, Windows, and Linux', 'Swift / Rust', 'github.com/beebeeb-io/desktop'],
  ['mobile', 'iOS and Android, React Native', 'TypeScript', 'github.com/beebeeb-io/mobile'],
  ['rclone-backend', 'Rclone backend — mount your vault as a drive', 'Go', 'github.com/beebeeb-io/rclone-backend'],
];

const verifySteps = [
  'Clone the repo at the commit SHA listed on the release page.',
  'Read core/src/ — everything that touches your keys is in there. About 1,500 lines.',
  'Build the client locally and compare its behaviour to what this page describes. The only data leaving your machine should be ciphertext, the wrapped per-file key, and OPAQUE protocol messages.',
  'Use a network proxy to confirm. We’d rather you verify than trust.',
];
---

<section id="open-source" class="security-section alt open-source-section" data-security-section>
  <div class="code-backdrop" aria-hidden="true"></div>
  <div class="security-container">
    <div class="security-kicker">
      <div class="bb-eyebrow">Verifiability</div>
      <h2 class="bb-display-l">Read the code yourself.</h2>
      <p>
        Every piece of software that handles your encryption keys is open source.
        If we said one thing on this page and shipped another, the code would show it.
      </p>
    </div>

    <div class="repo-grid">
      {repos.map(([repo, desc, lang, url]) => (
        <a class="repo-card" href={`https://${url}`} target="_blank" rel="noopener noreferrer">
          <span class="repo-head">
            <span class="t-mono">{repo}</span>
            <span class="t-mono">{lang}</span>
          </span>
          <span>{desc}</span>
          <span class="repo-url">{url} →</span>
        </a>
      ))}
    </div>

    <article class="verify-card">
      <div class="t-label">How to verify a release</div>
      <ol>
        {verifySteps.map((step) => (
          <li>
            {step.includes('core/src/') ? (
              <>
                Read <code>core/src/</code> — everything that touches your keys is in there. About 1,500 lines.
              </>
            ) : (
              step
            )}
          </li>
        ))}
      </ol>
      <div class="audit-note">
        <strong>On audits:</strong> we have not yet had a third-party
        cryptographic audit. Our clients are open source so anyone can review them today.
        We will publish audit results here when we have them.
      </div>
    </article>
  </div>
</section>

<style>
  .open-source-section {
    position: relative;
    overflow: hidden;
  }

  .code-backdrop {
    position: absolute;
    inset: 0;
    background-image: repeating-linear-gradient(0deg, transparent, transparent 22px, oklch(0.18 0.01 70) 22px, oklch(0.18 0.01 70) 23px);
    mask-image: radial-gradient(ellipse at center, black 30%, transparent 75%);
    opacity: 0.05;
    pointer-events: none;
  }

  .security-container {
    position: relative;
  }

  .repo-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
    margin-bottom: 32px;
  }

  .repo-card {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 24px 26px;
    border: 1px solid var(--line);
    border-radius: 10px;
    background: var(--paper);
    color: inherit;
    text-decoration: none;
    transition: border-color 150ms ease, transform 150ms ease;
  }

  .repo-card:hover {
    border-color: var(--ink-3);
    transform: translateY(-1px);
  }

  .repo-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
  }

  .repo-head span:first-child {
    color: var(--ink);
    font-size: 13.5px;
    font-weight: 600;
  }

  .repo-head span:last-child {
    color: var(--ink-3);
    font-size: 10px;
    letter-spacing: 0.06em;
  }

  .repo-card > span:nth-child(2) {
    color: var(--ink-2);
    font-size: 13.5px;
    line-height: 1.5;
  }

  .repo-url {
    margin-top: 4px;
    color: var(--amber-deep);
    font-family: var(--font-mono);
    font-size: 11px;
  }

  .verify-card {
    padding: 24px 28px;
    border: 1px solid var(--line);
    border-radius: 10px;
    background: var(--paper);
  }

  .verify-card .t-label {
    margin-bottom: 12px;
    color: var(--ink);
  }

  .verify-card ol {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin: 0;
    padding-left: 22px;
    color: var(--ink-2);
    font-size: 13.5px;
    line-height: 1.6;
  }

  .verify-card code {
    padding: 1px 5px;
    border-radius: 3px;
    background: var(--paper-2);
    font-family: var(--font-mono);
    font-size: 12px;
  }

  .audit-note {
    margin-top: 18px;
    padding-top: 16px;
    border-top: 1px dashed var(--line-2);
    color: var(--ink-3);
    font-size: 13px;
    line-height: 1.6;
    text-wrap: pretty;
  }

  .audit-note strong {
    color: var(--ink-2);
  }

  @media (max-width: 760px) {
    .repo-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
